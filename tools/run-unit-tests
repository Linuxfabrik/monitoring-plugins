"""Discover and run all plugin unit tests.

Each unit test is executed from its own directory
(`check-plugins/<name>/unit-test/`) because the test files use
relative paths for test data and plugin references.

Unit tests come in two shapes:

- **fast tests**: pure-Python tests that use `--test` fixtures and
  run in well under a second. These are safe to run in the multi-
  Python-version tox matrix.
- **container tests**: tests that start a podman container (either
  by building a per-distro image from `containerfiles/` or by
  pulling an upstream service image), inject the plugin plus
  `lib/`, and exercise the check against a live service. They take
  minutes per plugin and need podman. They are not safe for the
  tox matrix and get their own runner (`tools/run-container-tests`).
  A unit test counts as a container test when its `run` file
  references testcontainers-python or one of the lib.lftest
  container helpers (see `CONTAINER_TEST_SIGNATURES` below).

Usage:
    tools/run-unit-tests                 # run everything
    tools/run-unit-tests --no-container  # skip container tests
    tools/run-unit-tests --only-container  # run only container tests
    tools/run-unit-tests disk-smart      # run one plugin
    tools/run-unit-tests disk-smart xml  # run specific plugins
    tools/run-unit-tests --no-container procs  # flags + plugins mix

When specific plugins are requested on the command line, filters
like `--no-container` still apply.
"""

import argparse
import os
import subprocess
import sys

import _common

__author__ = 'Linuxfabrik GmbH, Zurich/Switzerland'
__version__ = '2026041301'


# Signatures that identify a real container-driven unit test. These
# must be precise substring matches: a plain keyword like `podman`
# would also fire on comments, docstrings, or on plugins whose name
# happens to contain `podman` (e.g. `podman-info`, `podman-stats`),
# which used to cause fixture-based tests to be silently skipped by
# the multi-Python matrix.
CONTAINER_TEST_SIGNATURES = (
    'import testcontainers',
    'from testcontainers',
    'lib.lftest.run_container(',
    'lib.lftest.run_mariadb(',
    'DockerContainer(',
    'DockerImage(',
)


def is_container_test(plugin_dir):
    """Return True if the plugin's unit test drives a container runtime.

    We look at the `run` file's content rather than at the presence
    of a `containerfiles/` subdirectory: a plugin may keep
    containerfiles around for a future testcontainers migration
    while its `run` file is already fixture-based and fast.
    """
    run_file = plugin_dir / 'unit-test' / 'run'
    try:
        content = run_file.read_text(encoding='utf-8')
    except OSError:
        return False
    return any(sig in content for sig in CONTAINER_TEST_SIGNATURES)


def ensure_podman_env():
    """Pre-flight environment setup for testcontainers under rootless podman.

    Linuxfabrik runs podman, not docker, so the user-facing env var
    is `CONTAINER_HOST` (matching the Linux container ecosystem
    convention used by `podman --remote`, buildah, skopeo etc.).
    testcontainers-python only knows about `DOCKER_HOST` internally,
    so this helper accepts either variable as input and always
    populates `DOCKER_HOST` for testcontainers to consume.

    The defaults if neither variable is set:
    - `unix:///run/user/$UID/podman/podman.sock` (rootless podman)
    - `TESTCONTAINERS_RYUK_DISABLED=true` (the Ryuk reaper hangs on
      rootless podman because its DinD container cannot reach back
      to the parent socket)

    Already-set values are preserved so callers running on a real
    docker host or with a custom socket override are not affected.
    """
    container_host = os.environ.get('CONTAINER_HOST') or os.environ.get('DOCKER_HOST')
    if container_host is None:
        container_host = f'unix:///run/user/{os.getuid()}/podman/podman.sock'
    # testcontainers-python only reads DOCKER_HOST, so always populate it.
    os.environ['DOCKER_HOST'] = container_host

    if 'TESTCONTAINERS_RYUK_DISABLED' not in os.environ:
        os.environ['TESTCONTAINERS_RYUK_DISABLED'] = 'true'


def parse_args():
    """Parse command line arguments using argparse."""
    parser = argparse.ArgumentParser(
        description=__doc__.strip().split('\n\n')[0],
    )

    parser.add_argument(
        '-V',
        '--version',
        action='version',
        version=f'%(prog)s: v{__version__} by {__author__}',
    )

    group = parser.add_mutually_exclusive_group()
    group.add_argument(
        '--no-container',
        action='store_true',
        help='Skip container-based unit tests.',
    )
    group.add_argument(
        '--only-container',
        action='store_true',
        help='Run only container-based unit tests. '
             'Used by tools/run-container-tests.',
    )

    parser.add_argument(
        'plugins',
        nargs='*',
        help='Optional list of plugin names to restrict the run to.',
    )

    return parser.parse_args()


def discover_plugins(args):
    """Return the list of plugin directories that should be executed."""
    requested = set(args.plugins) if args.plugins else None

    plugins = []
    # When a plugin is explicitly requested on the command line we run
    # it even if it would normally be in the skip set (the `example`
    # skeleton); otherwise we honour the default skip set.
    skip = frozenset() if requested else _common.SKIP_PLUGINS
    for plugin_dir in _common.iter_check_plugins(skip=skip):
        if requested is not None and plugin_dir.name not in requested:
            continue
        if not (plugin_dir / 'unit-test' / 'run').is_file():
            continue
        container = is_container_test(plugin_dir)
        if args.no_container and container:
            continue
        if args.only_container and not container:
            continue
        plugins.append(plugin_dir)
    return plugins


def main():
    """Find and run unit tests, report results."""
    args = parse_args()

    plugins = discover_plugins(args)
    if not plugins:
        print('No unit tests found.')
        return 0

    # If any of the discovered tests will spin up a container, set
    # the rootless-podman env vars so the user does not have to
    # remember them. Already-set values are preserved.
    if any(is_container_test(p) for p in plugins):
        ensure_podman_env()

    passed = []
    failed = []
    total = len(plugins)

    for i, plugin_dir in enumerate(plugins, 1):
        unit_test_dir = plugin_dir / 'unit-test'
        print(f'[{i}/{total}] {plugin_dir.name}', flush=True)

        result = subprocess.run(
            [sys.executable, 'run'],
            cwd=unit_test_dir,
            stderr=subprocess.STDOUT,
            check=False,
        )
        if result.returncode == 0:
            passed.append(plugin_dir.name)
        else:
            failed.append(plugin_dir.name)

    # summary
    print(f'\n{len(passed)} passed, {len(failed)} failed out of {total}')
    if failed:
        print(f'Failed: {", ".join(failed)}')
        return 1
    return 0


if __name__ == '__main__':
    sys.exit(main())
