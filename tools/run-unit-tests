"""Discover and run all plugin unit tests.

Each unit test is executed from its own directory (check-plugins/<name>/unit-test/)
because the test files use relative paths for test data and plugin references.

Unit tests come in two shapes:

- **fast tests**: pure-Python tests that use `--test` fixtures and run in
  well under a second. These are safe to run in the multi-Python-version
  tox matrix.
- **container tests**: tests that build a podman container per target OS,
  inject the plugin plus `lib/`, and exercise the check against a live
  service. They take minutes per plugin and need podman. They are not
  safe for the tox matrix, and get their own runner
  (`tools/run-container-tests`). A unit test counts as a container test
  if the plugin's `unit-test/` directory has a `containerfiles/`
  subdirectory.

Usage:
    python tools/run-unit-tests                 # run everything
    python tools/run-unit-tests --no-container  # skip container tests
    python tools/run-unit-tests --only-container  # run only container tests
    python tools/run-unit-tests disk-smart      # run one plugin
    python tools/run-unit-tests disk-smart xml  # run specific plugins
    python tools/run-unit-tests --no-container procs  # flags + plugins mix

When specific plugins are requested on the command line, filters like
`--no-container` still apply.
"""

import argparse
import os
import subprocess
import sys

# Plugins whose unit tests exist only as a template and are not meant to
# be executed by the runner. The `example` plugin is the reference skeleton
# for new plugins, its unit test is a copy-paste starting point.
SKIP_PLUGINS = {'example'}


# Signatures that identify a real container-driven unit test. These must
# be precise substring matches: a plain keyword like `podman` would also
# fire on comments, docstrings, or on plugins whose name happens to
# contain `podman` (e.g. `podman-info`, `podman-stats`), which used to
# cause fixture-based tests to be silently skipped by the multi-Python
# matrix.
CONTAINER_TEST_SIGNATURES = (
    'import testcontainers',
    'from testcontainers',
    'lib.lftest.run_container(',
    'lib.lftest.run_mariadb(',
    'DockerContainer(',
    'DockerImage(',
)


def is_container_test(check_plugins, plugin):
    """Return True if the plugin's unit test actually drives a container runtime.

    We look at the `run` file's content rather than the presence of a
    `containerfiles/` subdirectory: a plugin may keep containerfiles around
    for a future testcontainers migration while its `run` file is already
    fixture-based and fast.
    """
    run_file = os.path.join(check_plugins, plugin, 'unit-test', 'run')
    try:
        with open(run_file, encoding='utf-8') as f:
            content = f.read()
    except OSError:
        return False
    return any(sig in content for sig in CONTAINER_TEST_SIGNATURES)


def ensure_podman_env():
    """Pre-flight environment setup for testcontainers under rootless podman.

    Linuxfabrik runs podman, not docker, so the user-facing env var
    is `CONTAINER_HOST` (matching the Linux container ecosystem
    convention used by `podman --remote`, buildah, skopeo etc.).
    testcontainers-python only knows about `DOCKER_HOST` internally,
    so this helper accepts either variable as input and always
    populates `DOCKER_HOST` for testcontainers to consume.

    The defaults if neither variable is set:
    - `unix:///run/user/$UID/podman/podman.sock` (rootless podman)
    - `TESTCONTAINERS_RYUK_DISABLED=true` (the Ryuk reaper hangs on
      rootless podman because its DinD container cannot reach back
      to the parent socket)

    Already-set values are preserved so callers running on a real
    docker host or with a custom socket override are not affected.
    """
    container_host = os.environ.get('CONTAINER_HOST') or os.environ.get('DOCKER_HOST')
    if container_host is None:
        container_host = f'unix:///run/user/{os.getuid()}/podman/podman.sock'
    # testcontainers-python only reads DOCKER_HOST, so always populate it.
    os.environ['DOCKER_HOST'] = container_host

    if 'TESTCONTAINERS_RYUK_DISABLED' not in os.environ:
        os.environ['TESTCONTAINERS_RYUK_DISABLED'] = 'true'


def main():
    """Find and run unit tests, report results."""
    parser = argparse.ArgumentParser(description=__doc__.strip().split('\n\n')[0])
    group = parser.add_mutually_exclusive_group()
    group.add_argument(
        '--no-container',
        action='store_true',
        help='Skip container-based unit tests (anything with a containerfiles/ dir).',
    )
    group.add_argument(
        '--only-container',
        action='store_true',
        help='Run only container-based unit tests. Useful for tools/run-container-tests.',
    )
    parser.add_argument(
        'plugins',
        nargs='*',
        help='Optional list of plugin names to restrict the run to.',
    )
    args = parser.parse_args()

    root = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    check_plugins = os.path.join(root, 'check-plugins')

    requested = set(args.plugins) if args.plugins else None

    # discover tests
    plugins = []
    for plugin in sorted(os.listdir(check_plugins)):
        if requested is not None and plugin not in requested:
            continue
        # when a plugin is explicitly requested on the command line, run it
        # even if it is normally skipped; otherwise honor the skip set
        if plugin in SKIP_PLUGINS and requested is None:
            continue
        run_file = os.path.join(check_plugins, plugin, 'unit-test', 'run')
        if not os.path.isfile(run_file):
            continue
        container = is_container_test(check_plugins, plugin)
        if args.no_container and container:
            continue
        if args.only_container and not container:
            continue
        plugins.append(plugin)

    if not plugins:
        print('No unit tests found.')
        sys.exit(0)

    # If any of the discovered tests will spin up a container, set the
    # rootless-podman env vars so the user does not have to remember
    # them. Already-set values are preserved.
    if any(is_container_test(check_plugins, p) for p in plugins):
        ensure_podman_env()

    passed = []
    failed = []
    total = len(plugins)

    for i, plugin in enumerate(plugins, 1):
        unit_test_dir = os.path.join(check_plugins, plugin, 'unit-test')
        print(f'[{i}/{total}] {plugin}', flush=True)

        result = subprocess.run(
            [sys.executable, 'run'],
            cwd=unit_test_dir,
            stderr=subprocess.STDOUT,
        )
        if result.returncode == 0:
            passed.append(plugin)
        else:
            failed.append(plugin)

    # summary
    print(f'\n{len(passed)} passed, {len(failed)} failed out of {total}')
    if failed:
        print(f'Failed: {", ".join(failed)}')
        sys.exit(1)


if __name__ == '__main__':
    main()
