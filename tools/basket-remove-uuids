"""Strip the `uuid` fields from an Icinga Director basket JSON.

Linuxfabrik runs a forked Icinga Director that keeps uuids in its
exported baskets. The upstream Director rejects imports that
contain them, so users who install against upstream need a version
of the basket without uuids. This tool reads a basket, walks every
top-level object (and the embedded `services` inside service
sets), drops every `uuid` key it finds and writes the result back
to a new file.

Run as the second step of the "build a basket for upstream
Director" pipeline, after `tools/basket-join` has produced the
combined basket:

    tools/basket-join
    tools/basket-remove-uuids \\
        --input-file icingaweb2-module-director-basket.json \\
        --output-file icingaweb2-module-director-basket-no-uuids.json
"""

import argparse
import sys
from pathlib import Path

import _basket

__author__ = 'Linuxfabrik GmbH, Zurich/Switzerland'
__version__ = '2026041301'

DESCRIPTION = """Strip the `uuid` fields from an Icinga Director basket JSON so it can be
imported into a Director that uses the upstream schema. Linuxfabrik uses a forked Director
that keeps uuids; the upstream version does not, and rejects imports that contain them."""


def parse_args():
    """Parse command line arguments using argparse."""
    parser = argparse.ArgumentParser(description=DESCRIPTION)

    parser.add_argument(
        '-V',
        '--version',
        action='version',
        version=f'%(prog)s: v{__version__} by {__author__}',
    )

    parser.add_argument(
        '--input-file',
        help='Path to the input Icinga Director basket JSON file.',
        dest='INPUT_FILE',
        type=Path,
        required=True,
    )

    parser.add_argument(
        '--output-file',
        help='Path to the output JSON file. Overwritten if it exists.',
        dest='OUTPUT_FILE',
        type=Path,
        required=True,
    )

    return parser.parse_args()


def remove_uuids(basket):
    """Drop every `uuid` key from the basket in place.

    Walks the two-level structure Director uses - a top-level
    object type (`Datafield`, `HostTemplate`, ...) mapping to a
    dict of entries - and additionally descends one level into
    `services` entries carried by Service Sets.
    """
    for parent_value in basket.values():
        for value in parent_value.values():
            value.pop('uuid', None)
            # descent into services of Service Sets
            services = value.get('services')
            if services:
                for service_value in services.values():
                    service_value.pop('uuid', None)


def main():
    """Load the basket, strip uuids, save to the output file."""
    args = parse_args()
    basket = _basket.load_basket(args.INPUT_FILE)
    remove_uuids(basket)
    _basket.save_basket(args.OUTPUT_FILE, basket)


if __name__ == '__main__':
    sys.exit(main())
