"""Generates the docs/ directory structure with symlinks and the mkdocs.yml navigation
for the Linuxfabrik Monitoring Plugins documentation site.

Run this tool from the repository root directory.
"""

import os
import sys

__author__ = 'Linuxfabrik GmbH, Zurich/Switzerland'
__version__ = '2026042302'

REPO_ROOT = os.path.abspath(os.path.join(os.path.dirname(__file__), '..'))
DOCS_DIR = os.path.join(REPO_ROOT, 'docs')

# Check plugins whose README is also reachable under
# `docs/check-plugins/<name>/README.md` so that markdown links like
# `[text](check-plugins/<name>/README.md)` from CONTRIBUTING.md
# resolve both on GitHub (where the link points at the real README
# file in the plugin subdirectory) and on the rendered mkdocs site
# (where the symlink created here shadows the subdirectory). The
# default `tools/build-docs` layout only publishes one doc page per
# plugin at `docs/check-plugins/<name>.md`; this list adds the
# second form where it is needed.
#
# `example` is also excluded from the main nav because it is a
# template rather than a real plugin; every other entry in this
# list still shows up in the nav normally via its primary docs
# page and only gets an *additional* README.md symlink.
README_LINKED_FROM_CONTRIBUTING = [
    'example',
    'php-fpm-status',
]

# Top-level markdown files to include in the documentation.
# Format: (source filename, target filename in docs/, nav title)
# The site's landing page (docs/index.md) is a symlink to the root
# README.md so the docs site and GitHub always show the same front
# page. Every other top-level .md file is symlinked under the
# lowercased `target filename` used by the nav, plus an extra
# uppercase alias (identical to the source filename) so that
# relative links in README.md like `[INSTALL.md](INSTALL.md)`
# resolve correctly from the rendered index.md.
TOP_LEVEL_DOCS = [
    ('BUILD.md', 'build.md', 'Compiling and Packaging'),
    ('CHANGELOG.md', 'CHANGELOG.md', None),
    ('CODE_OF_CONDUCT.md', 'CODE_OF_CONDUCT.md', None),
    ('CONTRIBUTING.md', 'contributing.md', 'Contributing'),
    ('GRAFANA.md', 'grafana.md', 'Grafana'),
    ('ICINGA.md', 'icinga.md', 'Icinga Setup'),
    ('INSTALL.md', 'install.md', 'Installation'),
    ('PLUGINS-KEYCLOAK.md', 'plugins-keycloak.md', 'Plugin Group: Keycloak'),
    ('PLUGINS-MYSQL.md', 'plugins-mysql.md', 'Plugin Group: MySQL'),
    ('PLUGINS-ROCKETCHAT.md', 'plugins-rocketchat.md', 'Plugin Group: Rocket.Chat'),
    ('PLUGINS-WILDFLY.md', 'plugins-wildfly.md', 'Plugin Group: WildFly'),
    ('POSTER.md', 'poster.md', 'Check Plugin Poster'),
    ('README.md', 'index.md', None),
    ('SECURITY.md', 'security.md', 'Security'),
    ('SPONSORS.md', 'SPONSORS.md', None),
    ('TESTIMONIALS.md', 'testimonials.md', 'Testimonials'),
    ('THRESHOLDS.md', 'thresholds.md', 'Thresholds and Ranges'),
    ('TOOLS.md', 'tools.md', 'Maintainer Tools'),
    ('UNITS.md', 'units.md', 'Human-Readable Units'),
]

# Plugin directories to scan
PLUGIN_DIRS = [
    ('check-plugins', 'Check Plugins'),
    ('notification-plugins', 'Notification Plugins'),
    ('event-plugins', 'Event Plugins'),
]


def create_symlink(source, target):
    """Create a relative symlink from target to source."""
    target_dir = os.path.dirname(target)
    rel_source = os.path.relpath(source, target_dir)
    if os.path.islink(target) or os.path.exists(target):
        os.unlink(target)
    os.symlink(rel_source, target)


def scan_plugins(plugin_dir):
    """Scan a plugin directory and return sorted list of plugin names that have a README.md."""
    full_path = os.path.join(REPO_ROOT, plugin_dir)
    if not os.path.isdir(full_path):
        return []
    plugins = []
    for entry in sorted(os.listdir(full_path)):
        if entry == 'example':
            continue
        readme = os.path.join(full_path, entry, 'README.md')
        if os.path.isfile(readme):
            plugins.append(entry)
    return plugins


def generate_mkdocs_yml(nav_sections):
    """Generate the mkdocs.yml content."""
    lines = []
    lines.append(
        '# This file is auto-generated by tools/build-docs. Do not edit manually.'
    )
    lines.append('')
    lines.append("site_name: 'Linuxfabrik Monitoring Plugins'")
    lines.append("site_url: 'https://linuxfabrik.github.io/monitoring-plugins/'")
    lines.append("repo_url: 'https://github.com/Linuxfabrik/monitoring-plugins'")
    lines.append("repo_name: 'Linuxfabrik/monitoring-plugins'")
    lines.append('')
    lines.append('theme:')
    lines.append("  name: 'material'")
    lines.append('  icon:')
    lines.append("    logo: 'material/monitor-dashboard'")
    lines.append('  palette:')
    lines.append("    - scheme: 'default'")
    lines.append("      primary: 'blue grey'")
    lines.append("      accent: 'orange'")
    lines.append('      toggle:')
    lines.append("        icon: 'material/brightness-7'")
    lines.append("        name: 'Switch to dark mode'")
    lines.append("    - scheme: 'slate'")
    lines.append("      primary: 'blue grey'")
    lines.append("      accent: 'orange'")
    lines.append('      toggle:')
    lines.append("        icon: 'material/brightness-4'")
    lines.append("        name: 'Switch to light mode'")
    lines.append('  features:')
    lines.append('    - content.code.copy')
    lines.append('    - navigation.expand')
    lines.append('    - navigation.instant')
    lines.append('    - navigation.sections')
    lines.append('    - navigation.top')
    lines.append('    - search.highlight')
    lines.append('    - search.suggest')
    lines.append('    - toc.follow')
    lines.append('')
    lines.append('markdown_extensions:')
    lines.append('  - admonition')
    lines.append('  - attr_list')
    lines.append('  - def_list')
    lines.append('  - md_in_html')
    lines.append('  - tables')
    lines.append('  - toc:')
    lines.append('      permalink: true')
    lines.append('')
    lines.append('plugins:')
    lines.append('  - search')
    lines.append('')
    # Collect uppercase alias filenames that must be hidden from the
    # nav but still exist as reachable pages so relative links from
    # the root README (rendered as index.md) do not 404.
    alias_hidden = []
    for source_name, target_name, _ in TOP_LEVEL_DOCS:
        if source_name != target_name and source_name != 'README.md':
            alias_hidden.append(source_name)

    lines.append('not_in_nav: |')
    lines.append('  CHANGELOG.md')
    for name in sorted(README_LINKED_FROM_CONTRIBUTING):
        lines.append(f'  check-plugins/{name}/README.md')
    lines.append('  CODE_OF_CONDUCT.md')
    lines.append('  SPONSORS.md')
    for name in sorted(alias_hidden):
        lines.append(f'  {name}')
    lines.append('')

    # Build nav
    lines.append('nav:')
    lines.append("  - 'Home': 'index.md'")

    # Installation groups the general install doc and the four
    # plugin-group install docs (Keycloak, MySQL, Rocket.Chat,
    # WildFly) since those are essentially per-stack install
    # instructions.
    lines.append("  - 'Installation':")
    lines.append("      - 'Overview': 'install.md'")
    lines.append("      - 'Keycloak Plugins': 'plugins-keycloak.md'")
    lines.append("      - 'MySQL Plugins': 'plugins-mysql.md'")
    lines.append("      - 'Rocket.Chat Plugins': 'plugins-rocketchat.md'")
    lines.append("      - 'WildFly Plugins': 'plugins-wildfly.md'")

    lines.append("  - 'Icinga Setup': 'icinga.md'")
    lines.append("  - 'Grafana': 'grafana.md'")

    # Remaining top-level admin docs from the project root, ordered
    # general → specific: reference → showcase → meta.
    lines.append("  - 'Human-Readable Units': 'units.md'")
    lines.append("  - 'Thresholds and Ranges': 'thresholds.md'")
    lines.append("  - 'Check Plugin Poster': 'poster.md'")
    lines.append("  - 'Testimonials': 'testimonials.md'")
    lines.append("  - 'Security': 'security.md'")

    for section_dir, section_title, plugins in nav_sections:
        lines.append(f"  - '{section_title}':")
        for plugin in plugins:
            lines.append(f"      - '{plugin}': '{section_dir}/{plugin}.md'")

    # Developer-facing documentation, grouped at the bottom so admins
    # are not distracted by contribution/build/tooling details they
    # will not need for day-to-day monitoring.
    lines.append("  - 'For Developers':")
    lines.append("      - 'Contributing': 'contributing.md'")
    lines.append("      - 'Compiling and Packaging': 'build.md'")
    lines.append("      - 'Maintainer Tools': 'tools.md'")

    lines.append('')

    return '\n'.join(lines)


def main():
    os.makedirs(DOCS_DIR, exist_ok=True)

    # Create symlinks for top-level docs. For files whose target
    # filename differs from their source name (e.g. INSTALL.md →
    # install.md), also create an uppercase alias symlink so that
    # relative links from the root README like `[INSTALL.md]
    # (INSTALL.md)` keep resolving once README.md is rendered as
    # docs/index.md.
    for source_name, target_name, _ in TOP_LEVEL_DOCS:
        source = os.path.join(REPO_ROOT, source_name)
        target = os.path.join(DOCS_DIR, target_name)
        if not os.path.isfile(source):
            print(f'WARNING: {source_name} not found, skipping.')
            continue
        create_symlink(source, target)
        if source_name != target_name and source_name != 'README.md':
            alias_target = os.path.join(DOCS_DIR, source_name)
            create_symlink(source, alias_target)

    # Create symlinks for plugin READMEs
    nav_sections = []
    for plugin_dir, section_title in PLUGIN_DIRS:
        plugins = scan_plugins(plugin_dir)
        if not plugins:
            continue

        target_dir = os.path.join(DOCS_DIR, plugin_dir)
        os.makedirs(target_dir, exist_ok=True)

        # Remove stale symlinks
        expected_files = {f'{plugin}.md' for plugin in plugins}
        for entry in os.listdir(target_dir):
            entry_path = os.path.join(target_dir, entry)
            if os.path.islink(entry_path) and entry not in expected_files:
                os.unlink(entry_path)

        for plugin in plugins:
            source = os.path.join(REPO_ROOT, plugin_dir, plugin, 'README.md')
            target = os.path.join(target_dir, f'{plugin}.md')
            create_symlink(source, target)

        nav_sections.append((plugin_dir, section_title, plugins))

    # Generate mkdocs.yml
    mkdocs_content = generate_mkdocs_yml(nav_sections)
    mkdocs_path = os.path.join(REPO_ROOT, 'mkdocs.yml')
    with open(mkdocs_path, 'w') as f:
        f.write(mkdocs_content)

    # Create extra README.md symlinks under docs/check-plugins/<name>/
    # for every plugin linked from CONTRIBUTING.md. See the comment on
    # README_LINKED_FROM_CONTRIBUTING at the top of this file.
    for name in README_LINKED_FROM_CONTRIBUTING:
        src = os.path.join(REPO_ROOT, 'check-plugins', name, 'README.md')
        if not os.path.isfile(src):
            continue
        tgt_dir = os.path.join(DOCS_DIR, 'check-plugins', name)
        os.makedirs(tgt_dir, exist_ok=True)
        create_symlink(src, os.path.join(tgt_dir, 'README.md'))

    # Count
    total_symlinks = len(TOP_LEVEL_DOCS)
    for _, _, plugins in nav_sections:
        total_symlinks += len(plugins)
    print(f'Created {total_symlinks} symlinks in docs/')
    print(
        f'Generated mkdocs.yml with {sum(len(p) for _, _, p in nav_sections)} plugin entries'
    )

    return 0


if __name__ == '__main__':
    sys.exit(main())
