"""Integration tests for the mysql-innodb-buffer-pool-size check plugin.

The plugin opens a real `pymysql` connection and reads
`innodb_buffer_pool_size` / `innodb_log_file_size` from
`SHOW VARIABLES`, plus InnoDB data length from
`information_schema.engine_status`. A static fixture cannot drive
it - we spin up an actual MariaDB server, boot it with a pinned
`innodb_buffer_pool_size=32M` so the assertion can target a
deterministic size, and let the plugin talk to it over TCP.

Per CONTRIBUTING's "Combine container tests with fixtures" rule,
this file holds only the happy-path integration test. A freshly
booted MariaDB with 32 MiB buffer pool and no user data is far
below the `buffer_pool_size <= data size` warning threshold, so the
plugin returns STATE_OK.

The test matrix is defined by the Containerfiles under
`containerfiles/`. Each file is a Containerfile (typically a
one-line `FROM`) and gets built once via testcontainers'
DockerImage (cached across runs). Add a new MariaDB LTS by
dropping in a new Containerfile; retire one by deleting the file.

Requirements:
- podman (or docker) with a reachable socket
- `pip install testcontainers`
- `tools/run-unit-tests` auto-sets `CONTAINER_HOST` and
  `TESTCONTAINERS_RYUK_DISABLED`
"""

import os
import subprocess
import sys
import unittest

sys.path.insert(0, '..')

import lib.lftest
from lib.globals import STATE_OK

HERE = os.path.dirname(os.path.abspath(__file__))
CONTAINERFILES_DIR = os.path.join(HERE, 'containerfiles')
CONTAINERFILES = sorted(
    name for name in os.listdir(CONTAINERFILES_DIR)
    if os.path.isfile(os.path.join(CONTAINERFILES_DIR, name))
)


class TestCheck(unittest.TestCase):
    pass


def _check_image(test, containerfile):
    path = os.path.join(CONTAINERFILES_DIR, containerfile)
    print(f'\n=== Testing {containerfile} ===', flush=True)
    with lib.lftest.run_mariadb_from_containerfile(
        path,
        # Pin both the buffer pool and the log file so the plugin's
        # "ratio in [20%, 30%]" sanity check lands on exactly 25%
        # regardless of the image defaults. sclorg defaults to 8 MiB
        # log files and the upstream image to 96 MiB, which would
        # otherwise send the ratio to 300%.
        extra_args='--innodb-buffer-pool-size=33554432 --innodb-log-file-size=8388608',
    ) as (_container, defaults_file):
        cmd = [
            'python3', '../mysql-innodb-buffer-pool-size',
            f'--defaults-file={defaults_file}',
        ]
        print(f'Run plugin: {" ".join(cmd)}', flush=True)
        result = subprocess.run(
            cmd,
            cwd=os.path.dirname(os.path.abspath(__file__)),
            capture_output=True,
            text=True,
        )
        combined = result.stdout + result.stderr
        print(f'Script output:\n{combined.strip()}', flush=True)

        test.assertEqual(result.returncode, STATE_OK)
        test.assertRegex(combined, r'`innodb_buffer_pool_size`\s*\(32\.0+\s*MiB\)')


lib.lftest.attach_each(TestCheck, CONTAINERFILES, _check_image)


if __name__ == '__main__':
    unittest.main()
