import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'ok-status-ok',
        'test': 'stdout/status-ok,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'The GitLab application server is running. No Rails Controllers '
            'are deadlocked.',
        ],
    },
    {
        'id': 'warn-bad-gateway',
        'test': 'stdout/bad-gateway,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['Bad Gateway'],
    },
    {
        'id': 'warn-nginx-502-workhorse',
        'test': 'stdout/nginx-502-workhorse,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['nginx returned 502 when communicating with gitlab-workhorse'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../gitlab-liveness'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
