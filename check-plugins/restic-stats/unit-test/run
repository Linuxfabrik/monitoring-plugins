import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-242-files',
        'test': 'stdout/242-files,,',
        'params': '--repo=test --password-file=test',
        'assert-retc': STATE_OK,
        'assert-in': [
            '242.0 files, 433.4KiB size '
            '(total stats in restore-size mode over all snapshots)',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../restic-stats'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
