import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_OK

TESTS = [
    {
        'id': 'ok-events-latest-770',
        'test': 'stdout/events-latest-770,,0',
        'params': '--token=253ff1ec-a5b8-4248-be1d-b898d298d8fc',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Latest event: #770 uid=2 username settings-change 1.2.3.4 (',
            'eid ! uid ! displayname ! type            ! timestamp',
            '770 ! 2   ! displayname ! settings-change ! 2021-09-03 14:59:48',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../nodebb-events'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
