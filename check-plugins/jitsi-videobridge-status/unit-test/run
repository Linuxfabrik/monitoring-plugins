import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-healthy',
        'test': 'stdout/healthy,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.'],
    },
    {
        'id': 'crit-unhealthy-severity-crit',
        'test': 'stdout/unhealthy,,0',
        'params': '--severity=crit',
        'assert-retc': STATE_CRIT,
        'assert-in': ['Problems with jitsi-videobridge.'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../jitsi-videobridge-status'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
