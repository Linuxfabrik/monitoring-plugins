import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT

TESTS = [
    {
        'id': 'crit-system-faulty-powering-off',
        'test': 'stdout/system-faulty-powering-off,,0',
        'params': '--device-id=1 --password=pass --url=https://localhost --username=admin',
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'OceanStor Dorado 8000 V6 6.1.0.SPH12, UUID: 201:4711, Name: myname, '
            'Location: Zurich, Health Status: Faulty (2) [CRITICAL], '
            'Running Status: Powering off (47) [WARNING]',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../huawei-dorado-system'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
