import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT
import lib.lftest


TESTS = [
    {
        'id': 'crit-travel-disruption',
        'test': 'stdout/travel-disruption,,0',
        'params': '--datacenter=eu',
        'assert-retc': STATE_CRIT,
        'assert-in': ['Travel: disruption [CRITICAL] (@eu, UTC+0200)'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../sap-open-concur-com'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
