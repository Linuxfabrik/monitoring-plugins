import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_OK

TESTS = [
    {
        'id': 'ok-heap-5-percent-used',
        'test': 'stdout/heap-5-percent-used,,',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Heap used: 4.8% (254.0MiB of 5.2GiB), '
            'Non-Heap used: 290.5MiB (unlimited memory usage allowed)',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../starface-java-memory-usage'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
