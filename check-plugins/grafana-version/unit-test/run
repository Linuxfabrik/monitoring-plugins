"""Unit tests for the grafana-version check plugin.

The fixtures in `stdout/` are the raw `grafana-server -v` outputs
captured from the official `docker.io/grafana/grafana-oss:<tag>`
images on Docker Hub. There is no Red Hat family Grafana
container, so the upstream image is the right source. The plugin
runs its `r'Version (.*?) '` regex against each one (the
deprecation banner that newer Grafana releases print does not
contain "Version", so the regex picks the second line).

Each testcase pins the expected Nagios state to whatever
`lib.version.check_eol()` returned when these fixtures were saved
against the live https://endoflife.date/api/grafana.json data.
The EOL table drifts over time (releases hit EOL, new majors
appear), so the `assert-retc` and `assert-in` strings will need
to be re-pinned every few months.
"""

import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_UNKNOWN, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'warn-grafana-10-4-eol',
        'test': 'stdout/grafana-server-v10.4,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['Grafana v10.4.0', 'EOL 2025-06-05', '[WARNING]'],
    },
    {
        'id': 'warn-grafana-11-5-eol',
        'test': 'stdout/grafana-server-v11.5,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['Grafana v11.5.0', 'EOL 2025-10-28', '[WARNING]'],
    },
    {
        'id': 'warn-grafana-12-0-eol',
        'test': 'stdout/grafana-server-v12.0,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['Grafana v12.0.0', 'EOL 2026-02-05', '[WARNING]'],
    },
    {
        'id': 'ok-grafana-12-4',
        'test': 'stdout/grafana-server-v12.4,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Grafana v12.4.0', 'EOL 2027-05-24'],
    },
    {
        'id': 'unknown-garbage-output',
        'test': 'stdout/garbage-output,,0',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Grafana not found.'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../grafana-version'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
