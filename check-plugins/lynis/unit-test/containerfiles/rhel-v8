# Base image: Official RHEL 8
FROM registry.access.redhat.com/ubi8

# RHEL 8 ships Python 3.6 as the unversioned python3. The plugins target
# Python 3.9, so install python3.9 and make it the default python3 on the
# PATH (/usr/local/bin precedes /usr/bin).
RUN dnf --assumeyes install --nodocs \
        openssh-clients openssh-server python3.9 rsync sudo \
        https://dl.fedoraproject.org/pub/epel/epel-release-latest-8.noarch.rpm && \
    ln -sf /usr/bin/python3.9 /usr/local/bin/python3 && \
    dnf clean all

# lynis ships in EPEL but hard-requires audit and e2fsprogs, which are
# not part of the minimal UBI package set. lynis itself is a noarch shell
# tool that runs without them (the few tests needing those binaries are
# skipped), so install it without the unsatisfiable dependencies.
RUN dnf --assumeyes install --nodocs dnf-plugins-core && \
    dnf download --destdir=/tmp lynis && \
    rpm --upgrade --verbose --hash --nodeps /tmp/lynis*.rpm && \
    rm -f /tmp/lynis*.rpm && \
    dnf clean all

# Set up password-less root SSH-to-self so the plugin can audit 127.0.0.1
# over its normal SSH transport. sudo as root needs no password, so the
# privileged audit works without extra sudoers rules.
RUN ssh-keygen -A && \
    mkdir -p /run/sshd /root/.ssh && \
    ssh-keygen -t ed25519 -N '' -f /root/.ssh/id_ed25519 -q && \
    cp /root/.ssh/id_ed25519.pub /root/.ssh/authorized_keys && \
    chmod 700 /root/.ssh && \
    chmod 600 /root/.ssh/authorized_keys && \
    printf 'PermitRootLogin prohibit-password\nPubkeyAuthentication yes\n' \
        >> /etc/ssh/sshd_config

# Set the working directory in the container
WORKDIR /tmp

# Verify Python installation
RUN python3 --version

# Default command to keep the container running
CMD ["sleep", "infinity"]
