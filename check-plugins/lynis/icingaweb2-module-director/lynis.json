    "ServiceTemplate": {
        "tpl-service-lynis": {
            "action_url": null,
            "apply_for": null,
            "assign_filter": null,
            "check_command": "cmd-check-lynis",
            "check_interval": "86400",
            "check_period": null,
            "check_timeout": null,
            "command_endpoint": null,
            "disabled": false,
            "display_name": null,
            "enable_active_checks": null,
            "enable_event_handler": null,
            "enable_flapping": null,
            "enable_notifications": true,
            "enable_passive_checks": null,
            "enable_perfdata": true,
            "event_command": null,
            "fields": [],
            "flapping_threshold_high": null,
            "flapping_threshold_low": null,
            "groups": [],
            "host": null,
            "icon_image": "lynis.svg",
            "icon_image_alt": null,
            "imports": [
                "tpl-service-generic"
            ],
            "max_check_attempts": 5,
            "notes": "Runs a full security audit across the hosts of a subnet and reports each host's hardening posture. From a single management host it discovers the targets (the subnet of the default interface, a chosen interface, or an explicit host list), connects to each one over SSH, copies a self-contained copy of the audit tool over, runs a privileged system audit (root via password-less sudo by default), retrieves the machine-readable report, and removes its temporary files. A host that does not answer within the connect timeout is skipped. The check is meant to run at most once per day; the worst per-host result determines the overall state. Security posture is informational drift rather than a time-critical availability event, so by default only WARNING is raised.",
            "notes_url": "https://linuxfabrik.github.io/monitoring-plugins/check-plugins/lynis/",
            "object_name": "tpl-service-lynis",
            "object_type": "template",
            "retry_interval": 15,
            "service_set": null,
            "template_choice": null,
            "use_agent": null,
            "use_var_overrides": null,
            "vars": {
                "criticality": "C",
                "lynis_always_ok": false,
                "lynis_audit_timeout": 600,
                "lynis_connect_timeout": 3,
                "lynis_critical": "",
                "lynis_disable_pseudo_terminal": false,
                "lynis_host": [],
                "lynis_identity": [],
                "lynis_ipv4": false,
                "lynis_ipv6": false,
                "lynis_lengthy": true,
                "lynis_lynis_option": [],
                "lynis_lynis_skip_test": [],
                "lynis_lynis_test": [],
                "lynis_lynis_test_category": [],
                "lynis_lynis_test_group": [],
                "lynis_max_workers": 10,
                "lynis_network": [],
                "lynis_port": 22,
                "lynis_quiet": false,
                "lynis_ssh_option": [],
                "lynis_verbose": false,
                "lynis_warning": "65:"
            },
            "volatile": null,
            "zone": null,
            "uuid": "5dff85a4-d547-4bdf-ab99-0f102d0168e7"
        }
    },
    "Datafield": {
        "1": {
            "varname": "lynis_always_ok",
            "caption": "Lynis: Always OK?",
            "description": "Always returns OK.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "2d98159e-1108-4619-9500-a9d0951d8ef4"
        },
        "2": {
            "varname": "lynis_audit_timeout",
            "caption": "Lynis: Audit Timeout",
            "description": "Seconds to wait for the remote audit of a single host to finish.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "362f7330-cec5-4151-b479-983d1fd11242"
        },
        "3": {
            "varname": "lynis_configfile",
            "caption": "Lynis: Configfile",
            "description": "SSH: Alternative per-user configuration file. If a configuration file is given on the command line, the system-wide configuration file (`/etc/ssh/ssh_config`) will be ignored. The default for the per-user configuration file is `~/.ssh/config`. If set to `none`, no configuration files will be read.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "07cc236c-536a-4951-9ff8-3b563c7ab0fd"
        },
        "4": {
            "varname": "lynis_connect_timeout",
            "caption": "Lynis: Connect Timeout",
            "description": "Seconds to wait for the SSH connection to a target host before skipping it.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "3bd787f6-c02f-4f01-b1dc-4c19f03c54b5"
        },
        "5": {
            "varname": "lynis_critical",
            "caption": "Lynis: Critical",
            "description": "CRIT threshold for the per-host hardening index (0-100). Supports Nagios ranges. Empty by default, because a daily hardening scan is posture drift, not a time-critical event that should page someone at night.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "ad6c9478-ca86-4cee-8dbc-ffbe54059538"
        },
        "6": {
            "varname": "lynis_disable_pseudo_terminal",
            "caption": "Lynis: Disable Pseudo Terminal?",
            "description": "SSH: Disable pseudo-terminal allocation.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "63370fc1-953b-4993-a454-8a73695b5758"
        },
        "7": {
            "varname": "lynis_host",
            "caption": "Lynis: Host",
            "description": "Target host to audit. Overrides subnet auto-discovery. Can be specified multiple times. If not specified, the subnet of the default interface is scanned.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "146b7d9e-1eb3-4779-85e0-9bf8d56ddc64"
        },
        "8": {
            "varname": "lynis_identity",
            "caption": "Lynis: Identity",
            "description": "SSH: File from which the identity (private key) for public key authentication is read. You can also specify a public key file to use the corresponding private key that is loaded in ssh-agent(1) when the private key file is not present locally. The default is `~/.ssh/id_dsa`, `~/.ssh/id_ecdsa`, `~/.ssh/id_ecdsa_sk`, `~/.ssh/id_ed25519`, `~/.ssh/id_ed25519_sk` and `~/.ssh/id_rsa`. Identity files may also be specified on a per-host basis in the configuration file. It is possible to have multiple --identity options (and multiple identities specified in configuration files). If no certificates have been explicitly specified by the CertificateFile directive, ssh will also try to load certificate information from the filename obtained by appending `-cert.pub` to identity filenames.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "e22c1b2c-4330-40d6-a678-a1e69d6b83b2"
        },
        "9": {
            "varname": "lynis_interface",
            "caption": "Lynis: Interface",
            "description": "Network interface whose subnet is scanned. Ignored when --host is given. If not specified, the default interface (the one carrying the default route) is used.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "91699db4-0def-489d-8335-fbe5f5b10a3b"
        },
        "10": {
            "varname": "lynis_ipv4",
            "caption": "Lynis: IPv4?",
            "description": "SSH: Forces ssh to use IPv4 addresses only.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "c5205f0a-0ac3-4be1-83d9-5484367ddec5"
        },
        "11": {
            "varname": "lynis_ipv6",
            "caption": "Lynis: IPv6?",
            "description": "SSH: Forces ssh to use IPv6 addresses only.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "7d608326-47ee-4c4b-a70a-cb5b57739c44"
        },
        "12": {
            "varname": "lynis_lengthy",
            "caption": "Lynis: Lengthy?",
            "description": "Extended reporting.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "21600611-4b0e-4a02-9a7b-ff7beb057109"
        },
        "13": {
            "varname": "lynis_lynis_auditor",
            "caption": "Lynis: Lynis Auditor",
            "description": "Name of the auditor to record in the report (lynis `--auditor`). If not specified, lynis uses its own default.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "06604f2e-31d5-41d1-88af-f9ec64a742fd"
        },
        "14": {
            "varname": "lynis_lynis_option",
            "caption": "Lynis: Lynis Option",
            "description": "Additional raw option to pass to the remote `lynis audit system` call, for options that have no dedicated parameter here. Can be specified multiple times. Example: `--lynis-option=--no-plugins`",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "14b64c46-2678-4031-b35b-cd2977698025"
        },
        "15": {
            "varname": "lynis_lynis_profile",
            "caption": "Lynis: Lynis Profile",
            "description": "Profile file to use for the audit (lynis `--profile`). The path is resolved on the target host. If not specified, lynis uses the bundled default profile.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "95822760-504d-4739-8836-e02d295c3a3e"
        },
        "16": {
            "varname": "lynis_lynis_skip_test",
            "caption": "Lynis: Lynis Skip Test",
            "description": "Lynis test ID to skip on every target (injected as `skip-test` into the pushed profile), for fleet-wide exceptions controlled from the monitoring configuration. Can be specified multiple times. Host-specific exceptions belong in the target's own `/etc/lynis/custom.prf` instead. Example: `--lynis-skip-test=MAIL-8818`",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "12babf81-1627-4635-a81f-c49bd5a9769c"
        },
        "17": {
            "varname": "lynis_lynis_source",
            "caption": "Lynis: Lynis Source",
            "description": "Path to a self-contained lynis directory (the directory that contains the `lynis` executable next to its `include`, `db` and `plugins` subdirectories). This is the copy that gets pushed to and run on every target host. If not specified, a self-contained copy is assembled from the local lynis installation.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "8e4807b1-5468-4bf5-8c47-9cb830689878"
        },
        "18": {
            "varname": "lynis_lynis_test",
            "caption": "Lynis: Lynis Test",
            "description": "Only run these lynis tests (lynis `--tests`). Can be specified multiple times. If not specified, all tests are run. Example: `--lynis-test=SSH-7408 --lynis-test=KRNL-5820`",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "82462008-d8a3-40e7-9a6e-e68db08fbab9"
        },
        "19": {
            "varname": "lynis_lynis_test_category",
            "caption": "Lynis: Lynis Test Category",
            "description": "Only run lynis tests of these categories (lynis `--tests-from-category`). Can be specified multiple times. If not specified, all categories are run. Example: `--lynis-test-category=security`",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "35d5eb83-f6b1-43b4-b9d0-1a04b078a362"
        },
        "20": {
            "varname": "lynis_lynis_test_group",
            "caption": "Lynis: Lynis Test Group",
            "description": "Only run lynis tests of these groups (lynis `--tests-from-group`). Can be specified multiple times. If not specified, all groups are run. Example: `--lynis-test-group=ssh --lynis-test-group=kernel`",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "51cd49ab-b86a-4bf3-9c34-fac60a38fe01"
        },
        "21": {
            "varname": "lynis_max_workers",
            "caption": "Lynis: Max Workers",
            "description": "Maximum number of hosts to audit in parallel.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "27c5404a-cf4e-4a93-9b8f-d66498581f2e"
        },
        "22": {
            "varname": "lynis_network",
            "caption": "Lynis: Network",
            "description": "Network in CIDR notation to scan for targets via auto-discovery. Can be specified multiple times. Takes precedence over --interface. Example: `--network=192.0.2.0/24`",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "fae8b947-8786-4124-92d8-c92495550bc5"
        },
        "23": {
            "varname": "lynis_password",
            "caption": "Lynis: Password",
            "description": "SSH: Password authentication. NOT RECOMMENDED. Requires `sshpass`. If you need to use password-based SSH login, run this plugin only on trusted hosts. `ps` will expose the SSH password.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "hidden"
            },
            "uuid": "8fbbb1e1-54e8-49dc-994f-7c7f7b816639"
        },
        "24": {
            "varname": "lynis_port",
            "caption": "Lynis: Port",
            "description": "SSH: Port to connect to on the remote host. This can be specified on a per-host basis in the configuration file.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "1ec01918-ad5f-4b85-848b-fd84fc9d98fc"
        },
        "25": {
            "varname": "lynis_quiet",
            "caption": "Lynis: Quiet?",
            "description": "SSH: Quiet mode. Causes most warning and diagnostic messages to be suppressed.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "b3d140d6-940c-4118-8a7b-c5f5c9ef1481"
        },
        "26": {
            "varname": "lynis_ssh_option",
            "caption": "Lynis: SSH Option",
            "description": "SSH: Can be used to give options in the format used in the configuration file. This is useful for specifying options for which there is no separate command-line flag. For full details of the options, and their possible values, see ssh_config(5). Can be specified multiple times.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "76b872f4-e4dd-4905-83f7-9bfbb4ea46ce"
        },
        "27": {
            "varname": "lynis_username",
            "caption": "Lynis: Username",
            "description": "SSH: Username. If not specified, ssh determines the user from `~/.ssh/config` or falls back to the current local user.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "df220ea1-3745-482f-8afd-4929fd491ccb"
        },
        "28": {
            "varname": "lynis_verbose",
            "caption": "Lynis: Verbose?",
            "description": "Makes this plugin verbose during the operation. Useful for debugging and seeing what is going on under the hood.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "ae9b931d-be94-468b-9d4a-fe25b4066a35"
        },
        "29": {
            "varname": "lynis_warning",
            "caption": "Lynis: Warning",
            "description": "WARN threshold for the per-host hardening index (0-100). Supports Nagios ranges. The default alerts when the index drops below 65.",
