import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN
import lib.lftest


BASE_PARAMS = '--hostname hsm.example.com --password linuxfabrik'


TESTS = [
    {
        'id': 'crit-init-failed',
        'test': 'stdout/init-failed,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'hsmstate: Cannot initialize HSM communication library (11) [CRITICAL]',
        ],
    },
    {
        'id': 'warn-init-failed-severity-warn',
        'test': 'stdout/init-failed,,0',
        'params': f'{BASE_PARAMS} --severity warn',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'hsmstate: Cannot initialize HSM communication library (11) [WARNING]',
        ],
    },
    {
        'id': 'ok-usage-3-percent',
        'test': 'stdout/usage-3-percent,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_OK,
        'assert-in': [
            'HSM device 0: HSM in NORMAL MODE. RESPONDING to requests. Usage Level=3.1%',
        ],
    },
    {
        'id': 'warn-usage-85-percent',
        'test': 'stdout/usage-85-percent,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_WARN,
        'assert-in': [
            'HSM device 0: HSM in NORMAL MODE. RESPONDING to requests. Usage Level=85% [WARNING]',
        ],
    },
    {
        'id': 'crit-usage-95-percent',
        'test': 'stdout/usage-95-percent,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'HSM device 0: HSM in NORMAL MODE. RESPONDING to requests. Usage Level=95% [CRITICAL]',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../safenet-hsm-state'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
