import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_OK

TESTS = [
    {
        'id': 'ok-402-users',
        'test': 'stdout/402-users,,0',
        'params': '--token=253ff1ec-a5b8-4248-be1d-b898d298d8fc',
        'assert-retc': STATE_OK,
        'assert-in': [
            "402 users, latest active user: alice63 'alice@example.ch', "
            'online 2022-07-11 19:01:50',
            'uid ! userslug ! lastonline',
            '----+----------+-----------',
            '2   ! example  ! 2022-07-12 08:51:16',
            '220 ! alice63  ! 2022-07-11 19:01:50',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../nodebb-users'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
