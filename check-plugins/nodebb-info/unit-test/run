import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-heap-86-percent-used',
        'test': 'stdout/heap-86-percent-used,,0',
        'params': '--token=253ff1ec-a5b8-4248-be1d-b898d298d8fc',
        'assert-retc': STATE_OK,
        'assert-in': [
            'NodeBB nodebb:4567, /usr/bin/node v14.17.5, '
            'Heap 85.9% used (92.5MiB of 107.6MiB), RSS 263.8MiB, Up 2W 6D',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../nodebb-info'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
