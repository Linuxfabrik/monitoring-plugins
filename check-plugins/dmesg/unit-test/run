import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-benign-messages-v1',
        'test': 'stdout/benign-ignored-messages-v1,,0',
        'assert-retc': STATE_OK,
        'assert-regex': r'Everything is ok\.',
    },
    {
        'id': 'ok-benign-messages-v2',
        'test': 'stdout/benign-ignored-messages-v2,,0',
        'assert-retc': STATE_OK,
        'assert-regex': r'Everything is ok\.',
    },
    {
        'id': 'ok-benign-messages-v3',
        'test': 'stdout/benign-ignored-messages-v3,,0',
        'assert-retc': STATE_OK,
        'assert-regex': r'Everything is ok\.',
    },
    {
        'id': 'crit-tmpfs-bad-mount-option',
        'test': 'stdout/error-tmpfs-mount-option,,0',
        'assert-retc': STATE_CRIT,
        'assert-regex': r'1 error in Kernel Ring Buffer\.',
    },
    {
        'id': 'crit-rcu-stall',
        'test': 'stdout/error-rcu-stall,,0',
        'assert-retc': STATE_CRIT,
        'assert-regex': r'1 error in Kernel Ring Buffer\.',
    },
    {
        'id': 'crit-lorem-ipsum-with-error-keyword',
        'test': 'stdout/lorem-ipsum-with-error-keyword,,0',
        'assert-retc': STATE_CRIT,
        'assert-regex': r'7 errors in Kernel Ring Buffer\.',
    },
    {
        'id': 'crit-two-blk-update-errors',
        'test': 'stdout/errors-blk-update-request-two,,0',
        'assert-retc': STATE_CRIT,
        'assert-regex': r'2 errors in Kernel Ring Buffer\.',
    },
    {
        'id': 'crit-one-ignore-reduces-blk-errors-to-one',
        'test': 'stdout/errors-blk-update-request-two,,0',
        'params': '--ignore 567760',
        'assert-retc': STATE_CRIT,
        'assert-regex': r'1 error in Kernel Ring Buffer\.',
    },
    {
        'id': 'ok-two-ignores-suppress-all-blk-errors',
        'test': 'stdout/errors-blk-update-request-two,,0',
        'params': '--ignore 567760 --ignore 2719104',
        'assert-retc': STATE_OK,
        'assert-regex': r'Everything is ok\.',
    },
    {
        'id': 'ok-extra-ignore-is-no-op',
        'test': 'stdout/errors-blk-update-request-two,,0',
        'params': '--ignore 567760 --ignore 2719104 --ignore anything',
        'assert-retc': STATE_OK,
        'assert-regex': r'Everything is ok\.',
    },
]


class TestCheck(unittest.TestCase):

    check = '../dmesg'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
