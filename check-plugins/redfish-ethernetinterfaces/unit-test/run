import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_UNKNOWN

# The plugin appends `-systems` (Systems collection), `-system` (member),
# `-ethernetinterfaces` (EthernetInterfaces collection), and `-nic-N` (each
# interface, indexed) to the --test path as it walks the Redfish API. Each
# scenario therefore requires the matching fixture files.
TESTS = [
    {
        'id': 'ok-healthy-ethernetinterfaces',
        'test': 'stdout/healthy-ethernetinterfaces,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok, checked Ethernet interfaces on 1 member.',
        ],
        'assert-not-in': ['[WARNING]', '[CRITICAL]'],
    },
    {
        # A single interface reports Health=Critical while the rest are OK.
        # redfish-ethernetinterfaces must escalate to CRITICAL.
        'id': 'crit-one-nic-fault',
        'test': 'stdout/one-nic-fault,,0',
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'There are critical errors.',
            '[CRITICAL]',
        ],
    },
    {
        # A missing fixture must surface as STATE_UNKNOWN with a
        # readable message, not as a Python traceback.
        'id': 'unknown-missing-fixture',
        'test': 'stdout/does-not-exist,,0',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Test fixture not found'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../redfish-ethernetinterfaces'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
