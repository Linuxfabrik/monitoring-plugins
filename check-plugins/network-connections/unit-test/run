import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN

# The network-connections plugin normally calls
# `psutil.net_connections(kind='inet')` and walks the resulting list
# of `sconn` namedtuples, looking only at `family`, `type`, and
# `status`. Its `--test` hook reads a JSON list where each entry
# describes a single connection in an admin-friendly form:
#
#     [
#       {"proto": "tcp|udp|tcp6|udp6", "status": "<psutil status>"},
#       ...
#     ]
#
# The loader maps "proto" to the `(family, type)` pair psutil would
# return and builds `sconn` namedtuples; laddr/raddr/pid/fd are left
# blank because the plugin never reads them.
TESTS = [
    {
        'id': 'ok-mixed-light-load',
        'test': 'stdout/mixed-light-load,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'tcp ESTABLISHED: 2',
            'tcp LISTEN: 1',
            'tcp6 LISTEN: 1',
            'udp NONE: 1',
            'udp6 NONE: 1',
        ],
    },
    {
        'id': 'ok-no-connections',
        'test': 'stdout/no-connections,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['No connections of type'],
    },
    {
        'id': 'warn-time-wait-above-warn',
        'test': 'stdout/many-time-wait,,0',
        'params': '--warning=5 --critical=20',
        'assert-retc': STATE_WARN,
        'assert-in': ['tcp TIME WAIT: 10', '[WARNING]'],
    },
    {
        'id': 'crit-time-wait-above-crit',
        'test': 'stdout/many-time-wait,,0',
        'params': '--warning=5 --critical=8',
        'assert-retc': STATE_CRIT,
        'assert-in': ['tcp TIME WAIT: 10', '[CRITICAL]'],
    },
    {
        'id': 'ok-filter-tcp-only-hides-udp',
        'test': 'stdout/mixed-light-load,,0',
        'params': '--conn-type=tcp',
        'assert-retc': STATE_OK,
        'assert-in': ['tcp ESTABLISHED: 2'],
        'assert-not-in': ['udp NONE', 'udp6 NONE'],
    },
    {
        'id': 'ok-filter-by-status-listen-only',
        'test': 'stdout/mixed-light-load,,0',
        'params': '--conn-status=listen',
        'assert-retc': STATE_OK,
        'assert-in': ['tcp LISTEN: 1', 'tcp6 LISTEN: 1'],
        'assert-not-in': ['ESTABLISHED', 'NONE'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../network-connections'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
