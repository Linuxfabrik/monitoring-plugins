import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_UNKNOWN, STATE_WARN
import lib.lftest


_HEALTHY_FIXTURES = [
    'all-mounts-healthy-v1',
    'all-mounts-healthy-v2',
    'all-mounts-healthy-v3',
    'all-mounts-healthy-v4',
    'all-mounts-healthy-v5',
    'all-mounts-healthy-v6',
    'all-mounts-healthy-v7',
    'all-mounts-healthy-v8',
    'all-mounts-healthy-v9',
]


TESTS = [
    {
        'id': f'ok-{slug}',
        'test': f'stdout/{slug},,0',
        'assert-retc': STATE_OK,
        'assert-regex': r'Everything is ok\.',
    }
    for slug in _HEALTHY_FIXTURES
] + [
    {
        'id': 'ok-all-mounts-healthy-twenty-two-mounts',
        'test': 'stdout/all-mounts-healthy-twenty-two-mounts,,0',
        'assert-retc': STATE_OK,
        'assert-regex': r'Everything is ok\. 22 mount points checked\.',
    },
    {
        'id': 'warn-one-readonly-mount-v1',
        'test': 'stdout/one-readonly-mount-v1,,0',
        'assert-retc': STATE_WARN,
        'assert-regex': r'1 read-only mount point found',
    },
    {
        'id': 'warn-one-readonly-mount-v2',
        'test': 'stdout/one-readonly-mount-v2,,0',
        'assert-retc': STATE_WARN,
        'assert-regex': r'1 read-only mount point found',
    },
    {
        'id': 'warn-three-readonly-mounts',
        'test': 'stdout/three-readonly-mounts,,0',
        'assert-retc': STATE_WARN,
        'assert-regex': r'3 read-only mount points found',
    },
    {
        'id': 'unknown-malformed-proc-mounts',
        'test': 'stdout/malformed-proc-mounts,,0',
        'assert-retc': STATE_UNKNOWN,
        'assert-regex': r'Unexpected format of /proc/mounts\.',
    },
]


class TestCheck(unittest.TestCase):

    check = '../fs-ro'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
