            "max_check_attempts": 5,
            "notes": "Checks the lifecycle and health of Podman containers: the container status (running, exited, paused, ...), the result of the container health check (healthy, unhealthy, starting), and the number of automatic restarts. Containers can be selected or excluded by name using regular expressions, and the presence of expected containers can be enforced. For per-container CPU and memory usage, use the podman-stats check. For Docker, use the docker-container check instead. Requires root or sudo.",
            "notes_url": "https://linuxfabrik.github.io/monitoring-plugins/check-plugins/podman-container/",
            "object_name": "tpl-service-podman-container",
            "object_type": "template",
