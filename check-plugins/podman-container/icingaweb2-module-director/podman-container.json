    "Datafield": {
        "1": {
            "varname": "podman_container_always_ok",
            "caption": "Podman Container: Always OK?",
            "description": "Always returns OK.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "585c4020-af62-481f-a815-cb1f341e9803"
        },
        "2": {
            "varname": "podman_container_critical_restarts",
            "caption": "Podman Container: Critical Restarts",
            "description": "CRIT threshold for the number of automatic restarts a container has performed, compared as a Nagios range. Example: `--critical-restarts=5` alerts when a container has restarted more than 5 times. By default, the restart count is reported but not alerted on.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "cd4dc8e4-5297-4fa6-afe7-e04ece9d2919"
        },
        "3": {
            "varname": "podman_container_critical_uptime",
            "caption": "Podman Container: Critical Uptime",
            "description": "CRIT threshold for the container uptime in a human-readable format (s = seconds, m = minutes, h = hours, D = days, W = weeks, M = months, Y = years). Supports Nagios ranges. Example: `5m:` alerts if a running container has been up for less than 5 minutes (catches a crash-looping or flapping container). By default, the uptime is reported but not alerted on.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "5989dfe2-fe2b-48d7-babc-11256ff732be"
        },
        "4": {
            "varname": "podman_container_full_name",
            "caption": "Podman Container: Full Name?",
            "description": "Use the full container name, for example `traefik_traefik.2.1idw12p2yqp`. Without this flag, the name is shortened after the replica number.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "789786ef-8276-41f0-af28-8c73d90a977c"
        },
        "5": {
            "varname": "podman_container_ignore",
            "caption": "Podman Container: Ignore",
            "description": "Ignore containers whose name matches this Python regular expression. Matched against the full container name, even when the displayed name is shortened (see --full-name). Case-sensitive by default; use `(?i)` for case-insensitive matching. Can be specified multiple times. Example: `--ignore=\"^k8s_\"` to skip Kubernetes pod infrastructure containers. Example: `--ignore=\"(?i)test\"` (case-insensitive) to skip any container with \"test\" in its name.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "aba7dbd2-f624-479e-aa44-2d13de7c447e"
        },
        "6": {
            "varname": "podman_container_match",
            "caption": "Podman Container: Match",
            "description": "Only check containers whose name matches this Python regular expression. Matched against the full container name, even when the displayed name is shortened (see --full-name). Case-sensitive by default; use `(?i)` for case-insensitive matching. Can be specified multiple times. If both `--match` and `--ignore` are given, a container must match `--match` AND not match `--ignore` to be checked (include first, exclude second). Example: `--match=\"^traefik$\"` to pin a service to one specific container. Example: `--match=\"(?i)^web\"` (case-insensitive) to check every web container.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "f0c02ee8-3ca0-4500-b338-07d052b117b3"
        },
        "7": {
            "varname": "podman_container_no_match_severity",
            "caption": "Podman Container: No Match Severity",
            "description": "State to report when no item matches the filters and nothing is checked.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeDatalist",
            "format": null,
            "settings": {
                "behavior": "strict",
                "data_type": "string",
                "datalist": "podman_container_no_match_severity_list"
            },
            "uuid": "b1e47def-fc3d-4f8a-8f04-3cca130bafaf"
        },
        "8": {
            "varname": "podman_container_status",
            "caption": "Podman Container: Status",
            "description": "Desired container status, for example `running`, `exited` or `paused`. A container whose status differs is reported as CRITICAL. If not specified, the status is reported but not alerted on.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "dc81e9be-035d-47e8-b17c-da1eaa2e23d5"
        },
        "9": {
            "varname": "podman_container_user",
            "caption": "Podman Container: User",
            "description": "Inspect the rootless containers of this user instead of those visible to the executing user. Podman keeps each user's rootless containers in that user's own storage, so root (the monitoring user runs the check via sudo) does not see them. With --user, the check runs podman as that user. Requires the right to `sudo -u <user>` (root has this by default). Example: `--user=rocketchat`.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "96756a80-4f8e-4cff-9672-137faa70db7a"
        },
        "10": {
            "varname": "podman_container_warning_restarts",
            "caption": "Podman Container: Warning Restarts",
            "description": "WARN threshold for the number of automatic restarts a container has performed, compared as a Nagios range. Example: `--warning-restarts=3` alerts when a container has restarted more than 3 times. By default, the restart count is reported but not alerted on.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "b03e1cce-19dd-427e-95a1-a6293c964ee6"
        },
        "11": {
            "varname": "podman_container_warning_uptime",
            "caption": "Podman Container: Warning Uptime",
            "description": "WARN threshold for the container uptime in a human-readable format (s = seconds, m = minutes, h = hours, D = days, W = weeks, M = months, Y = years). Supports Nagios ranges. Example: `5m:` alerts if a running container has been up for less than 5 minutes (catches a crash-looping or flapping container). By default, the uptime is reported but not alerted on.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "779f5d7f-30da-41d2-9e9f-7bfee5816bbb"
        }
    }
}
