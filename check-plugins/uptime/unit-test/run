import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN
import lib.lftest


# The uptime plugin normally reads `psutil.boot_time()` plus the
# current epoch via `lib.time.now()`, and persists its last-seen
# timestamps to an SQLite cache so that it can report the length of
# the last downtime. Its `--test` hook replaces BOTH values with a
# JSON fixture of the form:
#
#     {"now": <epoch seconds>, "boot_time": <epoch seconds>}
#
# When `--test` is active, the plugin also bypasses the cache
# entirely (downtime, down_ts = 0) so that repeated test runs stay
# deterministic and the host's real cache database is not touched.
#
# We assert only on the human-readable uptime duration rather than
# the ISO timestamp in the message, because `lib.time.epoch2iso()`
# converts to local time and the unit test must be timezone-agnostic.
TESTS = [
    {
        'id': 'ok-one-hour-default-thresholds',
        'test': 'stdout/one-hour,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Up 1h'],
    },
    {
        'id': 'ok-seven-days-default-thresholds',
        'test': 'stdout/seven-days,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Up 1W'],
    },
    {
        'id': 'warn-just-booted-below-warn-low',
        'test': 'stdout/ten-seconds-just-booted,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['Up 10s', '[WARNING]'],
    },
    {
        'id': 'crit-two-years-above-crit',
        'test': 'stdout/two-years,,0',
        'assert-retc': STATE_CRIT,
        'assert-in': ['Up 2Y', '[CRITICAL]'],
    },
    {
        'id': 'ok-always-ok-masks-critical',
        'test': 'stdout/two-years,,0',
        'params': '--always-ok',
        'assert-retc': STATE_OK,
        'assert-in': ['Up 2Y'],
    },
    {
        'id': 'ok-custom-thresholds-allow-short-uptime',
        'test': 'stdout/ten-seconds-just-booted,,0',
        'params': '--warning=0:1Y --critical=0:2Y',
        'assert-retc': STATE_OK,
        'assert-in': ['Up 10s'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../uptime'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
