import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_OK

TESTS = [
    {
        'id': 'ok-169-peers',
        'test': 'stdout/169-peers,,',
        'assert-retc': STATE_OK,
        'assert-in': [
            '169 SIP Peers: 100 online / 68 offline (monitored), '
            '1 online / 0 offline (unmonitored)',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../starface-peer-stats'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
