# https://github.com/Linuxfabrik/monitoring-plugins/blob/main/CONTRIBUTING.md

"""Cross-distro integration tests for the cpu-usage check plugin.

cpu-usage reads `psutil.cpu_times()` directly, not a shell command, so
there is no stdout fixture we could drive it from. The value of the
test is to confirm the plugin runs on every supported distribution,
because psutil's field availability depends on the kernel and on
which `python3` version the distro ships.

For every Containerfile under `containerfiles/`, the test:

1. builds the image from that Containerfile (the Containerfiles
   already install python3 and a venv with the plugin's requirements,
   and use `CMD ["sleep", "infinity"]` to keep the container alive).
2. starts it with the local `lib/` and `cpu-usage` script mounted as
   volumes under `/tmp`.
3. runs the plugin inside the container via `container.exec()` (in
   the venv if `/tmp/venv` exists, otherwise system Python).
4. asserts the message shape contains an overall percentage and a
   per-category `user:` entry somewhere in the output, and that the
   plugin returned STATE_OK.

Requirements: podman (or docker) with a reachable socket. For
rootless podman, export `DOCKER_HOST=unix:///run/user/$UID/podman/podman.sock`
and `TESTCONTAINERS_RYUK_DISABLED=true`.
"""

import os
import re
import sys
import unittest

sys.path.insert(0, '..')

import lib.lftest
from lib.globals import STATE_OK

try:
    from testcontainers.core.container import DockerContainer
    from testcontainers.core.image import DockerImage
except ImportError:
    print('Python module "testcontainers" is not installed.')
    sys.exit(STATE_OK)


HERE = os.path.dirname(os.path.abspath(__file__))
LIB_DIR = os.path.realpath(os.path.join(HERE, '..', 'lib'))
PLUGIN = os.path.realpath(os.path.join(HERE, '..', 'cpu-usage'))

CONTAINERFILES = [
    'archlinux-vlatest',
    'debian-v11',
    'debian-v12',
    'debian-v13',
    'fedora-v35',
    'fedora-v40',
    'fedora-v41',
    'fedora-v42',
    'fedora-v43',
    'rhel-v8',
    'rhel-v9',
    'rhel-v10',
    'sles-v15',
    'sles-v16',
    'ubuntu-v2004',
    'ubuntu-v2204',
    'ubuntu-v2404',
    'ubuntu-v2604',
]


class TestCheck(unittest.TestCase):
    pass


def _check_containerfile(test, containerfile):
    print(f'\n=== Testing {containerfile} ===', flush=True)
    image_tag = f'lfmp-cpu-usage-{containerfile}'.lower()
    # clean_up=False keeps the built image on the host so the next
    # run reuses all cached layers instead of rebuilding from the
    # base image. Testcontainers' default (clean_up=True) not only
    # untags the image but also prunes dangling parent layers, which
    # wipes the cache and makes every run a full rebuild.
    with DockerImage(
        path=HERE,
        dockerfile_path=f'containerfiles/{containerfile}',
        tag=image_tag,
        clean_up=False,
    ) as image:
        # `,Z` relabels the mount for SELinux on podman/rhel hosts so
        # the container can actually read the bind-mounted files.
        container = (
            DockerContainer(str(image.tag))
            .with_volume_mapping(LIB_DIR, '/tmp/lib', mode='ro,Z')
            .with_volume_mapping(PLUGIN, '/tmp/cpu-usage', mode='ro,Z')
        )
        with container:
            # Some containerfiles install dependencies into a venv at
            # /tmp/venv (debian, ubuntu, archlinux), others install
            # them system-wide (fedora, rhel). Detect and use the
            # right python invocation.
            probe = container.exec(
                ['sh', '-c', 'test -d /tmp/venv && echo venv || echo system']
            )
            use_venv = b'venv' in probe.output
            if use_venv:
                cmd = [
                    'sh',
                    '-c',
                    '. /tmp/venv/bin/activate && cd /tmp && python3 ./cpu-usage',
                ]
            else:
                cmd = ['sh', '-c', 'cd /tmp && python3 ./cpu-usage']
            print(f'Run plugin: {" ".join(cmd)}', flush=True)
            result = container.exec(cmd)
            output = (result.output or b'').decode('utf-8', errors='replace')
            print(f'Script output:\n{output.strip()}', flush=True)

            # Plugin must exit cleanly and produce its normal
            # "<percent>% - ..., user: X%, ..." line. Use a
            # multi-line-tolerant regex because the "user:" segment
            # can land on the first or the second line depending on
            # psutil's by-value sort when several counters read 0%.
            test.assertEqual(result.exit_code, STATE_OK)
            test.assertRegex(output, r'(?s)\d+\.\d+%.*user:')


lib.lftest.attach_each(TestCheck, CONTAINERFILES, _check_containerfile)


if __name__ == '__main__':
    unittest.main()
