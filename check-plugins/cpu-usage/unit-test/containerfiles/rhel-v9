# Base image: Official RHEL 9
FROM registry.access.redhat.com/ubi9

# Install Python
RUN dnf --assumeyes install --nodocs python python-pip python-devel gcc && \
    dnf clean all

# Install tools
RUN dnf --assumeyes install --nodocs https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm && \
    dnf --assumeyes install --nodocs stress && \
    dnf clean all

# Set the working directory in the container
WORKDIR /tmp

# Use ADD to download the requirements.txt file
ADD https://raw.githubusercontent.com/Linuxfabrik/monitoring-plugins/refs/heads/main/lockfiles/py39/requirements.txt /tmp/requirements.txt

# Install dependencies using pip
# Remove the rpm-managed python3-requests and python3-setuptools: both are
# pinned in the lockfile and pip cannot uninstall the rpm copies (no RECORD
# file on UBI9), which otherwise aborts the --require-hashes install.
RUN dnf --assumeyes remove python3-requests python3-setuptools
RUN python3.9 -m pip install --upgrade pip && \
    python3.9 -m pip install --no-cache-dir --requirement requirements.txt --require-hashes --no-deps

# Verify Python installation
RUN python3.9 --version

# Default command to keep the container running
CMD ["sleep", "infinity"]