import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'warn-no-server-reachable',
        'test': 'stdout/no-server-reachable,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'NTP server not reachable. No NTP server is used.',
            'MS Name/IP address         Stratum Poll Reach LastRx Last sample               ',
            '===============================================================================',
        ],
    },
    {
        'id': 'ok-stratum-3-synced',
        'test': 'stdout/stratum-3-synced,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'NTP offset is -2.589ms, Stratum is 3, Leap status is Normal',
            'Reference ID    : D42D9003',
            'Stratum         : 3',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../ntp-chronyd'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
