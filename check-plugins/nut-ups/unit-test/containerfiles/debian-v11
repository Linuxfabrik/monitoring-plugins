# Base image: Debian 11 (bullseye)
FROM docker.io/library/debian:11

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends nut-server && \
    rm -rf /var/lib/apt/lists/*

RUN echo 'MODE=netserver' > /etc/nut/nut.conf && \
    printf '%s\n' \
        '[dummy]' \
        '    driver = dummy-ups' \
        '    port = dummy.dev' \
        '    desc = "Linuxfabrik Dummy UPS"' \
        > /etc/nut/ups.conf && \
    printf '%s\n' \
        'battery.charge: 87' \
        'battery.charge.low: 20' \
        'battery.runtime: 1800' \
        'battery.type: PbAc' \
        'device.mfr: Linuxfabrik' \
        'device.model: Dummy UPS' \
        'input.voltage: 230.0' \
        'output.voltage: 230.0' \
        'ups.load: 22' \
        'ups.mfr: Linuxfabrik' \
        'ups.model: Dummy UPS' \
        'ups.realpower: 110' \
        'ups.realpower.nominal: 1500' \
        'ups.status: OL' \
        'ups.temperature: 30.5' \
        > /etc/nut/dummy.dev && \
    echo 'LISTEN 0.0.0.0 3493' > /etc/nut/upsd.conf && \
    printf '%s\n' \
        '[admin]' \
        '    password = linuxfabrik' \
        '    actions = SET' \
        '    instcmds = ALL' \
        > /etc/nut/upsd.users && \
    chown -R nut:nut /etc/nut /var/lib/nut /run/nut 2>/dev/null || true

EXPOSE 3493
CMD ["sh", "-c", "upsdrvctl start && upsd && exec sleep infinity"]
