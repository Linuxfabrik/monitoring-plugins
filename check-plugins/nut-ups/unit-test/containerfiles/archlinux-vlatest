# Base image: Arch Linux (rolling release)
FROM docker.io/library/archlinux:latest

# archlinux:latest ships an empty keyring. Init/populate it, then refresh archlinux-keyring
# from the current mirror set before installing anything else, otherwise package signatures
# from any current packager fail with "unknown trust".
RUN pacman-key --init && \
    pacman-key --populate archlinux && \
    pacman -Sy --noconfirm --needed archlinux-keyring && \
    pacman -Su --noconfirm --needed nut && \
    rm -rf /var/cache/pacman/pkg/*

RUN echo 'MODE=netserver' > /etc/nut/nut.conf && \
    printf '%s\n' \
        '[dummy]' \
        '    driver = dummy-ups' \
        '    port = dummy.dev' \
        '    desc = "Linuxfabrik Dummy UPS"' \
        > /etc/nut/ups.conf && \
    printf '%s\n' \
        'battery.charge: 87' \
        'battery.charge.low: 20' \
        'battery.runtime: 1800' \
        'battery.type: PbAc' \
        'device.mfr: Linuxfabrik' \
        'device.model: Dummy UPS' \
        'input.voltage: 230.0' \
        'output.voltage: 230.0' \
        'ups.load: 22' \
        'ups.mfr: Linuxfabrik' \
        'ups.model: Dummy UPS' \
        'ups.realpower: 110' \
        'ups.realpower.nominal: 1500' \
        'ups.status: OL' \
        'ups.temperature: 30.5' \
        > /etc/nut/dummy.dev && \
    echo 'LISTEN 0.0.0.0 3493' > /etc/nut/upsd.conf && \
    printf '%s\n' \
        '[admin]' \
        '    password = linuxfabrik' \
        '    actions = SET' \
        '    instcmds = ALL' \
        > /etc/nut/upsd.users && \
    chown -R nut:nut /etc/nut /var/lib/nut /run/nut 2>/dev/null || true

EXPOSE 3493
CMD ["sh", "-c", "upsdrvctl start && upsd && exec sleep infinity"]
