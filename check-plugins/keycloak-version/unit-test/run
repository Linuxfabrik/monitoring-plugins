"""Integration tests for the keycloak-version check plugin.

Uses testcontainers-python to spin up real Keycloak containers and
runs the plugin against them from the host. The plugin hits the
Keycloak admin API, so we do not need Python installed inside the
Keycloak image (which is why the old containerfiles/ approach was
needed).

Requirements:
- podman (or docker) with a reachable socket
- `pip install testcontainers`
- on rootless podman: export
  `DOCKER_HOST=unix:///run/user/$UID/podman/podman.sock` and
  `TESTCONTAINERS_RYUK_DISABLED=true`

Every supported Keycloak major release listed in IMAGES is verified
for:
- version string in the output ("Keycloak vX")
- non-OK exit code (all current test versions are past their EOL date,
  so the plugin must warn or critical - the exact state depends on how
  far past EOL we are, which we explicitly do NOT pin to avoid the
  date-drift problem that the previous hardcoded regex had)
"""

import os
import re
import subprocess
import sys
import unittest

sys.path.insert(0, '..')

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN


# All Keycloak majors from 18 onwards that ship as
# `quay.io/keycloak/keycloak:<major>.<minor>[.<patch>]`. Each entry is the
# latest patch available on quay for that major (as of this file's mtime).
# When a new major is released, add it at the bottom.
IMAGES = [
    ('quay.io/keycloak/keycloak:18.0.2', 'v18'),
    ('quay.io/keycloak/keycloak:19.0.3', 'v19'),
    ('quay.io/keycloak/keycloak:20.0.5', 'v20'),
    ('quay.io/keycloak/keycloak:21.1.2', 'v21'),
    ('quay.io/keycloak/keycloak:22.0.5', 'v22'),
    ('quay.io/keycloak/keycloak:23.0.7', 'v23'),
    ('quay.io/keycloak/keycloak:24.0.5', 'v24'),
    ('quay.io/keycloak/keycloak:25.0.6', 'v25'),
    ('quay.io/keycloak/keycloak:26.6', 'v26'),
]


class TestCheck(unittest.TestCase):
    pass


def _check_image(test, image_pair):
    """Spin up one Keycloak image and run the plugin against the API."""
    image, version_tag = image_pair
    print(f'\n=== Testing {image} ===', flush=True)
    with lib.lftest.run_container(
        image,
        env={
            'KEYCLOAK_ADMIN': 'admin',
            'KEYCLOAK_ADMIN_PASSWORD': 'admin',
        },
        ports=[8080],
        command='start-dev',
        wait_log='Listening on:',
        wait_log_timeout=180,
    ) as container:
        url = 'http://{}:{}'.format(
            container.get_container_host_ip(),
            container.get_exposed_port(8080),
        )
        cmd = [
            'python3',
            '../keycloak-version',
            f'--url={url}',
            '--username=admin',
            '--password=admin',
            # `/opt/keycloak` does not exist on the host, so the
            # file-first path falls through to the API path.
            '--path=/nonexistent',
        ]
        print(f'Run plugin: {" ".join(cmd)}', flush=True)
        result = subprocess.run(
            cmd,
            cwd=os.path.dirname(os.path.abspath(__file__)),
            capture_output=True,
            text=True,
        )
        combined = result.stdout + result.stderr
        print(f'Script output:\n{combined.strip()}', flush=True)

        # Assert the version string is reported.
        test.assertRegex(combined, rf'Keycloak\s+{re.escape(version_tag)}')

        # The plugin must finish with a valid monitoring state.
        # The exact state depends on today's date relative to the
        # tested Keycloak version's EOL window, which shifts over
        # time. Anything except STATE_UNKNOWN means the plugin
        # parsed the version and produced a verdict.
        test.assertIn(result.returncode, (STATE_OK, STATE_WARN, STATE_CRIT))


lib.lftest.attach_each(TestCheck, IMAGES, _check_image, id_func=lambda it: it[1])


if __name__ == '__main__':
    unittest.main()
