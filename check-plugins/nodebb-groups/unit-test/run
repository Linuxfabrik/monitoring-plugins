import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-one-private-group',
        'test': 'stdout/one-private-group,,0',
        'params': '--token=253ff1ec-a5b8-4248-be1d-b898d298d8fc',
        'assert-retc': STATE_OK,
        'assert-in': [
            '1 group, newest group: "Lorem ipsum" (private) with 2 members '
            '(created 2022-03-06 16:21:16 (',
            'createtime ',
            '2022-03-06 16:21:16 (',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../nodebb-groups'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
