import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK

TESTS = [
    {
        'id': 'ok-twentyfive-sensors',
        'test': 'stdout/twentyfive-sensors-ok,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok, checked 25 sensors.'],
    },
    {
        'id': 'crit-thirtyeight-sensors-with-critical',
        'test': 'stdout/thirtyeight-sensors-with-critical,,0',
        'assert-retc': STATE_CRIT,
        'assert-in': ['Checked 38 sensors. There are critical errors.'],
    },
    {
        'id': 'ok-thirtyone-sensors',
        'test': 'stdout/thirtyone-sensors-ok,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok, checked 31 sensors.'],
    },
    {
        'id': 'ok-thirtyeight-sensors',
        'test': 'stdout/thirtyeight-sensors-ok,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok, checked 38 sensors.'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../ipmi-sensor'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
