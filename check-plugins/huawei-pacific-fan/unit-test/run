import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_OK, STATE_WARN

TESTS = [
    {
        'id': 'ok-fans-healthy',
        'test': 'stdout/fans-healthy,,0',
        'params': '--password=linuxfabrik --url=https://localhost --username=admin',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.', 'Fan0', 'normal'],
    },
    {
        'id': 'warn-fan-faulty',
        'test': 'stdout/fans-one-faulty,,0',
        'params': '--password=linuxfabrik --url=https://localhost --username=admin',
        'assert-retc': STATE_WARN,
        'assert-regex': r'fault.*\[WARNING\]',
    },
]


class TestCheck(unittest.TestCase):
    check = '../huawei-pacific-fan'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
