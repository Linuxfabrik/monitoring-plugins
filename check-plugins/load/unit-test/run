import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN

# The load plugin normally calls `psutil.getloadavg()` and
# `psutil.cpu_count()`. Its `--test` hook reads a JSON fixture of the
# form:
#
#     {"loadavg": [<l1>, <l5>, <l15>], "cpu_count": <int>}
#
# The load values are pre-normalisation (raw values as if returned by
# `os.getloadavg()`); the plugin divides each by cpu_count before
# building the message.
TESTS = [
    {
        'id': 'ok-idle-quad-core',
        'test': 'stdout/idle-quad-core,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Avg per CPU: 0.03 0.04 0.05'],
    },
    {
        'id': 'ok-single-core-nominal',
        'test': 'stdout/single-core-nominal,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Avg per CPU: 0.50 0.60 0.70'],
    },
    {
        'id': 'warn-load15-above-warn',
        'test': 'stdout/warn-load15-above-warn,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['Avg per CPU: 1.00 1.25 1.50'],
    },
    {
        'id': 'crit-load15-above-crit',
        'test': 'stdout/crit-load15-above-crit,,0',
        'assert-retc': STATE_CRIT,
        'assert-in': ['Avg per CPU: 5.00 5.50 6.25'],
    },
    {
        'id': 'ok-always-ok-masks-critical',
        'test': 'stdout/crit-load15-above-crit,,0',
        'params': '--always-ok',
        'assert-retc': STATE_OK,
        'assert-in': ['Avg per CPU: 5.00 5.50 6.25'],
    },
    {
        'id': 'ok-custom-thresholds-make-warn-ok',
        'test': 'stdout/warn-load15-above-warn,,0',
        'params': '--warning=2.00 --critical=10.00',
        'assert-retc': STATE_OK,
        'assert-in': ['Avg per CPU: 1.00 1.25 1.50'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../load'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
