import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK
import lib.lftest


BASE_PARAMS = '--token=TOKEN --account-id=ACCOUNT-ID'


TESTS = [
    {
        'id': 'crit-products-critical',
        'test': 'stdout/products-critical,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'There are critical errors.',
            'ID    ! Customer     ! Tag          ! Size (alloc/avail)  ! Dev ! Maint. ! Locked ! Busy  ! ',
            '------+--------------+--------------+---------------------+-----+--------+--------+-------+-',
            '34567 ! BK-200999-1  ! tag01, tag02 ! 9.1TiB / 9.1TiB     ! 1   ! False  ! False  ! False ! ',
        ],
    },
    {
        'id': 'ok-products-healthy',
        'test': 'stdout/products-healthy,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok.',
            'ID    ! Customer     ! Tag          ! Size (alloc/avail)  ! Dev ! Maint. ! Locked ! Busy  ! ',
            '------+--------------+--------------+---------------------+-----+--------+--------+-------+-',
            '34567 ! BK-200999-1  ! tag01, tag02 ! 9.1TiB / 9.1TiB     ! 1   ! False  ! False  ! False ! ',
        ],
    },
    {
        'id': 'ok-no-products',
        'test': 'stdout/no-products,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok'],
    },
    {
        'id': 'crit-products-maintenance-severity-crit',
        'test': 'stdout/products-maintenance,,0',
        'params': f'{BASE_PARAMS} --severity=crit',
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'There are critical errors.',
            'ID    ! Customer     ! Tag          ! Size (alloc/avail)  ! Dev ! Maint. ! Locked ! Busy  ! ',
            '------+--------------+--------------+---------------------+-----+--------+--------+-------+-',
            '34567 ! BK-200999-1  ! tag01, tag02 ! 9.1TiB / 9.1TiB     ! 1   ! False  ! False  ! False ! ',
        ],
    },
    {
        'id': 'ok-ignore-customer',
        'test': 'stdout/products-healthy,,0',
        'params': f"{BASE_PARAMS} --ignore-customer='BK-200999-1$'",
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.', '26056'],
        'assert-not-in': ['34567'],
    },
    {
        'id': 'ok-ignore-tag',
        'test': 'stdout/products-healthy,,0',
        'params': f"{BASE_PARAMS} --ignore-tag='^tag01$'",
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.', '26056'],
        'assert-not-in': ['34567'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../infomaniak-swiss-backup-products'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
