import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_UNKNOWN, STATE_WARN

# The disk-usage plugin normally calls `psutil.disk_partitions()` to
# enumerate mountpoints and then `psutil.disk_usage(mountpoint)` for
# each one. Its `--test` hook replaces both calls with a JSON
# fixture:
#
#     {
#       "partitions": [
#         {"device": "...", "mountpoint": "...", "fstype": "...", "opts": "..."},
#         ...
#       ],
#       "usage": {
#         "<mountpoint>": {"total": <bytes>, "used": <bytes>,
#                          "free": <bytes>, "percent": <0..100>},
#         ...
#       }
#     }
TESTS = [
    {
        'id': 'ok-single-root-nominal',
        'test': 'stdout/single-root-nominal,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['/ 30.0%'],
    },
    {
        'id': 'ok-two-mounts-root-and-boot',
        'test': 'stdout/two-mounts-root-and-boot,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok.',
            '/',
            '/boot',
        ],
    },
    {
        'id': 'warn-single-root-above-warn',
        'test': 'stdout/single-root-warn,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['91.0%', '[WARNING]'],
    },
    {
        'id': 'crit-single-root-above-crit',
        'test': 'stdout/single-root-crit,,0',
        'assert-retc': STATE_CRIT,
        'assert-in': ['98.0%', '[CRITICAL]'],
    },
    {
        'id': 'ok-always-ok-masks-critical',
        'test': 'stdout/single-root-crit,,0',
        'params': '--always-ok',
        'assert-retc': STATE_OK,
        'assert-in': ['98.0%'],
    },
    {
        'id': 'ok-exclude-boot-leaves-only-root',
        'test': 'stdout/two-mounts-root-and-boot,,0',
        'params': '--exclude-pattern=boot',
        'assert-retc': STATE_OK,
        'assert-not-in': ['/boot'],
    },
    # --match / --ignore are the canonical, suite-wide filter names
    # (regex, case-insensitive). The deprecated --include-* / --exclude-*
    # aliases must keep behaving identically. The three-mounts-mixed-state
    # fixture has / (30%, OK), /var (91%, WARN), /home (98%, CRIT).
    {
        'id': 'warn-match-keeps-only-var',
        'test': 'stdout/three-mounts-mixed-state,,0',
        'params': '--match=var',
        'assert-retc': STATE_WARN,
        'assert-in': ['/var'],
        'assert-not-in': ['/home', '97.8GiB'],
    },
    {
        'id': 'warn-match-is-case-insensitive',
        'test': 'stdout/three-mounts-mixed-state,,0',
        # disk-usage filters case-insensitively (Windows drive letters,
        # filesystem paths): uppercase VAR still matches /var.
        'params': '--match=VAR',
        'assert-retc': STATE_WARN,
        'assert-in': ['/var'],
    },
    {
        'id': 'ok-match-case-sensitive-opt-in-misses',
        'test': 'stdout/three-mounts-mixed-state,,0',
        # (?-i:...) re-enables case-sensitivity: uppercase VAR no longer
        # matches the lowercase /var, so nothing is checked.
        'params': '--match=(?-i:VAR)',
        'assert-retc': STATE_OK,
        'assert-in': ['Nothing checked.'],
    },
    {
        # #1308: when the filters match nothing, --no-match-severity turns the
        # otherwise-OK "Nothing checked." into the configured state.
        'id': 'unknown-no-match-severity-maps-empty-to-unknown',
        'test': 'stdout/three-mounts-mixed-state,,0',
        'params': '--match=(?-i:VAR) --no-match-severity=unknown',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Nothing checked.'],
    },
    {
        'id': 'crit-no-match-severity-maps-empty-to-crit',
        'test': 'stdout/three-mounts-mixed-state,,0',
        'params': '--match=(?-i:VAR) --no-match-severity=crit',
        'assert-retc': STATE_CRIT,
        'assert-in': ['Nothing checked.'],
    },
    {
        'id': 'ok-ignore-drops-var-and-home',
        'test': 'stdout/three-mounts-mixed-state,,0',
        'params': '--ignore=var|home',
        'assert-retc': STATE_OK,
        'assert-in': ['/ 30.0%'],
        'assert-not-in': ['[WARNING]', '[CRITICAL]'],
    },
    {
        'id': 'warn-include-regex-alias-matches-match',
        'test': 'stdout/three-mounts-mixed-state,,0',
        'params': '--include-regex=var',
        'assert-retc': STATE_WARN,
        'assert-in': ['/var'],
        'assert-not-in': ['/home'],
    },
    # #782: --brief hides filesystems within the thresholds and only
    # renders rows in WARN/CRIT state. Alerting and perfdata are
    # unaffected: all filesystems still drive the overall state.
    #
    # The three-mounts-mixed-state fixture has:
    #   /      30% (OK)
    #   /var   91% (WARN at --warning=90%USED)
    #   /home  98% (CRIT at --critical=95%USED)
    {
        'id': 'crit-three-mounts-full-table',
        'test': 'stdout/three-mounts-mixed-state,,0',
        # default (no --brief): all three mounts are in the table;
        # assert on the human-readable used size of each row (`37.3GiB`
        # is unique to /, `91.3GiB` to /var, `97.8GiB` to /home). These
        # strings only appear in the rendered table, not in the raw-
        # bytes perfdata section.
        'assert-retc': STATE_CRIT,
        'assert-in': ['37.3GiB', '91.3GiB', '97.8GiB'],
    },
    {
        'id': 'crit-three-mounts-brief-hides-ok-row',
        'test': 'stdout/three-mounts-mixed-state,,0',
        'params': '--brief',
        'assert-retc': STATE_CRIT,
        'assert-in': ['91.3GiB', '97.8GiB'],
        # the OK-state root filesystem must not appear in the table;
        # 37.3GiB is its human-readable used size and is unique to
        # the / row (the raw-bytes perfdata uses 40000000000 instead).
        'assert-not-in': ['37.3GiB'],
    },
    {
        'id': 'ok-two-mounts-brief-all-ok-renders-single-line',
        'test': 'stdout/two-mounts-root-and-boot,,0',
        'params': '--brief',
        # with --brief and zero WARN/CRIT rows, the plugin collapses
        # to a single-line "Everything is ok. (thresholds)" summary
        # without a table header row.
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.'],
        'assert-not-in': [
            'Mountpoint',  # no table header
            '300.0MiB',  # /boot human-readable used size, table-only
        ],
    },
    # #662 / #1286: --mount overrides the global thresholds for a single
    # mountpoint (matched exactly, case-insensitively). All other mounts keep
    # the global thresholds. The three-mounts-mixed-state fixture has
    # / (30%), /var (91%), /home (98%).
    {
        'id': 'ok-mount-override-relaxes-var',
        'test': 'stdout/three-mounts-mixed-state,,0',
        # /var is 91% (WARN at the global 90%), but the override relaxes it to
        # 99%USED, so it is OK. The single-line summary shows the override.
        'params': '--match=/var$ --mount=/var,99%USED,99%USED',
        'assert-retc': STATE_OK,
        'assert-in': ['/var', 'warn=99%USED crit=99%USED'],
    },
    {
        'id': 'crit-mount-override-tightens-root',
        'test': 'stdout/three-mounts-mixed-state,,0',
        # / is 30% used (OK globally), but the override tightens it so 30%
        # crosses the 25%USED critical threshold.
        'params': '--match=/$ --mount=/,20%USED,25%USED',
        'assert-retc': STATE_CRIT,
        'assert-in': ['[CRITICAL]', 'warn=20%USED crit=25%USED'],
    },
    {
        'id': 'crit-mount-override-shown-in-table',
        'test': 'stdout/three-mounts-mixed-state,,0',
        # no --match: a 3-row table. The override on / (30%, OK at the global
        # 90/95) makes it CRIT and the row must carry its own thresholds so
        # the admin sees why an otherwise-fine row alerts.
        'params': '--mount=/,20%USED,25%USED',
        'assert-retc': STATE_CRIT,
        'assert-in': ['(warn=20%USED crit=25%USED)', '[CRITICAL]'],
    },
    {
        'id': 'warn-mount-unknown-path-reported-not-applied',
        'test': 'stdout/three-mounts-mixed-state,,0',
        # an override for a mountpoint that is not checked has no effect on the
        # state (/var keeps the global thresholds and stays WARN), but the
        # plugin reports the unmatched entry so a typo is not silently ignored.
        'params': '--match=/var$ --mount=/does/not/exist,1%USED,1%USED',
        'assert-retc': STATE_WARN,
        'assert-in': [
            '/var',
            'warn=90%USED crit=95%USED',
            'ignored `--mount` for /does/not/exist (not checked)',
        ],
    },
    {
        'id': 'ok-mount-matched-emits-no-note',
        'test': 'stdout/three-mounts-mixed-state,,0',
        # a --mount entry that matches a checked filesystem must not trigger
        # the "ignored --mount" note.
        'params': '--match=/var$ --mount=/var,99%USED,99%USED',
        'assert-retc': STATE_OK,
        'assert-not-in': ['ignored `--mount`'],
    },
    {
        'id': 'unknown-mount-malformed',
        'test': 'stdout/three-mounts-mixed-state,,0',
        # --mount needs three fields; two is a usage error -> UNKNOWN.
        'params': '--mount=/var,90%USED',
        'assert-retc': STATE_UNKNOWN,
    },
    # Windows drive letters: the override matches `C:\` whether the user types
    # `C`, `C:` or `C:\`. The windows-drives fixture has C:\ (89.4%) and
    # D:\ (9.3%); without --mount both are OK (below the global 90%).
    {
        'id': 'crit-mount-windows-drive-letter',
        'test': 'stdout/windows-drives,,0',
        # `C` normalizes to the `C:\` mountpoint and overrides it to 3%USED
        # critical, so 89.4% is CRIT. D:\ keeps the global thresholds (OK).
        'params': '--mount=C,2%USED,3%USED',
        'assert-retc': STATE_CRIT,
        'assert-in': ['89.4%', '[CRITICAL]'],
        'assert-not-in': ['9.3% [CRITICAL]'],
    },
]


class TestCheck(unittest.TestCase):
    check = '../disk-usage'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
