    "Datafield": {
        "1": {
            "varname": "disk_usage_always_ok",
            "caption": "Disk Usage: Always OK?",
            "description": "Always returns OK.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "0ef8a81d-abee-489a-ab37-1bdb28d69ff4"
        },
        "2": {
            "varname": "disk_usage_brief",
            "caption": "Disk Usage: Brief?",
            "description": "Hide table rows for filesystems within the thresholds and show only those in WARN/CRIT state. Perfdata and alerting are unaffected: all filesystems still emit perfdata and still drive the overall check state.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "d042bf80-74d7-4855-942a-10ae41c8a194"
        },
        "3": {
            "varname": "disk_usage_critical",
            "caption": "Disk Usage: Critical",
            "description": "CRIT threshold in the form `<number>[unit][method]`. Unit is one of `%|K|M|G|T|P` (default: `%`). `K` means kibibyte etc. Method is one of `USED|FREE` (default: `USED`). `USED` means \"number or more\", `FREE` means \"number or less\". Examples: `95` = 95% used. `9.5M` = 9.5 MiB used. `5%FREE`. `1400GUSED`.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "f0468cc4-7e08-49f6-8258-18bde965cbc0"
        },
        "4": {
            "varname": "disk_usage_fstype",
            "caption": "Disk Usage: Fstype",
            "description": "Override the default behaviour (check physical devices only) and check these file system types instead. Can be specified multiple times. Run `disk-usage --list-fstypes` first to see available types (they are machine dependent).",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "86fcf815-b556-47ff-8477-9a2fb8ff29b8"
        },
        "5": {
            "varname": "disk_usage_ignore",
            "caption": "Disk Usage: Ignore",
            "description": "Ignore mountpoints matching this Python regular expression. Case-insensitive by default (on Windows, drive letters and paths are case-insensitive; use drive letters such as `C:` or `C`). For case-sensitive matching, wrap the pattern in `(?-i:...)`, e.g. `(?-i:Data)`. Can be specified multiple times.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "a63fdf48-46ec-4188-bd31-cb9ccc04732f"
        },
        "6": {
            "varname": "disk_usage_list_fstypes",
            "caption": "Disk Usage: List Fstypes?",
            "description": "Print available file system types and which ones are checked by default, then exit.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "5c45373f-09cd-4dc4-95de-69b992363eca"
        },
        "7": {
            "varname": "disk_usage_match",
            "caption": "Disk Usage: Match",
            "description": "Only check mountpoints matching this Python regular expression. Case-insensitive by default (on Windows, drive letters and paths are case-insensitive; use drive letters such as `C:` or `C`). For case-sensitive matching, wrap the pattern in `(?-i:...)`, e.g. `(?-i:Data)`. Can be specified multiple times.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "73ff35cc-ab8e-49a9-9955-b85dfb3a34e3"
        },
        "8": {
            "varname": "disk_usage_mount",
            "caption": "Disk Usage: Mount",
            "description": "Override the global --warning/--critical thresholds for a single mountpoint, in the form `<mountpoint>,<warning>,<critical>`. Each threshold uses the same `<number>[unit][method]` syntax as --warning/--critical. The mountpoint is matched exactly and case-insensitively, so the override always hits exactly one mountpoint and never several. On Windows, use drive letters such as `C:` or `C`. Can be specified multiple times. Example: `--mount=/var/log,80%USED,90%USED`",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "aed7781d-ead2-4093-8dc3-4673dfacdb35"
        },
        "9": {
            "varname": "disk_usage_perfdata_regex",
            "caption": "Disk Usage: Perfdata Regex",
            "description": "Only emit perfdata keys matching this Python regex. For a list of perfdata keys, see the README or run this plugin. Can be specified multiple times.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "ea299f9c-cfd2-4daa-b103-f0c221c34a27"
        },
        "10": {
            "varname": "disk_usage_warning",
            "caption": "Disk Usage: Warning",
            "description": "WARN threshold in the form `<number>[unit][method]`. Unit is one of `%|K|M|G|T|P` (default: `%`). `K` means kibibyte etc. Method is one of `USED|FREE` (default: `USED`). `USED` means \"number or more\", `FREE` means \"number or less\". Examples: `95` = 95% used. `9.5M` = 9.5 MiB used. `5%FREE`. `1400GUSED`.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
