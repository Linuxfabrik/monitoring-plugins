import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_UNKNOWN
import lib.lftest


TESTS = [
    {
        'id': 'ok-healthy',
        'test': 'stdout/healthy,,0',
        'assert-retc': STATE_OK,
        'assert-regex': r'Everything is ok\.',
    },
    {
        'id': 'unknown-malformed',
        'test': 'stdout/malformed,,0',
        'assert-retc': STATE_UNKNOWN,
        'assert-regex': r'Malformed mod_qos status info\.',
    },
]


class TestCheck(unittest.TestCase):

    check = '../mod-qos-stats'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
