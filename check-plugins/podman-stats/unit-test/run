import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-no-containers',
        'test': 'stdout/no-containers,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok,'],
    },
    {
        'id': 'ok-traefik-idle',
        'test': 'stdout/traefik-idle,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok,',
            'Container         ! CPU % ! Mem %',
            '------------------+-------+------',
            'traefik_traefik.2 ! 0.0   ! 0.0',
        ],
    },
    {
        'id': 'ok-traefik-idle-full-name',
        'test': 'stdout/traefik-idle,,0',
        'params': '--full-name',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok,',
            'Container                                   ! CPU % ! Mem %',
            '--------------------------------------------+-------+------',
            'traefik_traefik.2.1idw12p2yqpxutlzkcwign4at ! 0.0   ! 0.0',
        ],
    },
    {
        'id': 'ok-elasticsearch-graylog-mongo',
        'test': 'stdout/elasticsearch-graylog-mongo,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok,',
            'Container     ! CPU % ! Mem %',
            '--------------+-------+------',
            'elasticsearch ! 188.8 ! 16.7',
            'graylog       ! 204.2 ! 5.7',
            'mongo         ! 0.3   ! 1.9',
        ],
    },
    {
        'id': 'ok-gitlab-runners-long-names',
        'test': 'stdout/gitlab-runners-long-names,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok,',
            'Container                                                           ! CPU % ! Mem %',
            '--------------------------------------------------------------------+-------+------',
            'runner-7ayh6h5f-project-107-concurrent-0-37b2c7aee9359db9-build     ! 95.0  ! 1.2',
            'runner-7ayh6h5f-project-19-concurrent-0-99f0211c36d59d01-build      ! 59.5  ! 1.0',
            'runner-7ayh6h5f-project-49-concurrent-0-e180afe41fc754dc-predefined ! 79.5  ! 0.1',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../podman-stats'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
