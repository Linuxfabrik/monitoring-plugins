"""See the check's README for more details."""

import argparse
import json
import sys

import lib.args
import lib.base
import lib.huawei
import lib.lftest
import lib.txt
from lib.globals import STATE_CRIT, STATE_OK, STATE_UNKNOWN, STATE_WARN

__author__ = 'Linuxfabrik GmbH, Zurich/Switzerland'
__version__ = '2026040801'

DESCRIPTION = """Checks the health and running status of all interface modules on a Huawei OceanStor
Dorado storage system via the REST API (/intf_module endpoint). Alerts when any
module reports a non-normal state."""

DEFAULT_CACHE_EXPIRE = 15  # minutes; default session timeout period is 20 minutes
DEFAULT_INSECURE = True
DEFAULT_NO_PROXY = False
DEFAULT_SCOPE = 0
DEFAULT_TIMEOUT = 3


def parse_args():
    """Parse command line arguments using argparse."""
    parser = argparse.ArgumentParser(description=DESCRIPTION)

    parser.add_argument(
        '-V',
        '--version',
        action='version',
        version=f'%(prog)s: v{__version__} by {__author__}',
    )

    parser.add_argument(
        '--always-ok',
        help=lib.args.help('--always-ok'),
        dest='ALWAYS_OK',
        action='store_true',
        default=False,
    )

    parser.add_argument(
        '--cache-expire',
        help=lib.args.help('--cache-expire') + ' Default: %(default)s',
        dest='CACHE_EXPIRE',
        type=int,
        default=DEFAULT_CACHE_EXPIRE,
    )

    parser.add_argument(
        '--device-id',
        help='Huawei OceanStor Dorado API Device ID.',
        dest='DEVICE_ID',
        required=True,
    )

    parser.add_argument(
        '--insecure',
        help=lib.args.help('--insecure'),
        dest='INSECURE',
        action='store_true',
        default=DEFAULT_INSECURE,
    )

    parser.add_argument(
        '--no-proxy',
        help=lib.args.help('--no-proxy'),
        dest='NO_PROXY',
        action='store_true',
        default=DEFAULT_NO_PROXY,
    )

    parser.add_argument(
        '--password',
        help='Huawei OceanStor Dorado API password.',
        dest='PASSWORD',
        required=True,
    )

    parser.add_argument(
        '--scope',
        help='Huawei OceanStor Dorado API scope.',
        dest='SCOPE',
        default=DEFAULT_SCOPE,
    )

    parser.add_argument(
        '--test',
        help=lib.args.help('--test'),
        dest='TEST',
        type=lib.args.csv,
    )

    parser.add_argument(
        '--timeout',
        help=lib.args.help('--timeout') + ' Default: %(default)s (seconds)',
        dest='TIMEOUT',
        type=int,
        default=DEFAULT_TIMEOUT,
    )

    parser.add_argument(
        '-u',
        '--url',
        help='Huawei OceanStor Dorado API URL.',
        dest='URL',
        required=True,
    )

    parser.add_argument(
        '--username',
        help='Huawei OceanStor Dorado API username.',
        dest='USERNAME',
        required=True,
    )

    args, _ = parser.parse_known_args()
    return args


def main():
    """The main function. Hier spielt die Musik."""

    # parse the command line, exit with UNKNOWN if it fails
    try:
        args = parse_args()
    except SystemExit:
        sys.exit(STATE_UNKNOWN)

    if not args.URL.startswith('http'):
        lib.base.cu('--url parameter has to start with "http://" or https://".')

    # fetch data
    if args.TEST is None:
        result = lib.huawei.get_data('intf_module', args)
    else:
        # do not call the command, put in test data
        stdout, stderr, retc = lib.lftest.test(args.TEST)
        result = json.loads(stdout)

    # no valuable result?
    if not result:
        lib.base.cu(f'Got no valuable response from {args.URL}.')
    if result.get('error').get('code') != 0:
        lib.base.oao(
            f'{result.get("error").get("description")}'
            f' {result.get("error").get("suggestion")}',
            STATE_UNKNOWN,
        )

    # init some vars
    msg = ''
    state = STATE_OK
    perfdata = ''

    # analyze the data
    table_data = []
    for iface in result.get('data'):
        health_state = STATE_OK
        if lib.huawei.get_health_status(iface.get('HEALTHSTATUS')) != 'Normal (1)':
            health_state = STATE_WARN
            state = lib.base.get_worst(state, health_state)

        running_state = STATE_OK
        if (
            lib.huawei.get_running_status(iface.get('RUNNINGSTATUS')) != 'Normal (1)'
            and lib.huawei.get_running_status(iface.get('RUNNINGSTATUS'))
            != 'Running (2)'
            and lib.huawei.get_running_status(iface.get('RUNNINGSTATUS'))
            != 'Powering on (12)'
            and lib.huawei.get_running_status(iface.get('RUNNINGSTATUS'))
            != 'Online (27)'
        ):
            running_state = STATE_WARN
            state = lib.base.get_worst(state, running_state)

        iface['UUID'] = lib.huawei.get_uuid(iface)

        perfdata += lib.base.get_perfdata(
            f'{iface["UUID"]}_HEALTHSTATUS',
            iface['HEALTHSTATUS'],
            crit=2,
            _min=0,
            _max=2,
        )
        perfdata += lib.base.get_perfdata(
            f'{iface["UUID"]}_RUNNINGSTATUS',
            iface['RUNNINGSTATUS'],
            _min=0,
        )

        iface['health_state'] = lib.base.state2str(health_state, empty_ok=False)
        iface['running_state'] = lib.base.state2str(running_state, empty_ok=False)
        iface['MODEL'] = lib.huawei.get_interface_model(iface['MODEL'])
        iface['RUNMODE'] = lib.huawei.get_interface_runmode(iface['RUNMODE'])
        iface['LIGHTSTATUS'] = lib.huawei.get_led_status(iface['LIGHTSTATUS'])

        table_data.append(iface)

    if table_data:
        keys = [
            'UUID',
            'LOCATION',
            'MODEL',
            'RUNMODE',
            'LIGHTSTATUS',
            'health_state',
            'running_state',
        ]
        headers = ['UUID', 'Location', 'Model', 'RunMode', 'LED', 'Health', 'Running']
        msg += lib.base.get_table(table_data, keys, header=headers)

    counter = result.get('counter', 0)
    msg += f'\nFetched API {counter} {lib.txt.pluralize("time", counter)}'

    if state == STATE_CRIT:
        msg = 'There are critical errors.\n\n' + msg
    elif state == STATE_WARN:
        msg = 'There are warnings.\n\n' + msg
    else:
        msg = 'Everything is ok.\n\n' + msg

    # over and out
    lib.base.oao(msg, state, perfdata, always_ok=args.ALWAYS_OK)


if __name__ == '__main__':
    try:
        main()
    except Exception:
        lib.base.cu()
