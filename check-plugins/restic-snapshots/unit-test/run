import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_WARN
import lib.lftest


BASE_PARAMS = '--warn=1 --repo=test --password-file=test'


TESTS = [
    {
        'id': 'warn-snapshots-v1',
        'test': 'stdout/snapshots-v1,,',
        'params': BASE_PARAMS,
        'assert-retc': STATE_WARN,
        'assert-in': ['There are warnings.\n\nLatest snapshot '],
    },
    {
        'id': 'warn-snapshots-v2',
        'test': 'stdout/snapshots-v2,,',
        'params': BASE_PARAMS,
        'assert-retc': STATE_WARN,
        'assert-in': ['There are warnings.\n\nLatest snapshot '],
    },
]


class TestCheck(unittest.TestCase):

    check = '../restic-snapshots'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
