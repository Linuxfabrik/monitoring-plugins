import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-empty-podman',
        'test': 'stdout/empty-podman,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            '0 Containers',
            '0 Images',
            'Storage Driver: overlay',
            'Podman v3.0.1',
            '8 CPUs',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../podman-info'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
