import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN

BASE_PARAMS = '--hostname localhost --username user --password password'


TESTS = [
    {
        'id': 'ok-five-services',
        'test': 'stdout/five-services-ok,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_OK,
        'assert-regex': r'5 services checked\.',
    },
    {
        'id': 'ok-five-services-with-filter',
        'test': 'stdout/five-services-ok,,0',
        'params': f'{BASE_PARAMS} --filter PROD',
        'assert-retc': STATE_OK,
        'assert-regex': r'3 services checked\.',
    },
    {
        'id': 'warn-five-services-some-warn',
        'test': 'stdout/five-services-some-warn,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_WARN,
        'assert-regex': r'5 services checked\.',
    },
    {
        'id': 'crit-five-services-some-warn-severity-crit',
        'test': 'stdout/five-services-some-warn,,0',
        'params': f'--severity crit {BASE_PARAMS}',
        'assert-retc': STATE_CRIT,
        'assert-regex': r'5 services checked\.',
    },
    {
        'id': 'warn-two-services-with-warn',
        'test': 'stdout/two-services-with-warn,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_WARN,
        'assert-regex': r'2 services checked\.',
    },
]


class TestCheck(unittest.TestCase):

    check = '../kemp-services'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
