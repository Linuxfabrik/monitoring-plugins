import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-connections-nominal',
        'test': 'stdout/connections-nominal,,',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Connections: 25.2M opened, 25.2M closed, 18.0 active, 1.0 idle',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../starface-database-stats'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
