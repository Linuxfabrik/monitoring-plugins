import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'ok-enhancement-network-maintenance',
        'test': 'stdout/enhancement-network-maintenance,,0',
        'params': '--token=TOKEN',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok.',
            'Type        ! Title               ! Services ! Start               ! End',
            '------------+---------------------+----------+---------------------+----',
            'enhancement ! Network maintenance ! hosting  ! 2022-12-23 10:55:50 ! 2023-01-01 12:46:37',
        ],
    },
    {
        'id': 'ok-impacting-mail-completed',
        'test': 'stdout/impacting-mail-completed,,0',
        'params': '--token=TOKEN',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok.',
            'Type        ! Title                                ! Services               ! Start               ! End',
            '------------+--------------------------------------+------------------------+---------------------+----',
            'impacting   ! Mail Service                         ! email_hosting          ! 2022-12-21 12:50:36 ! 2022-12-21 13:18:53',
        ],
    },
    {
        'id': 'warn-impacting-in-progress',
        'test': 'stdout/impacting-in-progress,,0',
        'params': '--token=TOKEN',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'impacting: Access slowness and instability (email_hosting, webmail)',
