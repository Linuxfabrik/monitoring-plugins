"""Integration tests for the mysql-perf-metrics check plugin.

The plugin opens a real `pymysql` connection and reads a set of
performance-related counters from `SHOW GLOBAL STATUS`,
`SHOW VARIABLES` and `INFORMATION_SCHEMA.SYSTEM_VARIABLES`. A
static fixture cannot drive it - we spin up an actual MariaDB
server and let the plugin talk to it over TCP.

Per CONTRIBUTING's "Combine container tests with fixtures" rule,
this file holds only the happy-path integration test. A freshly
booted MariaDB ships sensible defaults for both checked variables
(`innodb_stats_on_metadata=OFF`, `concurrent_insert=AUTO`) and no
admin-set deprecated variables (all `GLOBAL_VALUE_ORIGIN` =
`COMPILE-TIME`), so the plugin reports verifications and exits OK
with `mysql_deprecated_config_variables=0`.

The WARN path for the deprecated-variable check is intentionally
not asserted here: the set of variables MariaDB exposes as
"Deprecated" in `INFORMATION_SCHEMA.SYSTEM_VARIABLES` differs per
LTS, so a cross-version `SET GLOBAL <known-deprecated-var>` is
fragile. The detection itself is verified by the perfdata key
existing in the OK output (the code path runs unconditionally).

Runs against the current MariaDB LTS releases
(`lib.lftest.MARIADB_LTS_IMAGES`).

Requirements:
- podman (or docker) with a reachable socket
- `pip install testcontainers`
- `tools/run-unit-tests` auto-sets `CONTAINER_HOST` and
  `TESTCONTAINERS_RYUK_DISABLED`
"""

import os
import subprocess
import sys
import unittest

sys.path.insert(0, '..')

import lib.lftest
from lib.globals import STATE_OK

IMAGES = lib.lftest.MARIADB_LTS_IMAGES


class TestCheck(unittest.TestCase):
    pass


def _check_image(test, image_pair):
    image, label = image_pair
    print(f'\n=== Testing {label} ({image}) ===', flush=True)
    with lib.lftest.run_mariadb(image) as (_container, defaults_file):
        cmd = [
            'python3', '../mysql-perf-metrics',
            f'--defaults-file={defaults_file}',
        ]
        print(f'Run plugin: {" ".join(cmd)}', flush=True)
        result = subprocess.run(
            cmd,
            cwd=os.path.dirname(os.path.abspath(__file__)),
            capture_output=True,
            text=True,
        )
        combined = result.stdout + result.stderr
        print(f'Script output:\n{combined.strip()}', flush=True)

        test.assertEqual(result.returncode, STATE_OK)
        # Both knobs ship safe defaults on a fresh MariaDB container;
        # "Everything is ok." leads the OK output, followed by the
        # verified values.
        test.assertIn('Everything is ok.', combined)
        test.assertIn('`innodb_stats_on_metadata` is `OFF`', combined)
        test.assertIn('`concurrent_insert` is `AUTO`', combined)
        # The deprecated-variable check ran; perfdata emitted with 0
        # findings (default-configured server has only COMPILE-TIME
        # origins).
        test.assertIn('mysql_deprecated_config_variables', combined)
        test.assertNotIn('[WARNING]', combined)


lib.lftest.attach_each(TestCheck, IMAGES, _check_image, id_func=lambda it: it[1])


if __name__ == '__main__':
    unittest.main()
