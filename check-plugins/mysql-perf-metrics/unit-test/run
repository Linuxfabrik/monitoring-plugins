"""Integration tests for the mysql-perf-metrics check plugin.

The plugin opens a real `pymysql` connection and reads a set of
performance-related counters from `SHOW GLOBAL STATUS`,
`SHOW VARIABLES` and `INFORMATION_SCHEMA.SYSTEM_VARIABLES`. A
static fixture cannot drive it - we spin up an actual MariaDB
server and let the plugin talk to it over TCP.

Per CONTRIBUTING's "Combine container tests with fixtures" rule,
this file holds only the happy-path integration test. A freshly
booted MariaDB ships sensible defaults for both checked variables
(`innodb_stats_on_metadata=OFF`, `concurrent_insert=AUTO`) and no
admin-set deprecated variables (all `GLOBAL_VALUE_ORIGIN` =
`COMPILE-TIME`), so the plugin reports verifications and exits OK
with `mysql_deprecated_config_variables=0`.

The WARN path for the deprecated-variable check is intentionally
not asserted here: the set of variables MariaDB exposes as
"Deprecated" in `INFORMATION_SCHEMA.SYSTEM_VARIABLES` differs per
LTS, so a cross-version `SET GLOBAL <known-deprecated-var>` is
fragile. The detection itself is verified by the perfdata key
existing in the OK output (the code path runs unconditionally).

The test matrix is defined by the Containerfiles under
`containerfiles/`. Each file is a Containerfile (typically a
one-line `FROM`) and gets built once via testcontainers' DockerImage
(cached across runs). Add a new MariaDB LTS by dropping in a new
Containerfile; retire one by deleting the file - no central image
list to maintain.

Requirements:
- podman (or docker) with a reachable socket
- `pip install testcontainers`
- `tools/run-unit-tests` auto-sets `CONTAINER_HOST` and
  `TESTCONTAINERS_RYUK_DISABLED`
"""

import os
import subprocess
import sys
import unittest

sys.path.insert(0, '..')

import lib.lftest
from lib.globals import STATE_OK, STATE_WARN

HERE = os.path.dirname(os.path.abspath(__file__))
CONTAINERFILES_DIR = os.path.join(HERE, 'containerfiles')
CONTAINERFILES = sorted(
    name for name in os.listdir(CONTAINERFILES_DIR)
    if os.path.isfile(os.path.join(CONTAINERFILES_DIR, name))
)


class TestCheck(unittest.TestCase):
    pass


def _check_image(test, containerfile):
    path = os.path.join(CONTAINERFILES_DIR, containerfile)
    print(f'\n=== Testing {containerfile} ===', flush=True)
    with lib.lftest.run_mysql_compatible_from_containerfile(path) as (_container, defaults_file):
        # `--storage-type=skip` so the SSD/HDD-aware checks do not
        # leak the controller host's storage into the assertions;
        # they are exercised separately on real images.
        cmd = [
            'python3', '../mysql-perf-metrics',
            f'--defaults-file={defaults_file}',
            '--storage-type=skip',
        ]
        print(f'Run plugin: {" ".join(cmd)}', flush=True)
        result = subprocess.run(
            cmd,
            cwd=HERE,
            capture_output=True,
            text=True,
        )
        combined = result.stdout + result.stderr
        print(f'Script output:\n{combined.strip()}', flush=True)

        # Two safe knobs (`innodb_stats_on_metadata`, `concurrent_insert`)
        # and the deprecated-config check run on every image; the latter
        # emits perfdata even when zero deprecated variables are set.
        test.assertIn('`innodb_stats_on_metadata` is `OFF`', combined)
        test.assertIn('`concurrent_insert` is `AUTO`', combined)
        test.assertIn('mysql_deprecated_config_variables', combined)

        # MariaDB exposes `innodb_snapshot_isolation` already on 10.6.
        # Up to and including 11.4 the default is OFF; combined with the
        # also-default `transaction_isolation=REPEATABLE-READ`, the
        # plugin mirrors mysqltuner's badprint and goes WARN. MariaDB
        # 11.8 flipped the default to ON, so the WARN no longer fires
        # there. MySQL never had the variable and stays OK on every LTS.
        warns_on_snapshot = containerfile in (
            'mariadb-v106', 'mariadb-v1011', 'mariadb-v114',
        )
        if warns_on_snapshot:
            test.assertEqual(result.returncode, STATE_WARN)
            test.assertIn(
                '`innodb_snapshot_isolation` is `OFF` with `REPEATABLE-READ`',
                combined,
            )
        else:
            test.assertEqual(result.returncode, STATE_OK)
            test.assertIn('Everything is ok.', combined)
            test.assertNotIn('[WARNING]', combined)


lib.lftest.attach_each(TestCheck, CONTAINERFILES, _check_image)


if __name__ == '__main__':
    unittest.main()
