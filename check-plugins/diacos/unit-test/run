import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT
import lib.lftest


# The diacos plugin makes three sequential SOAP calls (login,
# searchDiagnoses, logoff). `--test` takes a base path and the plugin
# looks up `<base>-login`, `<base>-searchDiagnoses`, and `<base>-logoff`
# next to each other in stdout/.
TESTS = [
    {
        'id': 'crit-login-search-logout-over-threshold',
        'test': 'stdout/login-search-logout-7s,,0',
        'params': '--login-licence=0815 --login-name=linuxfabrik',
        'assert-retc': STATE_CRIT,
        'assert-in': ['7368ms for login, search and logout'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../diacos'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
