import importlib.machinery
import importlib.util
import os
import sys
import types

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN

# Absolute path to the plugin script (no `.py` suffix), imported as a module so
# its pure helpers can be unit-tested directly without spawning a subprocess.
PLUGIN = os.path.abspath('../snmp')


def load_plugin_module():
    """Import the plugin script as a module so its pure helpers can be called directly.
    The script carries no `.py` suffix, so the source loader has to be named explicitly.
    """
    loader = importlib.machinery.SourceFileLoader('snmp_plugin', PLUGIN)
    spec = importlib.util.spec_from_loader('snmp_plugin', loader)
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    return module

# Absolute path to a device CSV outside the bundled `device-oids` directory,
# used to exercise the `--device` absolute-path branch. The tests run from the
# `unit-test` directory, so the fixture resolves relative to the cwd.
_ABS_DEVICE = os.path.abspath('stdout/generic-appliance-over-threshold-v1')

# The snmp plugin normally queries a device via snmpget/snmpwalk. In
# test mode `--test` replaces all SNMP calls with fixture data; the
# `--device` argument still controls which device CSV is consulted
# for OID -> label mappings, so the `generic-appliance-*` scenario
# exercises the plugin against three progressively trimmed device CSVs.
