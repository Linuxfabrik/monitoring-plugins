import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_WARN

# The snmp plugin normally queries a device via snmpget/snmpwalk. In
# test mode `--test` replaces all SNMP calls with fixture data; the
# `--device` argument still controls which device CSV is consulted
# for OID -> label mappings, so the `generic-appliance-*` scenario
# exercises the plugin against three progressively trimmed device CSVs.
_BROTHER_KEYS = [
    'Name                   ! BRW38B1DB3B30F4                                   ! [OK]',
    'Location               ! Buero                                             ! [OK]',
    'Contact                ! postmaster@linuxfabrik.ch                         ! [OK]',
    'Description            ! Brother NC-350w, Firmware Ver.N  ,MID 8CA-U29-001 ! [OK]',
    'Uptime                 ! 5M 2W                                             ! [WARNING]',
    'Memory Size            ! 256.0MiB                                          ! [OK]',
    'NIC.1 Speed            ! 72.0Mbps                                          ! [OK]',
    'NIC.1 Status           ! up                                                ! [OK]',
    'NIC.1 Traffic sent     ! 84.6MiB                                           ! [OK]',
    'NIC.1 Traffic received ! 621.0MiB                                          ! [OK]',
    'NIC.1 Traffic          ! 705.5MiB                                          ! [OK]',
]

_CISCO_KEYS = [
    'Name                               ! switch.linuxfabrik.loc                                                                                                   ! [OK]',
    'Location                           ! V.01.020!XZ                                                                                                              ! [OK]',
    'Contact                            ! postmaster@linuxfabrik.ch                                                                                                ! [OK]',
    'Description                        ! Cisco IOS Software [Gibraltar], Catalyst L3 Switch Software (CAT9K_LITE_IOSXE), Version 16.12.3a, RELEASE SOFTWARE (fc1) ! [OK]',
    'Uptime                             ! 4M 3W                                                                                                                    ! [WARNING]',
    'HOST-RESOURCES-MIB::hrMemorySize.0 ! No Such Object available on this agent at this OID                                                                       ! [UNKNOWN]',
    'NIC.1 Speed                        ! 1.0Gbps                                                                                                                  ! [OK]',
    'NIC.1 Status                       ! "down"                                                                                                                   ! [OK]',
    'NIC.1 Traffic sent                 ! 1.3KiB                                                                                                                   ! [OK]',
    'NIC.1 Traffic received             ! 4.6KiB                                                                                                                   ! [OK]',
    'NIC.1 Traffic                      ! 5.9KiB                                                                                                                   ! [OK]',
]


TESTS = [
    {
        'id': 'warn-brother-printer-mfc-uptime',
        'test': 'stdout/brother-printer-mfc,,0',
        'params': '--hostname 127.0.0.1',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'Key                    ! Value                                             ! State',
            '-----------------------+---------------------------------------------------+------',
            *_BROTHER_KEYS,
        ],
    },
    {
        'id': 'warn-cisco-catalyst-switch-uptime',
        'test': 'stdout/cisco-catalyst-switch,,0',
        'params': '--hostname 127.0.0.2',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'Key                                ! Value                                                                                                                    ! State',
            '-----------------------------------+--------------------------------------------------------------------------------------------------------------------------+------',
            *_CISCO_KEYS,
        ],
    },
    {
        'id': 'crit-generic-appliance-over-threshold-device-v1',
        'test': 'stdout/generic-appliance-over-threshold,,0',
        'params': (
            '--hostname 127.0.0.3 '
            '--device=../unit-test/stdout/generic-appliance-over-threshold-v1'
        ),
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'Key                      ! Value        ! State',
            '-------------------------+--------------+----------',
            'System Name              ! My Appliance ! [OK]',
            'System Location          ! My Location  ! [OK]',
            'Supply Air Temperature   ! 27.0         ! [WARNING]',
            'Rack Inlet Temperature 1 ! 36.0         ! [CRITICAL]',
        ],
    },
    {
        'id': 'crit-generic-appliance-over-threshold-device-v2',
        'test': 'stdout/generic-appliance-over-threshold,,0',
        'params': (
            '--hostname 127.0.0.3 '
            '--device=../unit-test/stdout/generic-appliance-over-threshold-v2'
        ),
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'System Name              ! My Appliance ! [OK]',
            'Supply Air Temperature   ! 27.0         ! [WARNING]',
            'Rack Inlet Temperature 1 ! 36.0         ! [CRITICAL]',
        ],
    },
    {
        'id': 'crit-generic-appliance-over-threshold-device-v3',
        'test': 'stdout/generic-appliance-over-threshold,,0',
        'params': (
            '--hostname 127.0.0.3 '
            '--device=../unit-test/stdout/generic-appliance-over-threshold-v3'
        ),
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'System Name              ! My Appliance ! [OK]',
            'Rack Inlet Temperature 1 ! 36.0         ! [CRITICAL]',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../snmp'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
