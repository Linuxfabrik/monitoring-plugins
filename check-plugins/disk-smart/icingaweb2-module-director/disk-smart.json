    "Datafield": {
        "1": {
            "varname": "disk_smart_always_ok",
            "caption": "Disk SMART: Always OK?",
            "description": "Always returns OK.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "3bd58503-b3f5-4f76-806e-94d205426517"
        },
        "2": {
            "varname": "disk_smart_full",
            "caption": "Disk SMART: Full?",
            "description": "Also warn on assumptions (stated as \"notice\" in GSmartControl), not just on actual SMART issues.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "8304d00a-3b5e-4a14-a0d5-0dad1f7d1730"
        },
        "3": {
            "varname": "disk_smart_ignore",
            "caption": "Disk SMART: Ignore",
            "description": "Any item matching this Python regex will be ignored. Can be specified multiple times. Example: `(?i)linuxfabrik` for a case-insensitive match.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "734880fa-1d84-417e-a0aa-0c4b3d4ea4f3"
        },
        "4": {
            "varname": "disk_smart_match",
            "caption": "Disk SMART: Match",
            "description": "Filter by this Python regular expression. Case-sensitive by default; use `(?i)` for case-insensitive matching. Can be specified multiple times. Examples: `(?i)example` to match \"example\" regardless of case. `^(?!.*example).*$` to match any string except \"example\" (negative lookahead).",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "4d400846-5265-4b0b-b354-50919c54f911"
        },
        "5": {
            "varname": "disk_smart_no_match_severity",
            "caption": "Disk SMART: No Match Severity",
            "description": "State to report when no item matches the filters and nothing is checked.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeDatalist",
            "format": null,
            "settings": {
                "behavior": "strict",
                "data_type": "string",
                "datalist": "disk_smart_no_match_severity_list"
            },
            "uuid": "0c8d2109-ce7a-4579-a7a9-b78aed210101"
        },
        "6": {
            "varname": "disk_smart_no_perfdata",
            "caption": "Disk SMART: No Perfdata?",
            "description": "Suppress the performance data section from the output. The status message and the exit code are unaffected, so alerting keeps working while trending data is dropped.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "162a552b-849d-42d3-b2c0-876c8c5a6ac7"
        }
    }
