import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN
import lib.lftest


# All fixtures in this directory are captured from `smartctl --all` (or
# `smartctl -a`) on a real disk using smartctl v6 or earlier, which
# produces plain-text output (no --json mode). The prefix
# `smartctl-v6-text-` makes room for future `smartctl-v7-json-*`
# fixtures once the plugin grows JSON parsing.
#
# Each disk produces two subtests: one with the plugin's default
# behaviour (only looks at `SMART overall-health`) and one with
# `--full`, which additionally inspects per-attribute thresholds and
# may promote a PASSED disk to WARN.
_DEFAULT_PASS_REGEX = r'All are healthy\.'
_FULL_WARN_REGEX = r'There are warnings\.'
_CRIT_REGEX = r'There are critical errors\.'


def _pair(slug, default_state, full_state):
    """Build both the default and `--full` testcases for one fixture."""
    fixture = f'stdout/smartctl-v6-text-{slug},,0'
    regex_for = {
        STATE_OK: _DEFAULT_PASS_REGEX,
        STATE_WARN: _FULL_WARN_REGEX,
        STATE_CRIT: _CRIT_REGEX,
    }
    return [
        {
            'id': f'{_state_name(default_state)}-{slug}-default',
            'test': fixture,
            'assert-retc': default_state,
            'assert-regex': regex_for[default_state],
        },
        {
            'id': f'{_state_name(full_state)}-{slug}-full',
            'test': fixture,
            'params': '--full',
            'assert-retc': full_state,
            'assert-regex': regex_for[full_state],
        },
    ]


def _state_name(state):
    return {STATE_OK: 'ok', STATE_WARN: 'warn', STATE_CRIT: 'crit'}[state]


# (slug, default state, --full state) per fixture
FIXTURES = [
    ('st32000542as-health-failed', STATE_CRIT, STATE_CRIT),
    ('sk-hynix-sc311-512gb', STATE_OK, STATE_WARN),
    ('st12000vn0007-health-failed', STATE_CRIT, STATE_CRIT),
    ('wd40efrx-crit-attrs', STATE_CRIT, STATE_CRIT),
    ('hds721010cla332-warn-attrs', STATE_WARN, STATE_WARN),
    ('st12000vn0007-v1', STATE_OK, STATE_WARN),
    ('hds721010cla332-v1', STATE_OK, STATE_WARN),
    ('hds721010cla332-v2', STATE_OK, STATE_WARN),
    ('wd1003fbyz', STATE_OK, STATE_WARN),
    ('samsung-sm841-256gb', STATE_OK, STATE_OK),
    ('nvme-3l2qexf7', STATE_OK, STATE_OK),
    ('micron-mtfddak256mam', STATE_OK, STATE_OK),
    ('wd40efrx-v1', STATE_OK, STATE_OK),
    ('st12000vn0007-v2', STATE_OK, STATE_WARN),
    ('st14000ne0008-ironwolf', STATE_OK, STATE_OK),
    ('crucial-mx500-ct500', STATE_OK, STATE_OK),
    ('empty-output-v1', STATE_OK, STATE_OK),
    ('nvme-2b2qexe7', STATE_OK, STATE_OK),
    ('wd101kryz-v1', STATE_OK, STATE_WARN),
    ('wd101kryz-v2', STATE_OK, STATE_WARN),
    ('wd20earx-wdred', STATE_OK, STATE_WARN),
    ('st2000dm006-v1', STATE_OK, STATE_OK),
    ('st2000dm006-v2', STATE_OK, STATE_OK),
    ('toshiba-dt01aca100', STATE_OK, STATE_WARN),
    ('unknown-10604106', STATE_OK, STATE_OK),
    ('sandisk-ssda240g', STATE_OK, STATE_OK),
    ('empty-output-v2', STATE_OK, STATE_WARN),
    ('empty-output-v3', STATE_OK, STATE_WARN),
]


TESTS = [tc for fx in FIXTURES for tc in _pair(*fx)]


class TestCheck(unittest.TestCase):

    check = '../disk-smart'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
