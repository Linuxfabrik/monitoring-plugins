import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_WARN

# The plugin appends `-screens` to the --test path to load the
# per-player screen data, so each scenario requires two fixture
# files: `<name>` (the player list) and `<name>-screens` (the
# screens attached to that player).
TESTS = [
    {
        'id': 'warn-one-screen-off',
        'test': 'stdout/one-screen-off,,0',
        'params': '--hostname=HOSTNAME --token=TOKEN',
        'assert-retc': STATE_WARN,
        'assert-in': [
            "1 screen is off (accessed ' 8 hours ago). 1 screen checked. Filter: --box-state",
            'Box ID    ! Name                 ! Screen1 On      ! Screen2 On',
            '----------+----------------------+-----------------+-----------',
            'GP111-111 ! Grassfish Player 111 ! False [WARNING] ! None',
        ],
    },
    {
        'id': 'warn-two-screens-off',
        'test': 'stdout/two-screens-off,,0',
        'params': '--hostname=HOSTNAME --token=TOKEN',
        'assert-retc': STATE_WARN,
        'assert-in': [
            "2 screens are off (accessed ' 8 hours ago). 2 screens checked. Filter: --box-state",
            'Box ID    ! Name                 ! Screen1 On      ! Screen2 On',
            '----------+----------------------+-----------------+-------------',
            'GP112-112 ! Grassfish Player 112 ! False [WARNING] ! False [WARNING]',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../grassfish-screens'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
