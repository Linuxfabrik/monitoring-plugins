            "uuid": "e778a186-00a7-4e4e-a539-b1dc54056562"
        },
        "5": {
            "varname": "mysql_database_metrics_ignore_tables",
            "caption": "MySQL Database Metrics: Ignore Tables",
            "description": "Regular expression matched against `TABLE_NAME` (case-sensitive). Tables whose name matches are excluded from every aggregate and every per-schema check. Useful for muting noisy temporary or backup tables that legitimately differ from the schema-wide engine/collation.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
