            "varname": "mysql_database_metrics_ignore_schemas",
            "caption": "MySQL Database Metrics: Ignore Schemas",
            "description": "Regular expression matched against `SCHEMA_NAME` (case-sensitive). Schemas whose name matches are skipped entirely (no aggregate contribution, no checks). Useful for known-mixed schemas that the admin cannot or does not want to fix (common with Icinga Director / Icinga Web 2 / Icinga DB schemas, which mix utf8 / utf8mb4 collations by design). System schemas are skipped unconditionally.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
