import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-enclosures-healthy',
        'test': 'stdout/enclosures-healthy,,0',
        'params': '--device-id=1 --password=pass --url=https://localhost --username=admin',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok.',
            'UUID   ! Location ! Name   ! Model                                 '
            '! SerialNumber         ! Logic                                '
            '! MacAddress        ! Switch ! Temp ! Health ! Running',
            '-------+----------+--------+---------------------------------------'
            '+----------------------+--------------------------------------'
            '+-------------------+--------+------+--------+--------',
            '206:0  ! 0.1      ! CTE0   ! Unknown                               '
            '! 210235843910E6000009 ! Controller Enclosure                 '
            '! 30:d1:7e:b4:f7:61 ! Off    ! 30   ! [OK]   ! [OK]   ',
            '206:0  ! --       ! CTE0   ! 4 U 4-controller controller enclosure '
            '! 0815                 ! Controller Enclosure                 '
            '! f4:b7:8d:f4:fe:ff ! Off    ! 22   ! [OK]   ! [OK]',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../huawei-dorado-enclosure'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
