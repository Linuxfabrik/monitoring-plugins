import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_UNKNOWN, STATE_WARN
import lib.lftest


# strongswan-connections talks to swanctl via three sequential calls.
# `--test` takes a base path and the plugin looks up
# `<base>-possible_connection_keys`, `<base>-active_connection_keys`,
# and `<base>-list_sas` next to each other in stdout/.
TESTS = [
    {
        'id': 'unknown-no-connections-configured',
        'test': 'stdout/no-connections-configured,,0',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['No connections configured.'],
    },
    {
        'id': 'warn-no-active-connections',
        'test': 'stdout/no-active-connections,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['There are no active connections at all.'],
    },
    {
        'id': 'warn-one-inactive-connection',
        'test': 'stdout/one-inactive-connection,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['One or more connections are configured but not active [WARNING].'],
    },
    {
        'id': 'ok-all-connections-active',
        'test': 'stdout/all-connections-active,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../strongswan-connections'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
