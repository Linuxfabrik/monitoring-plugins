# Base image: Official Fedora 43
FROM fedora:43

# Install Python 3 and strongswan
RUN dnf --assumeyes install --nodocs \
        python3 python3-pip python3-devel gcc \
        strongswan && \
    dnf clean all

# Normalize charon path and VICI socket so the cross-distro test
# harness can drive every container the same way. Fedora already
# ships charon at /usr/libexec/strongswan/charon and uses
# /run/strongswan/charon.vici by default, so this only pins the
# socket explicitly. Note that Fedora's strongswan.conf includes
# /etc/strongswan/strongswan.d/*.conf, not /etc/strongswan.d/*.conf.
RUN install -d -m 0755 /run/strongswan /etc/strongswan/strongswan.d && \
    printf 'charon { plugins { vici { socket = "unix:///run/strongswan/charon.vici" } } }\n' \
        > /etc/strongswan/strongswan.d/99-lfmp-test.conf

# Set the working directory in the container
WORKDIR /tmp

# Use ADD to download the requirements.txt file
ADD https://raw.githubusercontent.com/Linuxfabrik/monitoring-plugins/refs/heads/main/lockfiles/py314/requirements.txt /tmp/requirements.txt

# Install dependencies using pip (venv to avoid PEP 668 externally-managed)
RUN python3 -m venv /tmp/venv && \
    . /tmp/venv/bin/activate && \
    python3 -m pip install --upgrade pip wheel setuptools && \
    python3 -m pip install --no-cache-dir --requirement requirements.txt --require-hashes --no-deps

# Verify Python installation
RUN python3 --version

# Default command to keep the container running
CMD ["sleep", "infinity"]
