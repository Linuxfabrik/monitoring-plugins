# Base image: Official SUSE Linux Enterprise Server 15 (BCI)
FROM registry.suse.com/bci/bci-base:15.6

# SLES 15 ships Python 3.6 as the default `python3`, which is below
# our 3.9 minimum. Install the python311 stack and alias it to
# `python3` so the test run can invoke it generically.
RUN zypper --non-interactive install \
        python311 python311-pip python311-devel gcc \
        strongswan util-linux && \
    zypper clean --all && \
    ln -sf /usr/bin/python3.11 /usr/local/bin/python3

# Normalize charon path and VICI socket so the cross-distro test
# harness can drive every container the same way: it expects
# /usr/libexec/strongswan/charon and /run/strongswan/charon.vici.
RUN install -d -m 0755 /usr/libexec/strongswan /run/strongswan && \
    ln -sf /usr/lib/ipsec/charon /usr/libexec/strongswan/charon && \
    printf 'charon { plugins { vici { socket = "unix:///run/strongswan/charon.vici" } } }\n' \
        > /etc/strongswan.d/99-lfmp-test.conf

# Set the working directory in the container
WORKDIR /tmp

# Use ADD to download the requirements.txt file
ADD https://raw.githubusercontent.com/Linuxfabrik/monitoring-plugins/refs/heads/main/lockfiles/py311/requirements.txt /tmp/requirements.txt

# Install dependencies using pip
RUN python3 -m venv /tmp/venv && \
    . /tmp/venv/bin/activate && \
    python3 -m pip install --upgrade pip wheel setuptools && \
    python3 -m pip install --no-cache-dir --requirement requirements.txt --require-hashes --no-deps

# Verify Python installation
RUN python3 --version

# Default command to keep the container running
CMD ["sleep", "infinity"]
