# Base image: Official Ubuntu 20.04 (focal)
FROM ubuntu:20.04

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive

# Ubuntu 20.04 ships Python 3.8, which is below our 3.9 minimum.
# Install python3.9 explicitly. Also install strongswan.
RUN apt-get update && \
    apt-get install -y \
        python3.9 python3.9-venv python3.9-dev python3-pip gcc \
        strongswan strongswan-swanctl charon-systemd && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Normalize charon path and VICI socket so the cross-distro test
# harness can drive every container the same way: it expects
# /usr/libexec/strongswan/charon and /run/strongswan/charon.vici.
RUN install -d -m 0755 /usr/libexec/strongswan /run/strongswan && \
    ln -sf /usr/sbin/charon-systemd /usr/libexec/strongswan/charon && \
    printf 'charon { plugins { vici { socket = "unix:///run/strongswan/charon.vici" } } }\n' \
        > /etc/strongswan.d/99-lfmp-test.conf

# Set the working directory in the container
WORKDIR /tmp

# Use ADD to download the requirements.txt file
ADD https://raw.githubusercontent.com/Linuxfabrik/monitoring-plugins/refs/heads/main/lockfiles/py39/requirements.txt /tmp/requirements.txt

# Install dependencies in a venv pinned to python3.9
RUN python3.9 -m venv /tmp/venv && \
    . /tmp/venv/bin/activate && \
    python3.9 -m pip install --upgrade pip && \
    python3.9 -m pip install --no-cache-dir --requirement requirements.txt --require-hashes --no-deps

# Verify Python installation
RUN python3.9 --version

# Default command to keep the container running
CMD ["sleep", "infinity"]
