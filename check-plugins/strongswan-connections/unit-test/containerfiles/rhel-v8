# Base image: Official RHEL 8
FROM registry.access.redhat.com/ubi8

# Install Python 3.9. The python3.9 package meta-installs pip and
# the build toolchain needed to compile pysmbclient during the pip
# install below.
RUN dnf --assumeyes install --nodocs python3.9 && \
    dnf clean all

# Install EPEL and the strongswan daemon. The VPN functionality will
# not actually work inside an unprivileged container (the kernel IPSec
# interfaces need CAP_NET_ADMIN), but the VICI control socket is
# independent of the kernel backend and opens regardless. That is
# exactly what this test verifies: the plugin can reach the socket
# and parse the daemon's reply.
RUN dnf --assumeyes install --nodocs https://dl.fedoraproject.org/pub/epel/epel-release-latest-8.noarch.rpm && \
    dnf --assumeyes install --nodocs strongswan && \
    dnf clean all

# Install the plugin's Python dependencies (including vici).
WORKDIR /tmp
ADD https://raw.githubusercontent.com/Linuxfabrik/monitoring-plugins/refs/heads/main/requirements.txt /tmp/requirements.txt
RUN python3.9 -m pip install --upgrade pip && \
    python3.9 -m pip install --no-cache-dir --requirement requirements.txt --require-hashes --no-deps

# Default command to keep the container running. The test harness
# starts charon on demand via `container.exec()` once the container
# is up.
CMD ["sleep", "infinity"]
