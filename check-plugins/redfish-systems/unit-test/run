import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_UNKNOWN, STATE_WARN

# The plugin appends `-systems` (collection) and `-system` (member)
# to the --test path as it walks the Redfish API, so each scenario
# requires two fixture files: `<name>-systems` and `<name>-system`.
COMMON = '--url=https://example.com'

TESTS = [
    {
        'id': 'ok-healthy-server',
        'test': 'stdout/healthy-server,,0',
        'params': COMMON,
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok, checked system health on 1 member.'],
    },
    {
        'id': 'warn-inlet-temp-threshold',
        'test': 'stdout/inlet-temp-threshold,,0',
        'params': COMMON,
        'assert-retc': STATE_WARN,
        'assert-in': ['[WARNING]'],
    },
    {
        'id': 'crit-hardware-fault',
        'test': 'stdout/hardware-fault,,0',
        'params': COMMON,
        'assert-retc': STATE_CRIT,
        'assert-in': ['[CRITICAL]'],
    },
    {
        # --inventory emits the parsed components as JSON (one object keyed by
        # component type) and exits OK, so several Redfish checks can be merged
        # with `jq --slurp`.
        'id': 'ok-inventory-json',
        'test': 'stdout/healthy-server,,0',
        'params': f'{COMMON} --inventory',
        'assert-retc': STATE_OK,
        'assert-in': ['"system":', '"BiosVersion":'],
    },
    {
        # A missing fixture must surface as STATE_UNKNOWN with a
        # readable message, not as a Python traceback.
        'id': 'unknown-missing-fixture',
        'test': 'stdout/does-not-exist,,0',
        'params': COMMON,
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Test fixture not found'],
    },
]


class TestCheck(unittest.TestCase):
    check = '../redfish-systems'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
