"""See the check's README for more details."""

import argparse
import sys

import lib.args
import lib.base
import lib.db_mysql
import lib.human
from lib.globals import STATE_CRIT, STATE_OK, STATE_UNKNOWN, STATE_WARN

__author__ = 'Linuxfabrik GmbH, Zurich/Switzerland'
__version__ = '2026051001'

DESCRIPTION = """Reports MySQL/MariaDB's current open-files count as a percentage of
`open_files_limit` (the per-process file-descriptor ceiling MySQL was started with;
`Open_files` is a server-wide status counter, not a per-connection metric). Alerts
when the ratio crosses `--warning` / `--critical`."""

DEFAULT_DEFAULTS_FILE = '/var/spool/icinga2/.my.cnf'
DEFAULT_DEFAULTS_GROUP = 'client'
DEFAULT_TIMEOUT = 3
# Default thresholds match mysqltuner v2.8.41's single 85% cutoff. We also
# expose a higher --critical so admins can keep WARN for early notice and let
# the alert escalate when the ratio really runs hot.
DEFAULT_WARN = 85
DEFAULT_CRIT = 95


def parse_args():
    """Parse command line arguments using argparse."""
    parser = argparse.ArgumentParser(description=DESCRIPTION)

    parser.add_argument(
        '-V',
        '--version',
        action='version',
        version=f'%(prog)s: v{__version__} by {__author__}',
    )

    parser.add_argument(
        '--always-ok',
        help=lib.args.help('--always-ok'),
        dest='ALWAYS_OK',
        action='store_true',
        default=False,
    )

    parser.add_argument(
        '-c',
        '--critical',
        help='Percentage of `open_files_limit` at which the open-files ratio'
        ' flips to CRITICAL. '
        'Default: %(default)s',
        dest='CRITICAL',
        type=int,
        default=DEFAULT_CRIT,
    )

    parser.add_argument(
        '--defaults-file',
        help='MySQL/MariaDB cnf file to read user, host and password from. '
        'Example: `--defaults-file=/var/spool/icinga2/.my.cnf`. '
        'Default: %(default)s',
        dest='DEFAULTS_FILE',
        default=DEFAULT_DEFAULTS_FILE,
    )

    parser.add_argument(
        '--defaults-group',
        help=lib.args.help('--defaults-group') + ' Default: %(default)s',
        dest='DEFAULTS_GROUP',
        default=DEFAULT_DEFAULTS_GROUP,
    )

    parser.add_argument(
        '--timeout',
        help=lib.args.help('--timeout') + ' Default: %(default)s (seconds)',
        dest='TIMEOUT',
        type=int,
        default=DEFAULT_TIMEOUT,
    )

    parser.add_argument(
        '-w',
        '--warning',
        help='Percentage of `open_files_limit` at which the open-files ratio'
        ' flips to WARNING. '
        'Default: %(default)s',
        dest='WARNING',
        type=int,
        default=DEFAULT_WARN,
    )

    args, _ = parser.parse_known_args()
    return args


def get_vars(conn):
    # Do not implement `get_all_vars()`, just fetch the ones we need for this check.
    # Without the GLOBAL modifier, SHOW VARIABLES displays the values that are used for
    # the current connection to MariaDB.
    sql = """
        show global variables
        where variable_name like 'open_files_limit'
            ;
          """
    return lib.base.coe(lib.db_mysql.select(conn, sql))


def get_status(conn):
    # Do not implement `get_all_vars()`, just fetch the ones we need for this check.
    # Without the GLOBAL modifier, SHOW STATUS displays the values that are used for
    # the current connection to MariaDB.
    sql = """
        show global status
        where variable_name like 'Open_files'
            ;
          """
    return lib.base.coe(lib.db_mysql.select(conn, sql))


def main():
    """The main function. This is where the magic happens."""

    # logic taken from mysqltuner.pl:mysql_stats(), section # Open files, v1.9.8
    # including variable names

    # parse the command line
    try:
        args = parse_args()
    except SystemExit:
        sys.exit(STATE_UNKNOWN)

    # fetch data
    mysql_connection = {
        'defaults_file': args.DEFAULTS_FILE,
        'defaults_group': args.DEFAULTS_GROUP,
        'timeout': args.TIMEOUT,
    }
    conn = lib.base.coe(lib.db_mysql.connect(mysql_connection))
    lib.base.coe(lib.db_mysql.check_privileges(conn))

    myvar = lib.db_mysql.lod2dict(get_vars(conn))
    mystat = lib.db_mysql.lod2dict(get_status(conn))
    lib.db_mysql.close(conn)

    # init some vars
    state = STATE_OK
    sections = []
    # All recommendations from all WARN/CRIT paths land here and render once at
    # the end as a `Recommendations:\n* ...` bulleted block, regardless of
    # which WARN paths fire.
    recommendations = []

    # analyze data
    open_files = int(mystat['Open_files'])
    open_files_limit = int(myvar['open_files_limit'])
    if open_files_limit > 0:
        pct_files_open = round(open_files / open_files_limit * 100, 1)
    else:
        # open_files_limit = 0 means "no limit configured" on this server;
        # a percentage is meaningless then, so we report 0% and skip the alert.
        pct_files_open = 0.0

    if pct_files_open >= args.CRITICAL:
        state = STATE_CRIT
    elif pct_files_open >= args.WARNING:
        state = STATE_WARN
    if state != STATE_OK:
        recommendations.append(
            f'Raise `open_files_limit` (currently'
            f' {lib.human.number2human(open_files_limit)})'
        )

    # build the message
    sections.append(
        f'{pct_files_open}% of `open_files_limit` used'
        f' ({lib.human.number2human(open_files)}'
        f'/{lib.human.number2human(open_files_limit)})'
        f'{lib.base.state2str(state, prefix=" ")}.'
    )

    if recommendations:
        sections.append(
            'Recommendations:\n' + '\n'.join(f'* {r}' for r in recommendations)
        )

    msg = '\n\n'.join(sections)

    perfdata = ''
    perfdata += lib.base.get_perfdata(
        'mysql_open_files',
        open_files,
        _min=0,
    )
    perfdata += lib.base.get_perfdata(
        'mysql_open_files_limit',
        open_files_limit,
        _min=0,
    )
    perfdata += lib.base.get_perfdata(
        'mysql_pct_files_open',
        pct_files_open,
        uom='%',
        warn=args.WARNING,
        crit=args.CRITICAL,
        _min=0,
        _max=100,
    )

    # over and out
    lib.base.oao(msg, state, perfdata, always_ok=args.ALWAYS_OK)


if __name__ == '__main__':
    try:
        main()
    except Exception:
        lib.base.cu()
