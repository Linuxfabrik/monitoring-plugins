"""Unit tests for the openjdk-redhat-version check plugin.

The fixtures in `stderr/` are the raw `java -version` outputs
captured from the official Red Hat UBI8 OpenJDK images
(`registry.access.redhat.com/ubi8/openjdk-{8,11,17,21}`). Java
writes the version banner to STDERR (yes, really), so the
fixtures live under `stderr/` and the plugin's --test argument
is invoked as `,stderr/<file>,0`. The plugin runs its
`r'\\"(.*)\\"'` regex against the stderr payload.

Each testcase pins the expected Nagios state to whatever
`lib.version.check_eol()` returned when these fixtures were saved
against the live https://endoflife.date/api/redhat-build-of-openjdk.json
data. Note that OpenJDK 8 reports as `1.8.0_482`, which the
plugin transforms to `1.8.0.482` and `lib.version.check_eol()`
cannot map to the upstream `8` cycle - the plugin therefore
returns STATE_UNKNOWN with `version 1.8.0.482 unknown`. That is
the live behaviour we pin here. The EOL table drifts over time
(releases hit EOL, new majors appear), so the `assert-retc` and
`assert-in` strings will need to be re-pinned every few months.
"""

import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_UNKNOWN, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'unknown-openjdk-8',
        'test': ',stderr/java-version-openjdk-8,0',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Java (Red Hat build of OpenJDK) v1.8.0.482', 'unknown'],
    },
    {
        'id': 'warn-openjdk-11-eol',
        'test': ',stderr/java-version-openjdk-11,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'Java (Red Hat build of OpenJDK) v11.0.25',
            'EOL 2024-10-31',
            '[WARNING]',
        ],
    },
    {
        'id': 'ok-openjdk-17',
        'test': ',stderr/java-version-openjdk-17,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Java (Red Hat build of OpenJDK) v17.0.18',
            'EOL 2027-12-31',
        ],
    },
    {
        'id': 'ok-openjdk-21',
        'test': ',stderr/java-version-openjdk-21,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Java (Red Hat build of OpenJDK) v21.0.10',
            'EOL 2029-12-31',
        ],
    },
    {
        'id': 'unknown-garbage-output',
        'test': 'stdout/garbage-output,,0',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Java', 'not found.'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../openjdk-redhat-version'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
