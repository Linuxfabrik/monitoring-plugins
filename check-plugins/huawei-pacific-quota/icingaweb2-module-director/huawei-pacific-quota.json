            "max_check_attempts": 5,
            "notes": "Checks how full the quotas of a Huawei OceanStor Pacific storage system are via the REST API (/file_service/fs_quota endpoint). Walks all file systems and their dtrees and reports the used space of every quota relative to its configured hard quota. Quotas without a hard quota are skipped, because there is no limit to compare against. Alerts when the used space in percent reaches the warning or critical threshold. Supports extended reporting via --lengthy.",
            "notes_url": "https://linuxfabrik.github.io/monitoring-plugins/check-plugins/huawei-pacific-quota/",
            "object_name": "tpl-service-huawei-pacific-quota",
            "object_type": "template",
            "retry_interval": 30,
            "service_set": null,
            "template_choice": null,
            "use_agent": false,
            "use_var_overrides": null,
