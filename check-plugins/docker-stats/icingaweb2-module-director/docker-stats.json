        },
        "5": {
            "varname": "docker_stats_full_name",
            "caption": "Docker Stats: Full Name?",
            "description": "Use the full container name, for example `traefik_traefik.2.1idw12p2yqp`. Without this flag, the name is shortened after the replica number.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "4b20fa55-d44a-4bef-8698-b1816882ec2a"
        },
        "6": {
            "varname": "docker_stats_ignore",
            "caption": "Docker Stats: Ignore",
            "description": "Ignore containers whose name matches this Python regular expression. Matched against the full container name, even when the displayed name is shortened (see --full-name). Case-sensitive by default; use `(?i)` for case-insensitive matching. Can be specified multiple times. Example: `--ignore=\"^k8s_\"` to skip Kubernetes pod infrastructure containers. Example: `--ignore=\"(?i)test\"` (case-insensitive) to skip any container with \"test\" in its name.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "afcaf8bb-4c25-46f4-9f68-38c3ea098bb5"
        },
        "7": {
            "varname": "docker_stats_match",
            "caption": "Docker Stats: Match",
            "description": "Only check containers whose name matches this Python regular expression. Matched against the full container name, even when the displayed name is shortened (see --full-name). Case-sensitive by default; use `(?i)` for case-insensitive matching. Can be specified multiple times. If both `--match` and `--ignore` are given, a container must match `--match` AND not match `--ignore` to be checked (include first, exclude second). Example: `--match=\"^traefik$\"` to pin the check to one specific container. Example: `--match=\"(?i)^web\"` (case-insensitive) to check every web container.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "a62c3831-6479-4c57-a800-e75fa914bf39"
        },
        "8": {
            "varname": "docker_stats_no_match_severity",
            "caption": "Docker Stats: No Match Severity",
            "description": "State to report when no item matches the filters and nothing is checked.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeDatalist",
            "format": null,
            "settings": {
                "behavior": "strict",
                "data_type": "string",
                "datalist": "docker_stats_no_match_severity_list"
            },
            "uuid": "04542725-0f9a-4e5e-81d6-b5065a51a3fb"
        },
