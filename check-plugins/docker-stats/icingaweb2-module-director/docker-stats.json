            "max_check_attempts": 5,
            "notes": "Reports CPU and memory usage for all running Docker containers. CPU usage is normalized by dividing by the number of available host CPU cores. CPU alerts only trigger after the threshold has been exceeded for a configurable number of consecutive check runs (default: 5), suppressing short spikes. Memory alerts trigger immediately. Uses a local SQLite database for CPU trend tracking across runs. For Podman, use the podman-stats check instead. Requires root or sudo.",
            "notes_url": "https://linuxfabrik.github.io/monitoring-plugins/check-plugins/docker-stats/",
            "object_name": "tpl-service-docker-stats",
