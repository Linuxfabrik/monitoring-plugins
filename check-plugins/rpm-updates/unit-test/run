import sys
sys.path.append('..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


# The rpm-updates plugin makes three separate yum calls (`list --upgrades`,
# `list --installed`, `updateinfo list --available`). `--test` takes a
# base fixture path and looks for `<base>-upgrades`, `<base>-installed`,
# and `<base>-updateinfo` next to each other in `stdout/`.
#
# The `containerfiles/` directory next door still holds the legacy podman
# orchestration for a cross-OS smoke sweep. Those will be migrated to
# testcontainers-python in a separate commit - see
# https://github.com/Linuxfabrik/monitoring-plugins/issues/1072
TESTS = [
    {
        'id': 'ok-no-updates',
        'test': 'stdout/no-updates,,0',
        'params': '',
        'assert-retc': STATE_OK,
        'assert-in': ['No updates available'],
    },
    {
        'id': 'warn-one-pending-upgrade',
        'test': 'stdout/one-pending-upgrade,,0',
        'params': '',
        'assert-retc': STATE_WARN,
        'assert-in': ['1 update available', 'vim-minimal'],
    },
    {
        'id': 'ok-one-pending-upgrade-with-high-warn',
        'test': 'stdout/one-pending-upgrade,,0',
        'params': '--warning 5',
        'assert-retc': STATE_OK,
        'assert-in': ['1 update available'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../rpm-updates'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
