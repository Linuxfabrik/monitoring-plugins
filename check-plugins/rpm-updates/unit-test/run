import sys
sys.path.append('..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


# The rpm-updates plugin makes three separate yum/dnf calls
# (`list --upgrades`, `list --installed`, `updateinfo list --available`).
# `--test` takes a base fixture path and looks for `<base>-upgrades`,
# `<base>-installed`, and `<base>-updateinfo` next to each other in
# `stdout/`.
#
# The TESTS below cover every RPM-family distro we support. The
# fixtures were captured on real podman containers with
# `dnf list --upgrades`, `dnf list --installed`, and
# `dnf updateinfo list --available` at a single point in time, so the
# assertions only check the parser's behaviour (does the plugin cope
# with this distro's header layout, column widths, and repo names) -
# they do NOT validate that a specific package is or is not listed.
#
# Whether a given fixture shows upgrades or not depends on when the
# captures were taken. As of capture time, Fedora 40 and UBI 10 were
# fully up to date (STATE_OK), every other distro had at least one
# pending upgrade (STATE_WARN).
TESTS = [
    # Fedora
    {
        'id': 'warn-fedora30',
        'test': 'stdout/fedora30,,0',
        'params': '',
        'assert-retc': STATE_WARN,
        'assert-in': ['update', 'available'],
    },
    {
        'id': 'warn-fedora35',
        'test': 'stdout/fedora35,,0',
        'params': '',
        'assert-retc': STATE_WARN,
        'assert-in': ['update', 'available'],
    },
    {
        'id': 'ok-fedora40',
        'test': 'stdout/fedora40,,0',
        'params': '',
        'assert-retc': STATE_OK,
        'assert-in': ['No updates available'],
    },
    {
        'id': 'warn-fedora41',
        'test': 'stdout/fedora41,,0',
        'params': '',
        'assert-retc': STATE_WARN,
        'assert-in': ['update', 'available'],
    },
    {
        'id': 'warn-fedora42',
        'test': 'stdout/fedora42,,0',
        'params': '',
        'assert-retc': STATE_WARN,
        'assert-in': ['update', 'available'],
    },
    {
        'id': 'warn-fedora43',
        'test': 'stdout/fedora43,,0',
        'params': '',
        'assert-retc': STATE_WARN,
        'assert-in': ['update', 'available'],
    },
    # Red Hat Universal Base Image
    {
        'id': 'warn-rhel8',
        'test': 'stdout/rhel8,,0',
        'params': '',
        'assert-retc': STATE_WARN,
        'assert-in': ['update', 'available'],
    },
    {
        'id': 'warn-rhel9',
        'test': 'stdout/rhel9,,0',
        'params': '',
        'assert-retc': STATE_WARN,
        'assert-in': ['update', 'available'],
    },
    {
        'id': 'ok-rhel10',
        'test': 'stdout/rhel10,,0',
        'params': '',
        'assert-retc': STATE_OK,
        'assert-in': ['No updates available'],
    },
    # High --warning threshold keeps the plugin at STATE_OK even with
    # pending upgrades (sanity-check the state logic on a distro with
    # many pending upgrades).
    {
        'id': 'ok-rhel8-with-high-warn',
        'test': 'stdout/rhel8,,0',
        'params': '--warning 99999',
        'assert-retc': STATE_OK,
    },
]


class TestCheck(unittest.TestCase):

    check = '../rpm-updates'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
