import sys
sys.path.append('..')

import unittest

from lib.globals import STATE_OK, STATE_UNKNOWN, STATE_WARN
import lib.lftest


# needs-restarting has OS-family-specific branches. The tests use
# `--test-os-family` (a hidden test hook) to force the detection and
# `--test` to inject the relevant shell-command fixtures for each
# code path:
#   RedHat: needs-restarting --reboothint   -> <base>-reboothint
#           needs-restarting                -> <base>-services
#   Debian: needrestart -b                  -> <base>-needrestart
#
# The `containerfiles/` directory next door still holds the legacy
# per-distro podman setup for future cross-OS smoke coverage and can
# be migrated to testcontainers-python later if desired.
TESTS = [
    {
        'id': 'ok-rhel-clean',
        'test': 'stdout/rhel-clean,,0',
        'params': '--test-os-family=RedHat',
        'assert-retc': STATE_OK,
        'assert-in': ['No system or service restart needed'],
    },
    {
        'id': 'warn-rhel-reboot-required',
        'test': 'stdout/rhel-reboot-required,,1',
        'params': '--test-os-family=RedHat',
        'assert-retc': STATE_WARN,
        'assert-in': ['A system reboot may be required'],
    },
    {
        'id': 'warn-rhel-services-restart-needed',
        'test': 'stdout/rhel-services,,0',
        'params': '--test-os-family=RedHat',
        'assert-retc': STATE_WARN,
        'assert-in': ['sshd', 'may need a restart'],
    },
    {
        'id': 'ok-debian-clean',
        'test': 'stdout/debian-clean,,0',
        'params': '--test-os-family=Debian',
        'assert-retc': STATE_OK,
        'assert-in': ['No system or service restart needed'],
    },
    {
        'id': 'warn-debian-kernel-and-services-pending',
        'test': 'stdout/debian-kernel-pending,,0',
        'params': '--test-os-family=Debian',
        'assert-retc': STATE_WARN,
        'assert-in': ['sshd.service', 'Version upgrade pending'],
    },
    {
        'id': 'unknown-os-not-supported',
        'test': 'stdout/rhel-clean,,0',
        'params': '--test-os-family=Arch',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['OS not supported'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../needs-restarting'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
