import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_UNKNOWN

# The plugin appends `-systems` (Systems collection), `-system` (member),
# `-processors` (Processors collection), and `-cpu-N` (each processor, indexed)
# to the --test path as it walks the Redfish API. Each scenario therefore
# requires the matching fixture files.
TESTS = [
    {
        'id': 'ok-healthy-processors',
        'test': 'stdout/healthy-processors,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok, checked processors on 1 member.',
        ],
        'assert-not-in': ['[WARNING]', '[CRITICAL]'],
    },
    {
        # A single processor reports Health=Critical while the rest are OK.
        # redfish-processors must escalate to CRITICAL.
        'id': 'crit-one-cpu-fault',
        'test': 'stdout/one-cpu-fault,,0',
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'There are critical errors.',
            '[CRITICAL]',
        ],
    },
    {
        # --match keeps only the two CPUs named "Processor" (one of them the
        # faulty one), excluding the healthy FPGA, so the check stays CRITICAL.
        'id': 'crit-match-processor',
        'test': 'stdout/one-cpu-fault,,0',
        'params': "--match='Processor'",
        'assert-retc': STATE_CRIT,
        'assert-in': ['[CRITICAL]'],
        'assert-not-in': ['FPGA'],
    },
    {
        # --ignore drops both "Processor" CPUs (including the faulty one),
        # leaving only the healthy FPGA, so the check is OK.
        'id': 'ok-ignore-processor',
        'test': 'stdout/one-cpu-fault,,0',
        'params': "--ignore='Processor'",
        'assert-retc': STATE_OK,
        'assert-in': ['FPGA'],
        'assert-not-in': ['[CRITICAL]'],
    },
    {
        # --inventory emits the parsed components as JSON (one object keyed by
        # component type) and exits OK, so several Redfish checks can be merged
        # with `jq --slurp`.
        'id': 'ok-inventory-json',
        'test': 'stdout/healthy-processors,,0',
        'params': '--inventory',
        'assert-retc': STATE_OK,
        'assert-in': ['"processor":', '"system_ids":'],
    },
    {
        # A missing fixture must surface as STATE_UNKNOWN with a
        # readable message, not as a Python traceback.
        'id': 'unknown-missing-fixture',
        'test': 'stdout/does-not-exist,,0',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Test fixture not found'],
    },
]


class TestCheck(unittest.TestCase):
    check = '../redfish-processors'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
