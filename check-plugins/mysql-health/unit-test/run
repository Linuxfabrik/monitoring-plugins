"""Integration tests for the mysql-health check plugin.

The plugin opens a real `pymysql` connection and walks `SHOW GLOBAL STATUS`,
`SHOW GLOBAL VARIABLES`, `SHOW REPLICA STATUS`, `information_schema.tables`
and `mysql.user`, so a static fixture cannot drive it - we spin up an actual
MariaDB server and let the plugin talk to it over TCP.

Per CONTRIBUTING's "Combine container tests with fixtures" rule, this file
holds only the happy-path integration test. A freshly booted MariaDB has
no anonymous accounts, no empty-password users, no wildcard hosts beyond the
default `root@%` (which the seed removes), no InnoDB tables without a
PRIMARY KEY and no replication lag, so the score lands near 100 and the
plugin returns STATE_OK.

The test matrix is defined by the Containerfiles under
`containerfiles/`. Each file is a Containerfile (typically a
one-line `FROM`) and gets built once via testcontainers'
DockerImage (cached across runs). Add a new MariaDB LTS by
dropping in a new Containerfile; retire one by deleting the file.

Requirements:
- podman (or docker) with a reachable socket
- `pip install testcontainers`
- `tools/run-unit-tests` auto-sets `CONTAINER_HOST` and
  `TESTCONTAINERS_RYUK_DISABLED`
"""

import os
import subprocess
import sys
import unittest

sys.path.insert(0, '..')

import lib.lftest
from lib.globals import STATE_OK, STATE_WARN

HERE = os.path.dirname(os.path.abspath(__file__))
CONTAINERFILES_DIR = os.path.join(HERE, 'containerfiles')
CONTAINERFILES = sorted(
    name for name in os.listdir(CONTAINERFILES_DIR)
    if os.path.isfile(os.path.join(CONTAINERFILES_DIR, name))
)


class TestCheck(unittest.TestCase):
    pass


def _check_image(test, containerfile):
    path = os.path.join(CONTAINERFILES_DIR, containerfile)
    print(f'\n=== Testing {containerfile} ===', flush=True)
    with lib.lftest.run_mysql_compatible_from_containerfile(path) as (container, defaults_file):
        # mysql-health reads `mysql.user` (security findings) and
        # `information_schema.tables` (metadata health). The default
        # `test` user gets only the `test` database; grant `SELECT
        # ON mysql.*` so the plugin can do its job. Mirrors the
        # mysql-user-security unit test.
        container.exec([
            'sh', '-c',
            'if command -v mariadb >/dev/null 2>&1; then C=mariadb; '
            'else C=mysql; fi; '
            'GRANT_SQL="GRANT SELECT ON mysql.* TO '
            "'test'@'%'"
            '"; '
            '"$C" -uroot -e "$GRANT_SQL" 2>/dev/null '
            '|| "$C" -uroot -ptest -e "$GRANT_SQL"',
        ])

        cmd = [
            'python3', '../mysql-health',
            f'--defaults-file={defaults_file}',
        ]
        print(f'Run plugin: {" ".join(cmd)}', flush=True)
        result = subprocess.run(
            cmd,
            cwd=os.path.dirname(os.path.abspath(__file__)),
            capture_output=True,
            text=True,
        )
        combined = result.stdout + result.stderr
        print(f'Script output:\n{combined.strip()}', flush=True)

        # MariaDB defaults ship with `root@%` and no TLS configuration,
        # so the Security component loses points and the score lands
        # in the 70-80 band -> STATE_WARN. MySQL upstream is hardened
        # by default (auto-generated self-signed cert, no wildcard
        # root) and scores higher, landing right at or above the
        # default `70:` warn threshold -> STATE_OK. Accept either
        # state, but pin the perfdata so a regression that suppresses
        # the score entirely would still trip the test.
        test.assertIn(result.returncode, (STATE_OK, STATE_WARN))
        test.assertRegex(combined, r'Health Score: \d+/100')


lib.lftest.attach_each(TestCheck, CONTAINERFILES, _check_image)


if __name__ == '__main__':
    unittest.main()
