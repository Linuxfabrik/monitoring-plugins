# Base image: Official RHEL 10
FROM registry.access.redhat.com/ubi10

# Install Python, w (procps-ng), and OpenSSH server + client.
RUN dnf --assumeyes install --nodocs \
        python python-pip python-devel gcc \
        procps-ng openssh-server openssh-clients shadow-utils && \
    dnf clean all

# Generate host keys, prepare the privsep dir, create a test user with a
# pre-baked passwordless ssh-to-localhost setup. The runtime test then
# only has to start sshd and open one ssh session as testuser.
RUN ssh-keygen -A && \
    install -d -m 0755 /run/sshd && \
    install -d -m 0711 /var/empty/sshd && \
    install --mode=0664 --group=utmp /dev/null /var/run/utmp && \
    install --mode=0664 --group=utmp /dev/null /var/log/wtmp && \
    useradd --create-home --user-group --shell /bin/bash testuser && \
    echo "testuser:linuxfabrik" | chpasswd && \
    install -d -m 0700 -o testuser -g testuser /home/testuser/.ssh && \
    ssh-keygen -t ed25519 -f /home/testuser/.ssh/id_ed25519 -N '' && \
    chown testuser:testuser /home/testuser/.ssh/id_ed25519 /home/testuser/.ssh/id_ed25519.pub && \
    cp /home/testuser/.ssh/id_ed25519.pub /home/testuser/.ssh/authorized_keys && \
    chown testuser:testuser /home/testuser/.ssh/authorized_keys && \
    chmod 600 /home/testuser/.ssh/authorized_keys && \
    install -d -m 0755 /etc/ssh/sshd_config.d && \
    printf 'UsePAM no\nPrintLastLog no\nPrintMotd no\n' > /etc/ssh/sshd_config.d/00-lfmp-test.conf

# Set the working directory in the container
WORKDIR /tmp

# Use ADD to download the requirements.txt file
ADD https://raw.githubusercontent.com/Linuxfabrik/monitoring-plugins/refs/heads/main/requirements.txt /tmp/requirements.txt

# Install dependencies using pip
RUN dnf --assumeyes remove python3-requests
RUN python -m pip install --upgrade pip && \
    python -m pip install --no-cache-dir --requirement requirements.txt --require-hashes --no-deps

# Verify Python installation
RUN python --version

# Default command to keep the container running
CMD ["sleep", "infinity"]
