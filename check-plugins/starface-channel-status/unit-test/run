import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-3-of-4-channels-in-use',
        'test': 'stdout/3-of-4-channels-in-use,,',
        'assert-retc': STATE_OK,
        'assert-in': ['75.0% call usage (3/4). Current channels: 2x DAHDI, 1x SIP'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../starface-channel-status'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
