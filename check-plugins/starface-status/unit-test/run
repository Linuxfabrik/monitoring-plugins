import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_OK

TESTS = [
    {
        'id': 'ok-starface-healthy',
        'test': 'stdout/starface-healthy,,',
        'assert-retc': STATE_OK,
        'assert-in': [
            'STARFACE Free, v6.7.3.20, RAID Status: HEALTHY, 12 blacklisted hosts, '
            'SIP Status: OK, 99 phones online\n'
            'Owner: Example Inc., 99 licensed users, 156 whitelisted hosts, '
            '167 phones known, 5 phones changed IP, '
            'Up 6 weeks, 2 days, 19 hours, 42 minutes, 30 seconds',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../starface-status'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
