import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'ok-licenses-available',
        'test': 'stdout/licenses-available,,0',
        'params': '--hostname=HOSTNAME --token=TOKEN',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok.',
            'License Type     ! Usage',
            '-----------------+-------------------',
            'Player           ! 9/10 (1 available)',
        ],
    },
    {
        'id': 'warn-no-licenses-available',
        'test': 'stdout/no-licenses-available,,0',
        'params': '--hostname=HOSTNAME --token=TOKEN',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'No more licenses available: DsPlayerEntry, EntryPlayer',
            'License Type     ! Usage',
            '-----------------+---------------------------',
            'DsPlayerEntry    ! 1400/1400 (0 available [WARNING])',
            'EntryPlayer      ! 100/100 (0 available [WARNING])',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../grassfish-licenses'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
