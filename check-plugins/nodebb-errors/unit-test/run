import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-errors-one-404',
        'test': 'stdout/errors-one-404,,0',
        'params': '--token=253ff1ec-a5b8-4248-be1d-b898d298d8fc',
        'assert-retc': STATE_OK,
        'assert-in': ['HTTP Status today: 0x 503 too busy, 1x 404 not found'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../nodebb-errors'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
