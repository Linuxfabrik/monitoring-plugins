import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-cache-nominal',
        'test': 'stdout/cache-nominal,,0',
        'params': '--token=253ff1ec-a5b8-4248-be1d-b898d298d8fc',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok.',
            'Cache       ! Enabled ! Usage  ! Size          ! Hits   ! Misses ! HitRatio',
            'postCache   ! True    ! 0.68%  ! 71.4K / 10.5M ! 6.7K   ! 214.0  ! 96.9%',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../nodebb-cache'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
