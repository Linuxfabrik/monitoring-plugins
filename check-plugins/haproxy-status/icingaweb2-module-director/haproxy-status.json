            "varname": "haproxy_status_ignore",
            "caption": "HAProxy Status: Ignore",
            "description": "Ignore proxies, frontends, backends or servers matching this Python regular expression on the combined `<proxy>/<svname>` identifier (where `svname` is `FRONTEND`, `BACKEND` or an individual server name). Case-sensitive by default; use `(?i)` for case-insensitive matching. Can be specified multiple times. Example: `--ignore=\"^certbot/\"` to ignore everything under the certbot proxy. Example: `--ignore=\"(?i)^certbot/\"` for a case-insensitive match.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
