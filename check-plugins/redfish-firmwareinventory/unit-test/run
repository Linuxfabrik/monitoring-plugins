import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_UNKNOWN

# The plugin appends `-firmwareinventory` (FirmwareInventory collection) and
# `-firmware-N` (each firmware component, indexed) to the --test path as it
# walks the Redfish API. Each scenario therefore requires the matching fixture
# files.
TESTS = [
    {
        'id': 'ok-healthy-firmwareinventory',
        'test': 'stdout/healthy-firmwareinventory,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok, checked 3 firmware components.',
        ],
        'assert-not-in': ['[WARNING]', '[CRITICAL]'],
    },
    {
        # A single firmware component reports Health=Critical while the rest
        # are OK. redfish-firmwareinventory must escalate to CRITICAL.
        'id': 'crit-one-firmware-fault',
        'test': 'stdout/one-firmware-fault,,0',
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'There are critical errors.',
            '[CRITICAL]',
        ],
    },
    {
        # --inventory emits the parsed components as JSON (one object keyed by
        # component type) and exits OK, so several Redfish checks can be merged
        # with `jq --slurp`.
        'id': 'ok-inventory-json',
        'test': 'stdout/healthy-firmwareinventory,,0',
        'params': '--inventory',
        'assert-retc': STATE_OK,
        'assert-in': ['"firmware":', '"Version":'],
    },
    {
        # A missing fixture must surface as STATE_UNKNOWN with a
        # readable message, not as a Python traceback.
        'id': 'unknown-missing-fixture',
        'test': 'stdout/does-not-exist,,0',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Test fixture not found'],
    },
]


class TestCheck(unittest.TestCase):
    check = '../redfish-firmwareinventory'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
