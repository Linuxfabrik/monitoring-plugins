            "imports": [
                "tpl-service-generic"
            ],
            "max_check_attempts": 5,
            "notes": "Monitors IPv4 DHCP scope usage on a Windows DHCP server. Connects via WinRM and queries scope statistics using PowerShell. On servers with thousands of scopes, --brief hides rows within the thresholds so the output only lists scopes in WARN/CRIT state. Alerts when the address pool usage of any scope exceeds the configured thresholds (default: WARN at 80%, CRIT at 90%).",
            "notes_url": "https://linuxfabrik.github.io/monitoring-plugins/check-plugins/dhcp-scope-usage/",
            "object_name": "tpl-service-dhcp-scope-usage",
            "object_type": "template",
            "retry_interval": 180,
            "service_set": null,
            "template_choice": null,
            "use_agent": false,
            "use_var_overrides": null,
            "vars": {
                "criticality": "C",
                "dhcp_scope_usage_always_ok": false,
                "dhcp_scope_usage_brief": false,
                "dhcp_scope_usage_critical": 90,
                "dhcp_scope_usage_hostname": "localhost",
                "dhcp_scope_usage_warning": 80,
                "dhcp_scope_usage_winrm_transport": "ntlm",
                "dhcp_scope_usage_winrm_username": "Administrator"
            },
            "volatile": null,
            "zone": null,
            "uuid": "6fec782f-87b1-4925-a1b6-10cf7a396b26"
        },
