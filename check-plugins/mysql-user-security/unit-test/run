# https://github.com/Linuxfabrik/monitoring-plugins/blob/main/CONTRIBUTING.md

"""Integration tests for the mysql-user-security check plugin.

The plugin opens a real `pymysql` connection and queries
`mysql.user` / `mysql.global_priv` for anonymous accounts,
passwordless accounts and hosts granted wildcard access. Reading
the `mysql` system database requires elevated privileges, so the
test grants the regular `test` user SELECT on `mysql.*` via
`container.exec` as root before running the plugin.

On a default-configured MariaDB image, the plugin legitimately
flags three security issues: the `test` user has its username as
its password ("user with username as password"), both root and
test are defined as `@'%'` ("accounts without hostname
restriction"), and the `test` user is created on
`mysql_native_password` ("user on a legacy authentication
plugin"). The upstream MySQL images create their accounts on
`caching_sha2_password` and so only trip the wildcard-host
finding. All of them are real findings worth monitoring; the test
pins the WARN state so the plugin's detection logic stays in
place and a future refactor cannot silently mask either signal.

The test matrix is defined by the Containerfiles under
`containerfiles/`. Each file is a Containerfile (typically a
one-line `FROM`) and gets built once via testcontainers'
DockerImage (cached across runs). Add a new MariaDB LTS by
dropping in a new Containerfile; retire one by deleting the file.

`EXPECTED_AUTH_PLUGIN` pins the modern authentication plugin the
plugin must recommend per image, so a version-detection regression
cannot silently advise the wrong plugin: `caching_sha2_password` on
MySQL 8.0+, `parsec` on MariaDB 11.6+, `ed25519` on older MariaDB.

Requirements:
- podman (or docker) with a reachable socket
- `pip install testcontainers`
- `tools/run-unit-tests` auto-sets `CONTAINER_HOST` and
  `TESTCONTAINERS_RYUK_DISABLED`
"""

import os
import subprocess
import sys
import unittest

sys.path.insert(0, '..')

import lib.lftest
from lib.globals import STATE_WARN

HERE = os.path.dirname(os.path.abspath(__file__))
CONTAINERFILES_DIR = os.path.join(HERE, 'containerfiles')
CONTAINERFILES = sorted(
    name for name in os.listdir(CONTAINERFILES_DIR)
    if os.path.isfile(os.path.join(CONTAINERFILES_DIR, name))
)

# Modern authentication plugin the check must recommend for the legacy
# accounts it finds: `parsec` on MariaDB 11.6+ (where it first ships),
# `ed25519` on older MariaDB. The upstream MySQL images already create
# their accounts on `caching_sha2_password`, so they hold no legacy
# account and the check must not emit an auth recommendation at all.
EXPECTED_AUTH_RECOMMENDATION = {
    'mariadb-v106': 'IDENTIFIED VIA ed25519',
    'mariadb-v1011': 'IDENTIFIED VIA ed25519',
    'mariadb-v114': 'IDENTIFIED VIA ed25519',
    'mariadb-v118': 'IDENTIFIED VIA parsec',
    'mysql-v80': None,
    'mysql-v84': None,
}


class TestCheck(unittest.TestCase):
    pass


def _check_image(test, containerfile):
    path = os.path.join(CONTAINERFILES_DIR, containerfile)
    print(f'\n=== Testing {containerfile} ===', flush=True)
    with lib.lftest.run_mysql_compatible_from_containerfile(path) as (container, defaults_file):
        # Grant the `test` user read access to the `mysql` system
        # database so it can query `mysql.user` / `mysql.global_priv`.
        # sclorg images accept root via socket auth (no password
        # because the container runs as the mysql OS user); upstream
        # images require the `-p` password. Try without password
        # first, fall back to the password-auth variant.
        container.exec([
            'sh', '-c',
            'if command -v mariadb >/dev/null 2>&1; then C=mariadb; '
            'else C=mysql; fi; '
            'GRANT_SQL="GRANT SELECT ON mysql.* TO '
            "'test'@'%'"
            '"; '
            '"$C" -uroot -e "$GRANT_SQL" 2>/dev/null '
            '|| "$C" -uroot -ptest -e "$GRANT_SQL"',
        ])

        cmd = [
            'python3', '../mysql-user-security',
            f'--defaults-file={defaults_file}',
        ]
        print(f'Run plugin: {" ".join(cmd)}', flush=True)
        result = subprocess.run(
            cmd,
            cwd=os.path.dirname(os.path.abspath(__file__)),
            capture_output=True,
            text=True,
        )
        combined = result.stdout + result.stderr
        print(f'Script output:\n{combined.strip()}', flush=True)

        test.assertEqual(result.returncode, STATE_WARN)
        test.assertIn('without hostname restriction', combined)
        test.assertIn('on a legacy authentication plugin', combined)
        test.assertIn('mysql_users_on_legacy_auth_plugin', combined)

        # The legacy-auth finding must advise the plugin that the running
        # server branch actually supports, not just any modern plugin.
        # MariaDB loads neither parsec nor ed25519 by default, so the
        # one-time INSTALL has to precede the ALTER USER statements.
        expected = EXPECTED_AUTH_RECOMMENDATION[containerfile]
        if expected:
            test.assertIn(expected, combined)
            test.assertIn("INSTALL SONAME 'auth_", combined)
        else:
            test.assertIn('0 users on a legacy authentication plugin', combined)
            test.assertNotIn('IDENTIFIED', combined)


lib.lftest.attach_each(TestCheck, CONTAINERFILES, _check_image)


if __name__ == '__main__':
    unittest.main()
