import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_UNKNOWN

# The plugin appends `-chassises` (Chassis collection), `-chassis` (member),
# `-sensors` (Sensors collection), `-sensor-N` (each Sensor, indexed) and
# `-thermal` (Thermal block) to the --test path as it walks the Redfish API.
# When a chassis exposes no Sensors collection, the plugin falls back to the
# legacy Thermal and Power endpoints and additionally loads `-power`.
COMMON = '--url=https://example.com'

TESTS = [
    {
        'id': 'ok-healthy-chassis',
        'test': 'stdout/healthy-chassis,,0',
        'params': COMMON,
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok, checked sensors on 1 member.',
        ],
    },
    {
        # A sensor whose firmware reports a zero-width min/max range
        # (identical min and max, here 255 as a "not available"/"no limit"
        # placeholder) must not raise a false warning for an in-spec reading.
        # Fixture taken from issue #1211.
        'id': 'ok-zero-width-range',
        'test': 'stdout/zero-range-chassis,,0',
        'params': COMMON,
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok, checked sensors on 1 member.',
            'CPU Utilization',
        ],
    },
    {
        # A chassis without a modern Sensors collection must fall back to the
        # legacy Thermal (Temperatures, Fans) and Power (Voltages, power
        # supplies) endpoints and still report readings.
        'id': 'ok-legacy-thermal-fallback',
        'test': 'stdout/legacy-thermal,,0',
        'params': COMMON,
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok, checked sensors on 1 member.',
            'Cel',
            'RPM',
        ],
        'assert-not-in': ['[WARNING]', '[CRITICAL]'],
    },
    {
        # In the legacy fallback, a temperature above its UpperThresholdCritical
        # must escalate to CRITICAL. This proves the legacy threshold fields are
        # mapped onto the modern sensor-state logic.
        'id': 'crit-legacy-temp-threshold',
        'test': 'stdout/legacy-temp-crit,,0',
        'params': COMMON,
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'There are critical errors.',
            '[CRITICAL]',
        ],
    },
    {
        # Cisco returns the legacy Power "PowerControl" as a single object
        # instead of a list. The plugin must normalize it to a list and report
        # the chassis-wide power consumption rather than crash.
        'id': 'ok-cisco-powercontrol-dict',
        'test': 'stdout/cisco-powercontrol,,0',
        'params': COMMON,
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok, checked sensors on 1 member.',
            'System Power Control',
            '287',
        ],
        'assert-not-in': ['[WARNING]', '[CRITICAL]'],
    },
    {
        # --inventory emits the parsed components as JSON (one object keyed by
        # component type) and exits OK, so several Redfish checks can be merged
        # with `jq --slurp`.
        'id': 'ok-inventory-json',
        'test': 'stdout/healthy-chassis,,0',
        'params': f'{COMMON} --inventory',
        'assert-retc': STATE_OK,
        'assert-in': ['"sensor":', '"chassi_ids":'],
    },
    {
        # A missing fixture must surface as STATE_UNKNOWN with a
        # readable message, not as a Python traceback.
        'id': 'unknown-missing-fixture',
        'test': 'stdout/does-not-exist,,0',
        'params': COMMON,
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Test fixture not found'],
    },
]


class TestCheck(unittest.TestCase):
    check = '../redfish-sensors'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
