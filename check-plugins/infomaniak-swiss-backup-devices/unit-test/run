import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN
import lib.lftest


BASE_PARAMS = '--token=TOKEN --account-id=ACCOUNT-ID'


TESTS = [
    {
        'id': 'warn-devices-with-warning',
        'test': 'stdout/devices-with-warning,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_WARN,
        'assert-in': [
            'There are warnings.',
            'ID    ! Customer     ! Tag   ! User         ! Name   ! Type  ! Locked ! ',
            '------+--------------+-------+--------------+--------+-------+--------+-',
            '99904 ! BK-200999-1  ! tag01 ! SBI-AB123456 ! bucket ! swift ! False  ! ',
        ],
    },
    {
        'id': 'ok-devices-unlocked',
        'test': 'stdout/devices-unlocked,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok.',
            'ID    ! Customer     ! Tag   ! User         ! Name   ! Type  ! Locked ! ',
            '------+--------------+-------+--------------+--------+-------+--------+-',
            '99904 ! BK-200999-1  ! tag01 ! SBI-AB123456 ! bucket ! swift ! False  ! ',
        ],
    },
    {
        'id': 'ok-no-devices',
        'test': 'stdout/no-devices,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok'],
    },
    {
        'id': 'warn-devices-locked-severity-warn',
        'test': 'stdout/devices-locked,,0',
        'params': f'{BASE_PARAMS} --severity=warn',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'There are warnings.',
            'ID    ! Customer     ! Tag   ! User         ! Name   ! Type  ! Locked         ! ',
            '------+--------------+-------+--------------+--------+-------+----------------+-',
            '99904 ! BK-200999-1  ! tag01 ! SBI-AB123456 ! bucket ! swift ! True [WARNING] ! ',
        ],
    },
    {
        'id': 'crit-devices-locked-severity-crit',
        'test': 'stdout/devices-locked,,0',
        'params': f'{BASE_PARAMS} --severity=crit',
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'There are critical errors.',
            'ID    ! Customer     ! Tag   ! User         ! Name   ! Type  ! Locked          ! ',
            '------+--------------+-------+--------------+--------+-------+-----------------+-',
            '99904 ! BK-200999-1  ! tag01 ! SBI-AB123456 ! bucket ! swift ! True [CRITICAL] ! ',
        ],
    },
    {
        'id': 'ok-ignore-customer',
        'test': 'stdout/devices-unlocked,,0',
        'params': f"{BASE_PARAMS} --ignore-customer='BK-200999-1$'",
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.', '99924'],
        'assert-not-in': ['99904'],
    },
    {
        'id': 'ok-ignore-name',
        'test': 'stdout/devices-unlocked,,0',
        'params': f"{BASE_PARAMS} --ignore-name='^test$'",
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.', '99924'],
        'assert-not-in': ['99925', '99931', '99945'],
    },
    {
        'id': 'ok-ignore-tag',
        'test': 'stdout/devices-unlocked,,0',
        'params': f"{BASE_PARAMS} --ignore-tag='^tag01$'",
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.', '99924'],
        'assert-not-in': ['99904'],
    },
    {
        'id': 'ok-ignore-user',
        'test': 'stdout/devices-unlocked,,0',
        'params': f"{BASE_PARAMS} --ignore-user='SBI-AB123456'",
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.'],
        'assert-not-in': ['99904', '99924'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../infomaniak-swiss-backup-devices'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
