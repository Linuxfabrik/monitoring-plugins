"""Unit tests for the postgresql-version check plugin.

The fixtures in `stdout/` are real `psql --command="SELECT version();"`
outputs captured from every officially-supported PostgreSQL major
(13 through 18) using the `postgres:<tag>` images on Docker Hub. The
plugin runs its regex parser against each one.

Each testcase pins the expected Nagios state to whatever
`lib.version.check_eol()` returned when these fixtures were saved
against the live https://endoflife.date/api/postgresql.json data. The
EOL table drifts over time (releases hit EOL, new majors appear), so
the `assert-retc` and `assert-in` strings will need to be re-pinned
every few months.
"""

import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_UNKNOWN, STATE_WARN
import lib.lftest


TESTS = [
    {
        # PostgreSQL 13 reached EOL 2025-11-13.
        'id': 'warn-postgresql-13-eol',
        'test': 'stdout/select-version-13,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['PostgreSQL v13.23', 'EOL 2025-11-13', '[WARNING]'],
    },
    {
        'id': 'ok-postgresql-14-supported',
        'test': 'stdout/select-version-14,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['PostgreSQL v14.22', 'EOL 2026-11-12'],
    },
    {
        'id': 'ok-postgresql-15-supported',
        'test': 'stdout/select-version-15,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['PostgreSQL v15.17', 'EOL 2027-11-11'],
    },
    {
        'id': 'ok-postgresql-16-supported',
        'test': 'stdout/select-version-16,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['PostgreSQL v16.10', 'EOL 2028-11-09'],
    },
    {
        'id': 'ok-postgresql-17-supported',
        'test': 'stdout/select-version-17,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['PostgreSQL v17.9', 'EOL 2029-11-08'],
    },
    {
        'id': 'ok-postgresql-18-supported',
        'test': 'stdout/select-version-18,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['PostgreSQL v18.3', 'EOL 2030-11-14'],
    },
    {
        # Parser edge case: psql cannot connect, output does not
        # contain a "PostgreSQL X.Y" string.
        'id': 'unknown-garbage-output',
        'test': 'stdout/garbage-output,,0',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['PostgreSQL not found or unable to fetch version information.'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../postgresql-version'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
