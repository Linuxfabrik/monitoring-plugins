import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_OK

TESTS = [
    {
        'id': 'ok-291-active-conns',
        'test': 'stdout/291-active-conns,,',
        'assert-retc': STATE_OK,
        'assert-in': [
            '291 active concurrent conns; 16.6M accepted conns, '
            '16.6M handled conns, 31.1M reqs;',
            "connections_waiting'=106;;;0",
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../nginx-status'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
