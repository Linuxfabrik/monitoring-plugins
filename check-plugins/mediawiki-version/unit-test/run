import sys

sys.path.insert(0, '..')

import unittest

import lib.version
from lib.globals import STATE_WARN

# This plugin has no --test hook. It reads a local Defines.php file and then
# queries the endoflife.date API for the current MediaWiki EOL data. That API
# call is not deterministic, so unit tests exercise the `lib.version.check_eol`
# helper directly instead of the plugin binary. The `stdout/defines-php-1-39-3`
# fixture documents the expected Defines.php shape for reference.


class TestCheck(unittest.TestCase):

    def test_check_eol_1_38_2_warn(self):
        retc, msg = lib.version.check_eol(
            'https://endoflife.date/api/mediawiki.json',
            '1.38.2',
            offset_eol=-30,
            check_major=False,
            check_minor=False,
            check_patch=False,
        )
        self.assertRegex(
            msg,
            r'EOL 2023-06-30 -30d \[WARNING\], minor 1\..* available',
        )
        self.assertEqual(retc, STATE_WARN)


if __name__ == '__main__':
    unittest.main()
