            "icon_image": "docker-service.svg",
            "icon_image_alt": null,
            "imports": [
                "tpl-service-generic"
            ],
            "max_check_attempts": 5,
            "notes": "Checks the health of Docker Swarm services: how many of the expected tasks (containers) of a service are actually running, and optionally whether those tasks are spread evenly across the swarm nodes. The number of running tasks is compared against an expected count as a percentage, so a service that lost some but not all of its tasks can warn before it goes fully down. The expected count defaults to the service's own desired replica count, but can be pinned per service with --service, so scaling a service down by mistake is still caught against the count the service is supposed to run. With --check-distribution the check also warns when more tasks of a service sit on a single node than an even spread would place there, which surfaces a node that silently stopped taking work. Must be run on a swarm manager node, since only managers can list services. Podman does not support swarm mode, so there is no Podman counterpart to this check. Requires root or sudo.",
            "notes_url": "https://linuxfabrik.github.io/monitoring-plugins/check-plugins/docker-service/",
            "object_name": "tpl-service-docker-service",
            "object_type": "template",
            "retry_interval": 15,
            "service_set": null,
            "template_choice": null,
            "use_agent": null,
            "use_var_overrides": null,
            "vars": {
                "criticality": "C",
                "docker_service_always_ok": false,
                "docker_service_check_distribution": false,
                "docker_service_critical": "50:",
                "docker_service_ignore": [],
                "docker_service_lengthy": false,
                "docker_service_no_match_severity": "ok",
                "docker_service_service": [],
                "docker_service_warning": "100:"
            },
            "volatile": null,
            "zone": null,
            "uuid": "ad457c0e-e64e-48ce-ad48-ffd129c8c120"
        }
    },
