"""Integration tests for the mysql-table-cache check plugin.

The plugin opens a real `pymysql` connection and reads
`table_open_cache` / `opened_tables` / `table_open_cache_hits`
from `SHOW GLOBAL STATUS` and `SHOW VARIABLES`, so a static
fixture cannot drive it - we spin up an actual MariaDB server
and let the plugin talk to it over TCP.

Unlike most other integration tests this one targets the CRIT
branch, not STATE_OK: a freshly booted MariaDB opens ~17 system
tables during startup (all cache misses) and only a handful of
hits happen after, so the table cache hit rate sits around ~5.6%,
well below the plugin's `--critical` 10% floor. That is the
correct, expected signal in production - a cold restart should
fire the check - and the test pins that behavior so a future
refactor that accidentally masks the cold-cache alert does not
pass silently. We pass `--always-ok` and check the message text
plus the embedded state marker rather than the exit code, so the
plugin can keep returning OK to Icinga during the boot phase
while still surfacing the warning to the admin.

The test matrix is defined by the Containerfiles under
`containerfiles/`. Each file is a Containerfile (typically a
one-line `FROM`) and gets built once via testcontainers'
DockerImage (cached across runs). Add a new MariaDB LTS by
dropping in a new Containerfile; retire one by deleting the file.

Requirements:
- podman (or docker) with a reachable socket
- `pip install testcontainers`
- `tools/run-unit-tests` auto-sets `CONTAINER_HOST` and
  `TESTCONTAINERS_RYUK_DISABLED`
"""

import os
import subprocess
import sys
import unittest

sys.path.insert(0, '..')

import lib.lftest
from lib.globals import STATE_CRIT

HERE = os.path.dirname(os.path.abspath(__file__))
CONTAINERFILES_DIR = os.path.join(HERE, 'containerfiles')
CONTAINERFILES = sorted(
    name for name in os.listdir(CONTAINERFILES_DIR)
    if os.path.isfile(os.path.join(CONTAINERFILES_DIR, name))
)


class TestCheck(unittest.TestCase):
    pass


def _check_image(test, containerfile):
    path = os.path.join(CONTAINERFILES_DIR, containerfile)
    print(f'\n=== Testing {containerfile} ===', flush=True)
    with lib.lftest.run_mariadb_from_containerfile(path) as (_container, defaults_file):
        cmd = [
            'python3', '../mysql-table-cache',
            f'--defaults-file={defaults_file}',
        ]
        print(f'Run plugin: {" ".join(cmd)}', flush=True)
        result = subprocess.run(
            cmd,
            cwd=os.path.dirname(os.path.abspath(__file__)),
            capture_output=True,
            text=True,
        )
        combined = result.stdout + result.stderr
        print(f'Script output:\n{combined.strip()}', flush=True)

        test.assertEqual(result.returncode, STATE_CRIT)
        test.assertRegex(combined, r'[Tt]able cache hit rate.*\[CRITICAL\]')


lib.lftest.attach_each(TestCheck, CONTAINERFILES, _check_image)


if __name__ == '__main__':
    unittest.main()
