"""Integration tests for the mysql-table-cache check plugin.

The plugin opens a real `pymysql` connection and reads
`table_open_cache` / `opened_tables` / `table_open_cache_hits`
from `SHOW GLOBAL STATUS` and `SHOW VARIABLES`, so a static
fixture cannot drive it - we spin up an actual MariaDB server
and let the plugin talk to it over TCP.

Unlike the other Batch 2 plugins this one tests the WARN branch,
not STATE_OK: a freshly booted MariaDB opens ~17 system tables
during startup (all cache misses) and only ~1 hit happens after,
so the table cache hit rate sits around ~5.6%, well below the
plugin's hardcoded 20% WARN floor. That is the correct,
expected signal in production - a cold restart should fire the
check - and the test pins that behavior so a future refactor
that accidentally masks the cold-cache warning does not pass
silently.

Runs against the current MariaDB LTS releases
(`lib.lftest.MARIADB_LTS_IMAGES`).

Requirements:
- podman (or docker) with a reachable socket
- `pip install testcontainers`
- `tools/run-unit-tests` auto-sets `CONTAINER_HOST` and
  `TESTCONTAINERS_RYUK_DISABLED`
"""

import os
import subprocess
import sys
import unittest

sys.path.insert(0, '..')

import lib.lftest
from lib.globals import STATE_WARN

IMAGES = lib.lftest.MARIADB_LTS_IMAGES


class TestCheck(unittest.TestCase):
    pass


def _check_image(test, image_pair):
    image, label = image_pair
    print(f'\n=== Testing {label} ({image}) ===', flush=True)
    with lib.lftest.run_mariadb(image) as (_container, defaults_file):
        cmd = [
            'python3', '../mysql-table-cache',
            f'--defaults-file={defaults_file}',
        ]
        print(f'Run plugin: {" ".join(cmd)}', flush=True)
        result = subprocess.run(
            cmd,
            cwd=os.path.dirname(os.path.abspath(__file__)),
            capture_output=True,
            text=True,
        )
        combined = result.stdout + result.stderr
        print(f'Script output:\n{combined.strip()}', flush=True)

        test.assertEqual(result.returncode, STATE_WARN)
        test.assertRegex(combined, r'table cache hit rate.*\[WARNING\]')


lib.lftest.attach_each(TestCheck, IMAGES, _check_image, id_func=lambda it: it[1])


if __name__ == '__main__':
    unittest.main()
