import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


# The plugin appends `-v1`, `-managers`, `-vendor` to the --test path
# as it walks the Redfish API, so each scenario requires three fixture
# files: `<name>-v1`, `<name>-v1-managers`, `<name>-v1-managers-vendor`.
TESTS = [
    {
        'id': 'ok-empty-sel',
        'test': 'stdout/empty-sel,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok, checked SEL on 1 member.'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../redfish-sel'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
