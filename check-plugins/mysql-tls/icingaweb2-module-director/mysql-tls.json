            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "0a549772-3a34-4def-abc9-1060dfd16542"
        }
    }
