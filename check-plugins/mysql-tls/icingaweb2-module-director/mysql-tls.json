        },
        "3": {
            "varname": "mysql_tls_defaults_file",
            "caption": "MySQL Tls: Defaults File",
            "description": "MySQL/MariaDB cnf file to read user, host and password from. Example: `--defaults-file=/var/spool/icinga2/.my.cnf`.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "46d82a3c-1eb8-4595-9163-37bd0b34e4b3"
        },
        "4": {
            "varname": "mysql_tls_defaults_group",
            "caption": "MySQL Tls: Defaults Group",
            "description": "Group/section to read from in the cnf file.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
