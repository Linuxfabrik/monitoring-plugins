            "settings": {
                "visibility": "visible"
            },
            "uuid": "dab3e19d-f997-4c9f-9358-24a19bde7cbd"
        },
        "5": {
            "varname": "mysql_tls_severity",
            "caption": "MySQL Tls: Severity",
            "description": "Severity for the threshold-less TLS findings (session not encrypted, `have_ssl=DISABLED`, `require_secure_transport=OFF`, weak TLS versions, missing cert/key, remote users without `REQUIRE SSL`). One of `warn` or `crit`.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeDatalist",
            "format": null,
            "settings": {
                "behavior": "strict",
                "data_type": "string",
                "datalist": "mysql_tls_severity_list"
            },
            "uuid": "ebf0c8a5-0299-4946-96f0-75eea2b85524"
        },
        "6": {
