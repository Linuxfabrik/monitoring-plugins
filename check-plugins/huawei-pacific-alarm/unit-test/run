import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN

TESTS = [
    {
        'id': 'ok-no-alarms',
        'test': 'stdout/alarms-none,,0',
        'params': '--password=linuxfabrik --url=https://localhost --username=admin',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.', 'No active alarms.'],
    },
    {
        'id': 'crit-critical-alarm',
        'test': 'stdout/alarms-critical,,0',
        'params': '--password=linuxfabrik --url=https://localhost --username=admin',
        'assert-retc': STATE_CRIT,
        'assert-regex': r'License Has Expired.*\[CRITICAL\]',
    },
    {
        'id': 'warn-major-alarm',
        'test': 'stdout/alarms-major,,0',
        'params': '--password=linuxfabrik --url=https://localhost --username=admin',
        'assert-retc': STATE_WARN,
        'assert-regex': r'Disk Predicted To Fail.*\[WARNING\]',
    },
]


class TestCheck(unittest.TestCase):
    check = '../huawei-pacific-alarm'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
