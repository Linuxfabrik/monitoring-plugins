    "Datafield": {
        "1": {
            "varname": "json_values_always_ok",
            "caption": "JSON Values: Always OK?",
            "description": "Always returns OK.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "1fae34a4-a074-4679-9f8f-34de7517aa18"
        },
        "2": {
            "varname": "json_values_critical",
            "caption": "JSON Values: Critical",
            "description": "Nagios range expression evaluated for the CRIT state against the value of the JSON key referenced by --critical-key. Example: `--critical-key=days --critical=1`. Example: `--critical-key=detailedInfo.count1 --critical=@90:100`.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "129cfbe0-6227-4d39-9889-e5ff7e36dd6e"
        },
        "3": {
            "varname": "json_values_critical_key",
            "caption": "JSON Values: Critical Key",
            "description": "Name of the JSON key whose value should be evaluated against --critical for the CRIT state. Supports dot-notation for nested keys (e.g. `detailedInfo.count1`). The value at the resolved key must be numeric in the JSON, otherwise the check returns UNKNOWN. Example: `--critical-key=days`. Example: `--critical-key=detailedInfo.count1`.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "e459d06c-6aa0-4fe9-96fc-83637b93a72a"
        },
        "4": {
            "varname": "json_values_filename",
            "caption": "JSON Values: Filename",
            "description": "Path to a local JSON file. Mutually exclusive with -u / --url.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "eb5056ae-b34f-4669-9bf0-32af51d28455"
        },
        "5": {
            "varname": "json_values_header",
            "caption": "JSON Values: Header",
            "description": "Custom HTTP request header to send when fetching the URL. curl-style format `\"Name: Value\"`. Can be specified multiple times. Example: `--header=\"X-API-Key: linuxfabrik\"`. Example: `--header=\"Accept: application/json\"`.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeArray",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "1c0c5159-5889-4d9f-b190-f4224959ac91"
        },
