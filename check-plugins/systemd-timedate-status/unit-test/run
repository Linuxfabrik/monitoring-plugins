import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


# Fixtures are named after the `timedatectl` release date they were
# captured from. The wording of the NTP sync line has changed between
# systemd releases, so each pair (`<date>-ok`, `<date>-nok`) exercises
# the parser on one historical format.
TESTS = [
    {
        'id': 'ok-20121017',
        'test': 'stdout/20121017-ok,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'NTP synchronized: yes, NTP enabled: yes',
            'RTC in local TZ: no',
        ],
    },
    {
        'id': 'warn-20121017',
        'test': 'stdout/20121017-nok,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'NTP synchronized: no, NTP enabled: no',
            'The system is configured to read the RTC time in the local time zone. ',
        ],
    },
    {
        'id': 'ok-20140318',
        'test': 'stdout/20140318-ok,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'NTP synchronized: yes, NTP enabled: yes',
            'RTC in local TZ: no',
        ],
    },
    {
        'id': 'warn-20140318',
        'test': 'stdout/20140318-nok,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'NTP synchronized: no, NTP enabled: no',
            'The system is configured to read the RTC time in the local time zone. ',
        ],
    },
    {
        'id': 'ok-20150407',
        'test': 'stdout/20150407-ok,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'NTP synchronized: yes',
            'RTC in local TZ: no',
        ],
    },
    {
        'id': 'warn-20150407',
        'test': 'stdout/20150407-nok,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'NTP synchronized: no',
            'The system is configured to read the RTC time in the local time zone. ',
        ],
    },
    {
        'id': 'ok-20170921',
        'test': 'stdout/20170921-ok,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'System clock synchronized: yes, systemd-timesyncd.service active: yes',
            'RTC in local TZ: no',
        ],
    },
    {
        'id': 'warn-20170921',
        'test': 'stdout/20170921-nok,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'System clock synchronized: no, systemd-timesyncd.service active: no',
            'The system is configured to read the RTC time in the local time zone. ',
        ],
    },
    {
        'id': 'ok-20201026',
        'test': 'stdout/20201026-ok,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'System clock synchronized: yes, NTP service: yes',
            'RTC in local TZ: no',
        ],
    },
    {
        'id': 'warn-20201026',
        'test': 'stdout/20201026-nok,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'System clock synchronized: no, NTP service: no',
            'The system is configured to read the RTC time in the local time zone. ',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../systemd-timedate-status'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
