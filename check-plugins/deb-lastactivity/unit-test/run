import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'crit-last-activity-years-old',
        'test': 'stdout/old-activity-2020,,0',
        'assert-retc': STATE_CRIT,
        'assert-in': ['Last package manager activity is '],
    },
    {
        'id': 'warn-missing-last-modified-timestamp',
        'test': 'stdout/packages-without-timestamp,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'Missing "Last-Modified" timestamp for one or more packages. '
            'Check the output of ',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../deb-lastactivity'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
