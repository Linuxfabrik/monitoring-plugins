import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-pairs-in-sync',
        'test': 'stdout/pairs-in-sync,,0',
        'params': '--device-id=1 --password=pass --url=https://localhost --username=admin',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok.',
            'UUID                                   ! Link ! Last Sync                       '
            '! Duration ! Progr (%) ! LocalJob  ! DataState ! Access ! RemoteJob ! DataState '
            '! Access ! Health ! Running',
            '---------------------------------------+------+---------------------------------'
            '+----------+-----------+-----------+-----------+--------+-----------+-----------'
            '+--------+--------+--------',
            '15361:2100f4b78d046ec60000000000000000 ! [OK] ! 2021-08-18 10:39:47',
            '15361:2100f4b78d046ec60000000000000001 ! [OK] ! 2021-08-18 10:39:50',
            '15361:2100f4b78d046ec60000000000000002 ! [OK] ! 2021-08-18 10:38:29',
            '15361:2100f4b78d046ec60000000000000003 ! [OK] ! 2021-08-18 10:39:03',
            '15361:2100f4b78d046ec',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../huawei-dorado-hypermetropair'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
