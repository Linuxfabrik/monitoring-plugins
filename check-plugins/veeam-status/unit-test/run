import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK
import lib.lftest


BASE_PARAMS = '--username=test --password=test'


TESTS = [
    {
        'id': 'crit-jobs-failed-and-warnings',
        'test': 'stdout/jobs-failed-and-warnings,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_CRIT,
        'assert-in': [
            '5 Jobs failed [CRITICAL], 1 VM failed [CRITICAL], "Backup_2014-10-18T044119" ran for 1D 9m [WARNING], Fileserver02 Replication ran for 1D 3h [WARNING], 3 Jobs with warnings [WARNING], 2 VMs with warnings [WARNING], "Omega Cloud Vol2" 0.3% used - total: 300.0GiB, used: 915.0MiB, free: 299.1GiB, "Alpha Cloud Repository" 0.0% used - total: 10.0GiB, used: 0.0B, free: 10.0GiB, "Backup Volume 01" 18.3% used - total: 1005.5GiB, used: 184.2GiB, free: 821.3GiB, "Default Backup Repository" 17.6% used - total: 119.7GiB, used: 21.0GiB, free: 98.6GiB, "Omega Cloud Vol1" 1.7% used - total: 500.0GiB, used: 8.6GiB, free: 491.4GiB',
        ],
    },
    {
        'id': 'ok-all-healthy',
        'test': 'stdout/all-healthy,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_OK,
        'assert-in': [
            '"Backup Volume 01" 18.3% used - total: 1005.5GiB, used: 184.2GiB, free: 821.3GiB',
        ],
    },
    {
        'id': 'ok-with-high-thresholds',
        'test': 'stdout/ok-with-high-thresholds,,0',
        'params': (
            f'{BASE_PARAMS} --failed-job-runs=10 --failed-vm-lastest-states=10 '
            '--max-backup-job-duration=8640000 --max-replica-job-duration=864000 '
            '--warnings-job-runs=10 --warning-vm-lastest-states=10'
        ),
        'assert-retc': STATE_OK,
        'assert-in': [
            '"Backup Volume 01" 18.3% used - total: 1005.5GiB, used: 184.2GiB, free: 821.3GiB',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../veeam-status'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
