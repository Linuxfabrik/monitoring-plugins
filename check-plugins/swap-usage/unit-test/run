import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN
import lib.lftest


# The swap-usage plugin normally calls `psutil.swap_memory()` and
# walks `/proc/<pid>/status` for its top-processes table. Its
# `--test` hook reads a JSON fixture mirroring the attributes of the
# `sswap` namedtuple:
#
#     {"total": <bytes>, "used": <bytes>, "free": <bytes>,
#      "percent": <0..100>, "sin": <bytes>, "sout": <bytes>}
#
# When `--test` is active, the /proc-tree scan for top processes is
# skipped so that the test stays deterministic on any host.
TESTS = [
    {
        'id': 'ok-no-swap-in-use',
        'test': 'stdout/no-swap-in-use,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['0.0%', 'total:', 'swapped in:', 'swapped out:'],
    },
    {
        'id': 'ok-half-used',
        'test': 'stdout/half-used,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['50.0%'],
    },
    {
        'id': 'warn-above-warn',
        'test': 'stdout/warn-above-warn,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['80.0%'],
    },
    {
        'id': 'crit-above-crit',
        'test': 'stdout/crit-above-crit,,0',
        'assert-retc': STATE_CRIT,
        'assert-in': ['95.0%'],
    },
    {
        'id': 'ok-always-ok-masks-critical',
        'test': 'stdout/crit-above-crit,,0',
        'params': '--always-ok',
        'assert-retc': STATE_OK,
        'assert-in': ['95.0%'],
    },
    {
        'id': 'ok-custom-thresholds-half-is-crit',
        'test': 'stdout/half-used,,0',
        'params': '--warning=30 --critical=40',
        'assert-retc': STATE_CRIT,
        'assert-in': ['50.0%'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../swap-usage'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
