            "icon_image": "mysql-storage-engines.svg",
            "icon_image_alt": null,
            "imports": [
                "tpl-service-generic"
            ],
            "max_check_attempts": 5,
            "notes": "Checks storage engine health in MySQL/MariaDB. Lists per-engine table counts and sizes, flags InnoDB-enabled-but-no-InnoDB-tables, hunts fragmented tables, and warns when an `AUTO_INCREMENT` value approaches its column-type maximum. The fragmentation rule mirrors mysqltuner: only tables larger than 100 MiB with more than 10% `DATA_FREE` count. The `AUTO_INCREMENT` check goes beyond mysqltuner by comparing each column to its own type ceiling (`TINYINT` to `BIGINT`, signed/unsigned), so tables using `INT UNSIGNED` are caught long before they hit the duplicate-key error.",
            "notes_url": "https://linuxfabrik.github.io/monitoring-plugins/check-plugins/mysql-storage-engines/",
            "object_name": "tpl-service-mysql-storage-engines",
            "object_type": "template",
            "retry_interval": 15,
            "service_set": null,
            "template_choice": null,
            "use_agent": null,
            "use_var_overrides": null,
            "vars": {
                "criticality": "C",
                "mysql_storage_engines_always_ok": false,
                "mysql_storage_engines_critical_autoincrement_pct": "90",
                "mysql_storage_engines_critical_fragmented_tables": "4",
                "mysql_storage_engines_defaults_file": "/var/spool/icinga2/.my.cnf",
                "mysql_storage_engines_defaults_group": "client",
                "mysql_storage_engines_lengthy": true,
                "mysql_storage_engines_timeout": 3,
                "mysql_storage_engines_warning_autoincrement_pct": "75",
                "mysql_storage_engines_warning_fragmented_tables": "0"
            },
