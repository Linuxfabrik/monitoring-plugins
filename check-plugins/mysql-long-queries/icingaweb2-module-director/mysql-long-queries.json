            "max_check_attempts": 5,
            "notes": "Checks for in-flight MySQL/MariaDB queries that have been running longer than `--warning` / `--critical` seconds. Unlike `mysql-slow-queries` (which trends the historical ratio of finished slow queries), this plugin shows queries that are *currently* executing right now, with their session ID, user, database, runtime and a truncated copy of the statement so the admin can `KILL <id>` directly. Sleeping sessions and replication threads are ignored. Logic taken from MySQLTuner `mysql_pfs()`, but the data source is `information_schema.processlist` so the check works on every MySQL/MariaDB release without requiring Performance Schema to be enabled. Without `PROCESS` privilege, the monitoring user only sees its own sessions; grant `PROCESS` on `*.*` to see queries across all sessions.",
            "notes_url": "https://linuxfabrik.github.io/monitoring-plugins/check-plugins/mysql-long-queries/",
            "object_name": "tpl-service-mysql-long-queries",
            "object_type": "template",
            "retry_interval": 15,
            "service_set": null,
            "template_choice": null,
            "use_agent": null,
            "use_var_overrides": null,
            "vars": {
                "criticality": "C",
                "mysql_long_queries_always_ok": false,
                "mysql_long_queries_critical": "300",
                "mysql_long_queries_defaults_file": "/var/spool/icinga2/.my.cnf",
                "mysql_long_queries_defaults_group": "client",
                "mysql_long_queries_ignore": [],
                "mysql_long_queries_lengthy": false,
                "mysql_long_queries_timeout": 3,
                "mysql_long_queries_warning": "30"
