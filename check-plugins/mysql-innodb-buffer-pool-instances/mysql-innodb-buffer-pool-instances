"""See the check's README for more details."""

import argparse
import os
import re
import sys

import lib.args
import lib.base
import lib.db_mysql
import lib.human
from lib.globals import STATE_OK, STATE_UNKNOWN, STATE_WARN

__author__ = 'Linuxfabrik GmbH, Zurich/Switzerland'
__version__ = '2026051001'

DESCRIPTION = """Checks the InnoDB buffer pool instance configuration in MySQL/MariaDB. Alerts if
the configured `innodb_buffer_pool_instances` differs from the recommended value (one instance
per GiB of `innodb_buffer_pool_size`, capped by the number of logical CPU cores and by the
hard upper bound of 64). Skipped on MariaDB 10.4+ where the variable was deprecated and
removed."""

DEFAULT_DEFAULTS_FILE = '/var/spool/icinga2/.my.cnf'
DEFAULT_DEFAULTS_GROUP = 'client'
DEFAULT_TIMEOUT = 3


def parse_args():
    """Parse command line arguments using argparse."""
    parser = argparse.ArgumentParser(description=DESCRIPTION)

    parser.add_argument(
        '-V',
        '--version',
        action='version',
        version=f'%(prog)s: v{__version__} by {__author__}',
    )

    parser.add_argument(
        '--always-ok',
        help=lib.args.help('--always-ok'),
        dest='ALWAYS_OK',
        action='store_true',
        default=False,
    )

    parser.add_argument(
        '--defaults-file',
        help='MySQL/MariaDB cnf file to read user, host and password from (instead of specifying them on the command line). '
        'Example: `/var/spool/icinga2/.my.cnf`. '
        'Default: %(default)s',
        dest='DEFAULTS_FILE',
        default=DEFAULT_DEFAULTS_FILE,
    )

    parser.add_argument(
        '--defaults-group',
        help=lib.args.help('--defaults-group') + ' Default: %(default)s',
        dest='DEFAULTS_GROUP',
        default=DEFAULT_DEFAULTS_GROUP,
    )

    parser.add_argument(
        '--timeout',
        help=lib.args.help('--timeout') + ' Default: %(default)s (seconds)',
        dest='TIMEOUT',
        type=int,
        default=DEFAULT_TIMEOUT,
    )

    args, _ = parser.parse_known_args()
    return args


def get_vars(conn):
    # Do not implement `get_all_vars()`, just fetch the ones we need for this check.
    # Without the GLOBAL modifier, SHOW VARIABLES displays the values that are used for
    # the current connection to MariaDB.
    sql = """
        show global variables
        where variable_name like 'innodb_buffer_pool_instances'
            or variable_name like 'innodb_buffer_pool_size'
            or variable_name like 'version'
            or variable_name like 'version_comment'
            ;
          """
    return lib.base.coe(lib.db_mysql.select(conn, sql))


def main():
    """The main function. This is where the magic happens."""

    # logic taken from mysqltuner.pl:mysql_innodb(), section "InnoDB Buffer Pool
    # Instances", verified in sync with MySQLTuner v2.8.41 (the `> 64` hard cap,
    # the "1 instance per GiB of innodb_buffer_pool_size" formula, the CPU-core
    # cap and the MariaDB 10.4+ skip gate are unchanged upstream since the
    # original port).

    # parse the command line
    try:
        args = parse_args()
    except SystemExit:
        sys.exit(STATE_UNKNOWN)

    mysql_connection = {
        'defaults_file': args.DEFAULTS_FILE,
        'defaults_group': args.DEFAULTS_GROUP,
        'timeout': args.TIMEOUT,
    }
    conn = lib.base.coe(lib.db_mysql.connect(mysql_connection))
    lib.base.coe(lib.db_mysql.check_privileges(conn))

    engines = lib.db_mysql.get_engines(conn)
    myvar = lib.db_mysql.lod2dict(get_vars(conn))
    lib.db_mysql.close(conn)

    # init some vars
    state = STATE_OK
    perfdata = ''

    # InnoDB engine availability. The InnoDB engine has been the MariaDB default
    # since 10.0; if it is genuinely not present or disabled, that is a config
    # decision (e.g. MariaDB compiled without InnoDB), not an UNKNOWN. Mirror
    # mysqltuner's `infoprint` semantic.
    if (
        not engines.get('have_innodb', '')
        or engines['have_innodb'] != 'YES'
    ):
        lib.base.oao(
            'InnoDB Storage Engine not available or disabled.',
            STATE_OK,
            always_ok=args.ALWAYS_OK,
        )

    # MariaDB 10.4 deprecated `innodb_buffer_pool_instances`, MariaDB 10.6 removed
    # it entirely. Running the check on 10.4-10.5 would emit a recommendation the
    # admin cannot act on, so skip with an info message.
    version = myvar.get('version', '')
    version_comment = myvar.get('version_comment', '')
    is_mariadb = (
        'mariadb' in version.lower()
        or 'mariadb' in version_comment.lower()
    )
    version_match = re.match(r'(\d+)\.(\d+)', version)
    major, minor = (
        (int(version_match.group(1)), int(version_match.group(2)))
        if version_match
        else (0, 0)
    )
    if is_mariadb and (major, minor) >= (10, 4):
        lib.base.oao(
            f'`innodb_buffer_pool_instances` is deprecated since MariaDB 10.4 and removed'
            f' since MariaDB 10.6 (this server reports MariaDB {major}.{minor}); skipping.',
            STATE_OK,
            always_ok=args.ALWAYS_OK,
        )

    # Pre-5.6 MySQL never had the variable.
    if myvar.get('innodb_buffer_pool_instances') is None:
        lib.base.oao(
            '`innodb_buffer_pool_instances` is not exposed by this server (pre-MySQL 5.6).',
            STATE_OK,
            always_ok=args.ALWAYS_OK,
        )

    # cache int conversions
    instances = int(myvar['innodb_buffer_pool_instances'])
    buffer_size = int(myvar['innodb_buffer_pool_size'])

    # Compute the recommended value: 1 instance per GiB of innodb_buffer_pool_size,
    # capped by the number of logical CPU cores (mysqltuner uses `nproc`, which is
    # logical cores; os.cpu_count() matches on Linux), and by the hard upper bound
    # of 64. NOTE: the CPU count is read on the host running the plugin. Most
    # Linuxfabrik MySQL plugins run via the local Icinga agent on the DB host, so
    # this matches; on remote invocations the CPU cap reflects the monitoring host.
    cpu_count = os.cpu_count() or 0
    cpu_capped = False
    if buffer_size > 1024 * 1024 * 1024:
        recommended = int(buffer_size / (1024 * 1024 * 1024))
        if cpu_count > 0 and recommended > cpu_count:
            recommended = cpu_count
            cpu_capped = True
        if recommended > 64:
            recommended = 64
    else:
        recommended = 1

    perfdata += lib.base.get_perfdata(
        'mysql_innodb_buffer_pool_instances',
        instances,
        _min=0,
    )
    perfdata += lib.base.get_perfdata(
        'mysql_innodb_buffer_pool_size',
        buffer_size,
        uom='B',
        _min=0,
    )

    # Build the message in independent sections, joined with a single blank line.
    sections = []
    base = (
        f'`innodb_buffer_pool_instances` = {instances}'
        f' (`innodb_buffer_pool_size` = {lib.human.bytes2human(buffer_size)})'
    )
    if instances != recommended:
        state = STATE_WARN
        cap_note = (
            f', capped at {cpu_count} logical CPU cores' if cpu_capped else ''
        )
        sections.append(
            f'{base}. Recommendation: set `innodb_buffer_pool_instances` ='
            f' {recommended}{cap_note}.'
        )
    else:
        sections.append(f'{base}. Matches the recommended value.')

    msg = '\n\n'.join(sections)

    # over and out
    lib.base.oao(msg, state, perfdata, always_ok=args.ALWAYS_OK)


if __name__ == '__main__':
    try:
        main()
    except Exception:
        lib.base.cu()
