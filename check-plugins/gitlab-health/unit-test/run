import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'ok-gitlab-ok',
        'test': 'stdout/gitlab-ok,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'The GitLab application server is processing requests, but this '
            'does not mean that the database or other services are ready.',
        ],
    },
    {
        'id': 'warn-empty-response',
        'test': 'stdout/empty-response,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['The GitLab application server seems to have a problem'],
    },
    {
        'id': 'warn-nginx-502-error',
        'test': 'stdout/nginx-502-error,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['The GitLab application server seems to have a problem'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../gitlab-health'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
