import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_OK

TESTS = [
    {
        'id': 'ok-fans-healthy',
        'test': 'stdout/fans-healthy,,0',
        'params': '--device-id=1 --password=pass --url=https://localhost --username=admin',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok.',
            'UUID            ! Location      ! Runlevel   ! Health ! Running',
            '----------------+---------------+------------+--------+--------',
            '211:211.0.0.00  ! CTE0.A.FAN0   ! normal (1) ! [OK]   ! [OK]   ',
            '211:211.0.0.01  ! CTE0.A.FAN1   ! normal (1) ! [OK]   ! [OK]   ',
            '211:211.0.0.02  ! CTE0.A.FAN2   ! normal (1) ! [OK]   ! [OK]   ',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../huawei-dorado-fan'


lib.lftest.attach_tests(TestCheck, TESTS)


