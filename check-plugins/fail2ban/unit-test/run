import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_OK, STATE_UNKNOWN, STATE_WARN

# fail2ban's `--test` argument takes a base path and the plugin looks up
# `<base>-ping`, `<base>-status`, and `<base>-status-<jail>` next to each
# other in stdout/.
TESTS = [
    {
        'id': 'unknown-fail2ban-client-ping-failed',
        'test': 'stdout/sshd-over-threshold,,1',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Problem while testing if the fail2ban server is alive.'],
    },
    {
        'id': 'warn-sshd-jail-over-threshold',
        'test': 'stdout/sshd-over-threshold,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            '5434 IPs banned',
            'apache-dos',
            'portscan',
            'sshd',
        ],
        'assert-regex': r'sshd\s.*5432.*\[WARNING\]',
    },
    {
        'id': 'warn-ignore-sshd-drops-to-ok',
        'test': 'stdout/sshd-over-threshold,,0',
        'params': '--ignore="^sshd$"',
        'assert-retc': STATE_OK,
        'assert-in': ['2 IPs banned'],
        'assert-not-in': ['sshd', '5432'],
    },
    {
        'id': 'ok-ignore-everything-nothing-checked',
        'test': 'stdout/all-jails-empty,,0',
        'params': '--ignore=".*"',
        'assert-retc': STATE_OK,
        'assert-in': ['Nothing checked.'],
    },
    {
        # #1308: when the ignore filter drops every jail, --no-match-severity
        # turns the otherwise-OK "Nothing checked." into the configured state.
        'id': 'warn-no-match-severity-maps-empty-to-warn',
        'test': 'stdout/all-jails-empty,,0',
        'params': '--ignore=".*" --no-match-severity=warn',
        'assert-retc': STATE_WARN,
        'assert-in': ['Nothing checked.'],
    },
    {
        'id': 'unknown-no-match-severity-maps-empty-to-unknown',
        'test': 'stdout/all-jails-empty,,0',
        'params': '--ignore=".*" --no-match-severity=unknown',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Nothing checked.'],
    },
    {
        'id': 'unknown-invalid-ignore-regex',
        'test': 'stdout/all-jails-empty,,0',
        'params': '--ignore="["',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Invalid regular expression'],
    },
    {
        'id': 'ok-all-jails-empty',
        'test': 'stdout/all-jails-empty,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            '0 IPs banned',
            'apache-dos',
            'portscan',
            'sshd',
            '[OK]',
        ],
    },
    {
        'id': 'unknown-no-jails-configured',
        'test': 'stdout/no-jails-configured,,0',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['No jails found.'],
    },
]


class TestCheck(unittest.TestCase):
    check = '../fail2ban'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
