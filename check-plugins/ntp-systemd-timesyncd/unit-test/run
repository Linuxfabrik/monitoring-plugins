import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'warn-no-server-used-v1',
        'test': 'stdout/no-server-used-v1,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['No NTP server used.'],
    },
    {
        'id': 'warn-no-server-used-v2',
        'test': 'stdout/no-server-used-v2,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['No NTP server used.'],
    },
    {
        'id': 'ok-stratum-2-synced-v1',
        'test': 'stdout/stratum-2-synced-v1,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Stratum is 2'],
    },
    {
        'id': 'warn-no-server-used-v3',
        'test': 'stdout/no-server-used-v3,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['No NTP server used.'],
    },
    {
        'id': 'ok-stratum-2-synced-v2',
        'test': 'stdout/stratum-2-synced-v2,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Stratum is 2'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../ntp-systemd-timesyncd'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
