import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN
import lib.lftest


# The file-descriptors plugin normally reads `/proc/sys/fs/file-nr`
# (a tab-separated "<allocated>\t<unused>\t<max>" line) and then
# walks `psutil.process_iter()` for its top-N fd-consumer table.
# Its `--test` hook replaces the file-nr read with a JSON fixture:
#
#     {"allocated": <int>, "unused": <int>, "max": <int>}
#
# When `--test` is active the plugin also forces `--top=0` so that
# the Top-N scan of real processes is skipped and the test stays
# deterministic.
TESTS = [
    {
        'id': 'ok-nominal-idle',
        'test': 'stdout/nominal-idle,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['0.5% file descriptors used'],
    },
    {
        'id': 'warn-above-warn',
        'test': 'stdout/warn-above-warn,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['92.0% file descriptors used'],
    },
    {
        'id': 'crit-near-exhaustion',
        'test': 'stdout/crit-near-exhaustion,,0',
        'assert-retc': STATE_CRIT,
        'assert-in': ['99.0% file descriptors used'],
    },
    {
        'id': 'ok-always-ok-masks-critical',
        'test': 'stdout/crit-near-exhaustion,,0',
        'params': '--always-ok',
        'assert-retc': STATE_OK,
        'assert-in': ['99.0% file descriptors used'],
    },
    {
        'id': 'ok-custom-thresholds-idle-is-crit',
        'test': 'stdout/nominal-idle,,0',
        'params': '--warning=0 --critical=0',
        'assert-retc': STATE_CRIT,
        'assert-in': ['0.5% file descriptors used'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../file-descriptors'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
