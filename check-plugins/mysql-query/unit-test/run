"""Integration tests for the mysql-query check plugin.

The plugin opens a real `pymysql` connection and runs an arbitrary
user-supplied SELECT statement for the warning and/or critical
branch. A static fixture cannot drive it - we spin up an actual
MariaDB server and let the plugin run `SELECT 1` against it over
TCP as the simplest happy-path sanity check.

Per CONTRIBUTING's "Combine container tests with fixtures" rule,
this file holds only the happy-path integration test. The plugin
is given no `-c` threshold, so the single returned value `1` from
`SELECT 1` is never compared against anything and the result is
STATE_OK by default.

The test matrix is defined by the Containerfiles under
`containerfiles/`. Each file is a Containerfile (typically a
one-line `FROM`) and gets built once via testcontainers'
DockerImage (cached across runs). Add a new MariaDB LTS by
dropping in a new Containerfile; retire one by deleting the file.

Requirements:
- podman (or docker) with a reachable socket
- `pip install testcontainers`
- `tools/run-unit-tests` auto-sets `CONTAINER_HOST` and
  `TESTCONTAINERS_RYUK_DISABLED`
"""

import os
import subprocess
import sys
import unittest

sys.path.insert(0, '..')

import lib.lftest
from lib.globals import STATE_OK

HERE = os.path.dirname(os.path.abspath(__file__))
CONTAINERFILES_DIR = os.path.join(HERE, 'containerfiles')
CONTAINERFILES = sorted(
    name for name in os.listdir(CONTAINERFILES_DIR)
    if os.path.isfile(os.path.join(CONTAINERFILES_DIR, name))
)


class TestCheck(unittest.TestCase):
    pass


def _check_image(test, containerfile):
    path = os.path.join(CONTAINERFILES_DIR, containerfile)
    print(f'\n=== Testing {containerfile} ===', flush=True)
    with lib.lftest.run_mysql_compatible_from_containerfile(path) as (_container, defaults_file):
        cmd = [
            'python3', '../mysql-query',
            f'--defaults-file={defaults_file}',
            '--critical-query=SELECT 1',
        ]
        print(f'Run plugin: {" ".join(cmd)}', flush=True)
        result = subprocess.run(
            cmd,
            cwd=os.path.dirname(os.path.abspath(__file__)),
            capture_output=True,
            text=True,
        )
        combined = result.stdout + result.stderr
        print(f'Script output:\n{combined.strip()}', flush=True)

        test.assertEqual(result.returncode, STATE_OK)
        # Single-cell `SELECT 1` returns the cell value 1; the plugin's
        # OK output now leads with "Everything is ok." and describes the
        # query result via "CRIT query (`...`) returned <value>".
        test.assertIn('Everything is ok.', combined)
        test.assertRegex(
            combined, r'CRIT query \(`SELECT 1`\) returned 1',
        )
        # Perfdata uses the mysql_-prefixed name for consistency with the
        # other mysql-* plugins.
        test.assertIn("'mysql_query_crit_value'=1", combined)


lib.lftest.attach_each(TestCheck, CONTAINERFILES, _check_image)


if __name__ == '__main__':
    unittest.main()
