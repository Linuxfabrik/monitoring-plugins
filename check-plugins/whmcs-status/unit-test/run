import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_UNKNOWN, STATE_WARN
import lib.lftest


BASE_PARAMS = '--identifier=linuxfabrik --secret=linuxfabrik'


TESTS = [
    {
        'id': 'warn-four-messages',
        'test': 'stdout/four-messages,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_WARN,
        'assert-in': ['There are 4 messages, ordered by severity.'],
    },
    {
        'id': 'ok-one-message',
        'test': 'stdout/one-message,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_OK,
        'assert-in': ['There is 1 message.'],
    },
    {
        'id': 'ok-no-messages',
        'test': 'stdout/no-messages,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.'],
    },
    {
        'id': 'unknown-api-error',
        'test': 'stdout/api-error,,0',
        'params': BASE_PARAMS,
        'assert-retc': STATE_UNKNOWN,
        'assert-in': [
            "Error: {'result': 'error', 'message': 'Something went wrong.'}",
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../whmcs-status'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
