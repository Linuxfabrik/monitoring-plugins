"""Tests for the logfile check plugin.

The plugin has no `--test` hook because it reads a real file given via
`--filename`. The test scenarios pass the fixture paths directly as
`--filename` values. The plugin also maintains a per-check SQLite cache
under `/tmp/linuxfabrik-monitoring-plugins-logfile-<basename>-<hash>.db`
(hash over all pattern/regex arguments), so each subtest removes every
cache DB that matches its fixture to ensure a clean "first scan" state.
"""

import glob
import hashlib
import json
import os
import shutil
import sqlite3
import sys
import tempfile
import unittest

sys.path.insert(0, '..')

import lib.lftest
from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN


def _db_glob(fixture_basename):
    return os.path.join(
        tempfile.gettempdir(),
        f'linuxfabrik-monitoring-plugins-logfile-{fixture_basename}-*.db',
    )


def _legacy_db_path(fixture_basename):
    return os.path.join(
        tempfile.gettempdir(),
        f'linuxfabrik-monitoring-plugins-logfile-{fixture_basename}.db',
    )


# The `test` field is a dummy (the plugin has no `--test` hook) but it
# is required by lib.lftest.run. `params` carries the real CLI, built
# from `--filename=stdout/<fixture>` plus whatever pattern/threshold
# flags the scenario needs.
TESTS = [
    {
        'id': 'ok-clean-log-no-matches',
        'test': 'stdout/django-app-clean,,0',
        'params': (
            '--filename=stdout/django-app-clean '
            '--warning-regex=" WARNING " '
            '--critical-regex=" ERROR "'
        ),
        'assert-retc': STATE_OK,
        'assert-in': [
            'Scanned stdout/django-app-clean',
            '5 lines',
            "' WARNING ' (matched 0 lines)",
            "' ERROR ' (matched 0 lines)",
        ],
        'assert-not-in': ['[WARNING]', '[CRITICAL]'],
    },
    {
        'id': 'warn-two-warnings',
        'test': 'stdout/django-app-two-warnings,,0',
        'params': (
            '--filename=stdout/django-app-two-warnings '
            '--warning-regex=" WARNING " '
            '--critical-regex=" ERROR "'
        ),
        'assert-retc': STATE_WARN,
        'assert-in': [
            'Scanned stdout/django-app-two-warnings',
            '4 lines',
            "' WARNING ' (matched 2 lines) [WARNING]",
            "' ERROR ' (matched 0 lines)",
            'Not Found: /favicon.ico',
            'Not Found: /robots.txt',
        ],
    },
    {
        'id': 'crit-one-warning-one-error',
        'test': 'stdout/django-app-one-warning-one-error,,0',
        'params': (
            '--filename=stdout/django-app-one-warning-one-error '
            '--warning-regex=" WARNING " '
            '--critical-regex=" ERROR "'
        ),
        'assert-retc': STATE_CRIT,
        'assert-in': [
            'Scanned stdout/django-app-one-warning-one-error',
            '3 lines',
            "' WARNING ' (matched 1 line) [WARNING]",
            "' ERROR ' (matched 1 line) [CRITICAL]",
            'MYPRODUCT salutation sync failed',
        ],
    },
    {
        'id': 'ok-one-warning-suppressed-via-ignore-pattern',
        'test': 'stdout/django-app-two-warnings,,0',
        'params': (
            '--filename=stdout/django-app-two-warnings '
            '--warning-regex=" WARNING " '
            '--critical-regex=" ERROR " '
            '--ignore-pattern=favicon.ico '
            '--ignore-pattern=robots.txt'
        ),
        'assert-retc': STATE_OK,
        'assert-in': [
            'Scanned stdout/django-app-two-warnings',
            '4 lines',
            "' WARNING ' (matched 0 lines)",
            "' ERROR ' (matched 0 lines)",
            "ignoring 'favicon.ico' and 'robots.txt'",
        ],
        'assert-not-in': ['[WARNING]', '[CRITICAL]'],
    },
]


class TestCheck(unittest.TestCase):
    check = '../logfile'


def _run_logfile_test(test, testcase):
    # Delete every stateful cache DB for this fixture so the test is
    # reproducible and always starts from offset 0. The plugin derives a
    # per-check hash from the pattern arguments, so we wipe both the
    # legacy per-file DB and any per-check DBs already sitting in /tmp.
    fixture_basename = testcase['params'].split('--filename=stdout/', 1)[1].split(' ', 1)[0]
    legacy_db = _legacy_db_path(fixture_basename)
    if os.path.exists(legacy_db):
        os.remove(legacy_db)
    for db_file in glob.glob(_db_glob(fixture_basename)):
        os.remove(db_file)
    lib.lftest.run(test, test.check, testcase)


lib.lftest.attach_each(TestCheck, TESTS, _run_logfile_test, id_func=lambda t: t['id'])


class TestMultipleChecksSameFile(unittest.TestCase):
    """Regression test for issue #698: two checks on the same logfile with
    different pattern sets must not trample each other's read offset or
    match history. Each check should maintain its own state DB."""

    check = '../logfile'
    fixture = 'stdout/django-app-one-warning-one-error'

    def setUp(self):
        # Start from a clean slate for both hypothetical checks.
        fixture_basename = os.path.basename(self.fixture)
        legacy_db = _legacy_db_path(fixture_basename)
        if os.path.exists(legacy_db):
            os.remove(legacy_db)
        for db_file in glob.glob(_db_glob(fixture_basename)):
            os.remove(db_file)

    def test_two_distinct_checks_do_not_share_state(self):
        # Check A only looks for WARNING lines.
        testcase_a = {
            'id': 'instance-a-warning-only',
            'test': f'{self.fixture},,0',
            'params': (
                f'--filename={self.fixture} '
                '--warning-regex=" WARNING "'
            ),
            'assert-retc': STATE_WARN,
            'assert-in': [
                "' WARNING ' (matched 1 line) [WARNING]",
            ],
        }
        lib.lftest.run(self, self.check, testcase_a)

        # Check B, run immediately after on the same file, only looks
        # for ERROR lines. Before the fix, Check A would have advanced
        # the shared offset to end-of-file and Check B would have seen
        # zero matches. With per-check state, Check B must find its
        # own match.
        testcase_b = {
            'id': 'instance-b-critical-only',
            'test': f'{self.fixture},,0',
            'params': (
                f'--filename={self.fixture} '
                '--critical-regex=" ERROR "'
            ),
            'assert-retc': STATE_CRIT,
            'assert-in': [
                "' ERROR ' (matched 1 line) [CRITICAL]",
            ],
        }
        lib.lftest.run(self, self.check, testcase_b)

        # Two distinct DBs must now exist side by side.
        dbs = glob.glob(_db_glob(os.path.basename(self.fixture)))
        self.assertEqual(
            len(dbs),
            2,
            f'expected two per-check state DBs, found: {dbs}',
        )


# The hash algorithm below mirrors the plugin's instance-hash exactly.
# Keep it in sync if the plugin ever changes the calculation.
def _instance_hash(warn_pattern=None, warn_regex=None, crit_pattern=None,
                   crit_regex=None, ignore_pattern=None, ignore_regex=None):
    payload = json.dumps(
        {
            'crit_pattern': sorted(crit_pattern or []),
            'crit_regex': sorted(crit_regex or []),
            'ignore_pattern': sorted(ignore_pattern or []),
            'ignore_regex': sorted(ignore_regex or []),
            'warn_pattern': sorted(warn_pattern or []),
            'warn_regex': sorted(warn_regex or []),
        },
        sort_keys=True,
    ).encode('utf-8')
    return hashlib.sha256(payload).hexdigest()[:10]


def _per_check_db_path(basename, **hash_kwargs):
    return os.path.join(
        tempfile.gettempdir(),
        f'linuxfabrik-monitoring-plugins-logfile-{basename}-'
        f'{_instance_hash(**hash_kwargs)}.db',
    )


class TestOffsetSurvivesAcrossRuns(unittest.TestCase):
    """Regression tests for issue #1035 fallout: the offset comparison
    must continue to match across runs for both the current TEXT-inode
    schema AND legacy INTEGER-inode schemas migrated forward by the
    #698 state-DB rename. Otherwise the plugin resets the offset to 0
    on every run and re-reads the whole file each time, which shows up
    as a steadily growing `scanned_lines` in Grafana."""

    check = '../logfile'
    source_fixture = 'stdout/django-app-one-warning-one-error'
    hash_kwargs = {
        'warn_regex': [' WARNING '],
        'crit_regex': [' ERROR '],
    }

    def setUp(self):
        # Work on a scratch copy of the fixture so we can safely append
        # to it without polluting the tracked fixture file.
        self.scratch_dir = tempfile.mkdtemp(prefix='logfile-offset-')
        self.scratch_file = os.path.join(self.scratch_dir, 'scan.log')
        shutil.copy(self.source_fixture, self.scratch_file)
        self.scratch_basename = os.path.basename(self.scratch_file)
        # Paranoid: remove any lingering state DB for this basename.
        legacy = _legacy_db_path(self.scratch_basename)
        if os.path.exists(legacy):
            os.remove(legacy)
        for db_file in glob.glob(_db_glob(self.scratch_basename)):
            os.remove(db_file)

    def tearDown(self):
        legacy = _legacy_db_path(self.scratch_basename)
        if os.path.exists(legacy):
            os.remove(legacy)
        for db_file in glob.glob(_db_glob(self.scratch_basename)):
            os.remove(db_file)
        shutil.rmtree(self.scratch_dir, ignore_errors=True)

    def _params(self):
        return (
            f'--filename={self.scratch_file} '
            '--warning-regex=" WARNING " '
            '--critical-regex=" ERROR " '
            '--always-ok'
        )

    def _run(self, expected_new_lines):
        testcase = {
            'id': f'scan-expecting-{expected_new_lines}-lines',
            'test': f'{self.scratch_file},,0',
            'params': self._params(),
            'assert-retc': STATE_OK,
            'assert-in': [
                f'({expected_new_lines} '
                f'{"line" if expected_new_lines == 1 else "lines"})',
            ],
        }
        lib.lftest.run(self, self.check, testcase)

    def test_fresh_db_advances_offset_across_runs(self):
        # Run 1: first scan, reads the whole fixture (3 lines).
        self._run(expected_new_lines=3)
        # Run 2: unchanged file must yield 0 new lines — proof that the
        # offset was persisted and correctly matched on the second read.
        self._run(expected_new_lines=0)
        # Run 3: append one line, expect exactly one new line scanned.
        with open(self.scratch_file, 'a') as fh:
            fh.write('2026-04-22 14:00:00 INFO added one more line\n')
        self._run(expected_new_lines=1)

    def test_legacy_integer_inode_schema_does_not_reset_offset(self):
        # Seed a legacy-schema DB (pre-#1035: inode INTEGER) at the new
        # per-check path so the plugin picks it up without triggering
        # the transparent rename. Inode stored as int to mimic what the
        # old plugin would have written.
        db_path = _per_check_db_path(
            self.scratch_basename, **self.hash_kwargs
        )
        stat = os.stat(self.scratch_file)
        conn = sqlite3.connect(db_path)
        try:
            conn.execute("""
                CREATE TABLE file_stats (
                    filename TEXT NOT NULL PRIMARY KEY,
                    offset INTEGER NOT NULL,
                    inode INTEGER NOT NULL
                )
            """)
            conn.execute("""
                CREATE TABLE matching_lines (
                    filename TEXT NOT NULL,
                    state INTEGER NOT NULL,
                    line TEXT NOT NULL,
                    found_at TIMESTAMP NOT NULL
                )
            """)
            # Seed offset at the current end-of-file and store the inode
            # as INTEGER, exactly as the pre-#1035 plugin would have.
            conn.execute(
                'INSERT INTO file_stats VALUES (?, ?, ?)',
                (self.scratch_file, stat.st_size, stat.st_ino),
            )
            conn.commit()
        finally:
            conn.close()

        # Without the string-cast fix, Run 1 would compare
        #   str(st_ino) != int_from_db  → always True  → offset=0
        # and report 3 lines scanned. With the fix, the offset carries
        # over and the first run sees 0 new lines.
        self._run(expected_new_lines=0)
        # Append a line; the plugin should read exactly that one.
        with open(self.scratch_file, 'a') as fh:
            fh.write('2026-04-22 14:05:00 INFO new line after legacy db\n')
        self._run(expected_new_lines=1)
        # One more unchanged run to confirm the offset keeps advancing
        # cleanly after the legacy row has been overwritten.
        self._run(expected_new_lines=0)

    def test_file_rotation_via_inode_change_still_resets_offset(self):
        # After a real log rotation the file name stays the same but the
        # inode changes. The plugin must detect this and reset the
        # offset to 0 — regardless of the string-cast safety net.
        self._run(expected_new_lines=3)
        self._run(expected_new_lines=0)
        # Simulate rotation: unlink + recreate gives a new inode.
        os.unlink(self.scratch_file)
        shutil.copy(self.source_fixture, self.scratch_file)
        self._run(expected_new_lines=3)


if __name__ == '__main__':
    unittest.main()
