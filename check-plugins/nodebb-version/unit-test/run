import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'warn-v1.17.1-installed',
        'test': 'stdout/v1.17.1-installed,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'NodeBB v1.17.1 installed, NodeBB ',
            " available, Last restart: 2021-08-09 16:03:29 by username 'email'",
        ],
    },
    {
        'id': 'warn-v1.1-installed',
        'test': 'stdout/v1.1-installed,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'NodeBB v1.1 installed, NodeBB ',
            ' available',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../nodebb-version'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
