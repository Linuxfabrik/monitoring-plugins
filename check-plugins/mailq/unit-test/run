import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'ok-postfix-one-mail',
        'test': 'stdout/postfix-one-mail,,0',
        'assert-retc': STATE_OK,
        'assert-regex': r'1 mail to deliver\.',
    },
    {
        'id': 'warn-postfix-two-mails',
        'test': 'stdout/postfix-two-mails,,0',
        'assert-retc': STATE_WARN,
        'assert-regex': r'2 mails to deliver\.',
    },
    {
        'id': 'ok-postfix-empty',
        'test': 'stdout/postfix-empty,,0',
        'assert-retc': STATE_OK,
        'assert-regex': r'Mail queue is empty\.',
    },
    {
        'id': 'warn-postfix-two-mails-alt',
        'test': 'stdout/postfix-two-mails-alt,,0',
        'assert-retc': STATE_WARN,
        'assert-regex': r'2 mails to deliver\.',
    },
    {
        'id': 'ok-sendmail-one-mail',
        'test': 'stdout/sendmail-one-mail,,0',
        'assert-retc': STATE_OK,
        'assert-regex': r'1 mail to deliver\.',
    },
    # Same stdout fixture, but stderr carries a warning from the postqueue binary.
    {
        'id': 'warn-postfix-empty-with-stderr',
        'test': 'stdout/postfix-empty,stderr/postfix-empty,0',
        'assert-retc': STATE_WARN,
        'assert-regex': (
            r'postqueue: warning: Mail system is down -- accessing queue directly\. '
            r'Mail queue is empty\.'
        ),
    },
    {
        'id': 'ok-exim-one-mail',
        'test': 'stdout/exim-one-mail,,0',
        'assert-retc': STATE_OK,
        'assert-regex': r'1 mail to deliver\.',
    },
    {
        'id': 'warn-exim-three-mails',
        'test': 'stdout/exim-three-mails,,0',
        'assert-retc': STATE_WARN,
        'assert-regex': r'3 mails to deliver\.',
    },
    {
        'id': 'ok-exim-empty',
        'test': 'stdout/exim-empty,,0',
        'assert-retc': STATE_OK,
        'assert-regex': r'Mail queue is empty\.',
    },
]


class TestCheck(unittest.TestCase):

    check = '../mailq'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
