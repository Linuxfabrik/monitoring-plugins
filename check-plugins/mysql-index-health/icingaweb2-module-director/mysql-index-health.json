                "mysql_index_health_always_ok": false,
                "mysql_index_health_defaults_file": "/var/spool/icinga2/.my.cnf",
                "mysql_index_health_defaults_group": "client",
                "mysql_index_health_lengthy": false,
                "mysql_index_health_min_uptime_hours": 24,
                "mysql_index_health_timeout": 3,
                "mysql_index_health_warning_redundant": "0",
                "mysql_index_health_warning_unused": "0"
            },
