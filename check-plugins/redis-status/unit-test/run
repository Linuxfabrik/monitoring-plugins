import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'warn-redis-3.2-standalone',
        'test': 'stdout/redis-3.2-standalone,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'Redis v3.2.12, standalone mode on 127.0.0.1:6379, /etc/redis.conf',
        ],
    },
    {
        'id': 'warn-redis-6.0-standalone',
        'test': 'stdout/redis-6.0-standalone,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'Redis v6.0.15, standalone mode on 127.0.0.1:6379, /etc/redis.conf',
        ],
    },
    {
        'id': 'warn-redis-3.0-standalone-v1',
        'test': 'stdout/redis-3.0-standalone-v1,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'Redis v3.0.7.9, standalone mode on 127.0.0.1:6379, /path/to/redis.conf',
        ],
    },
    {
        'id': 'warn-redis-3.0-standalone-v2',
        'test': 'stdout/redis-3.0-standalone-v2,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'Redis v3.0.7.9, standalone mode on 127.0.0.1:6379, /path/to/redis.conf',
        ],
    },
    {
        'id': 'warn-redis-5.0-memory-99-percent',
        'test': 'stdout/redis-5.0-memory-99-percent,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'Redis v5.0.3, standalone mode on 127.0.0.1:6379, /path/to/redis.conf',
            '99.7% memory usage [WARNING] (9.5MiB/9.5MiB, 10.0MiB peak, 21.6MiB RSS)',
            'maxmemory-policy=noeviction',
            '1 DB (db0) with 4 keys, 0.0 evicted keys, 0.0 expired keys',
            'hit rate 100.0% (4.5M hits, 0.0 misses)',
            '2.0 denied partial resync requests [WARNING]',
        ],
    },
    {
        'id': 'ok-redis-5.0-memory-99-percent-ignore-all',
        'test': 'stdout/redis-5.0-memory-99-percent,,0',
        'params': (
            '--warning=100 --critical=100 --ignore-maxmemory0 --ignore-overcommit '
            '--ignore-somaxconn --ignore-sync-partial-err --ignore-thp'
        ),
        'assert-retc': STATE_OK,
        'assert-in': [
            'Redis v5.0.3, standalone mode on 127.0.0.1:6379, /path/to/redis.conf',
            '99.7% memory usage (9.5MiB/9.5MiB, 10.0MiB peak, 21.6MiB RSS)',
            'maxmemory-policy=noeviction',
            '1 DB (db0) with 4 keys, 0.0 evicted keys, 0.0 expired keys',
            'hit rate 100.0% (4.5M hits, 0.0 misses)',
            '2.0 denied partial resync requests',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../redis-status'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
