import sys

sys.path.insert(0, '..')  # Adds higher directory to python modules path.


import unittest

from lib.globals import STATE_OK, STATE_UNKNOWN, STATE_WARN, STATE_CRIT
import lib.base
import lib.shell


class TestCheck(unittest.TestCase):
    check = '../ipmi-sel'

    # self.assertEqual(retc, STATE_CRIT)
    # self.assertIn('Waiting for more data (1).', stdout)
    # self.assertRegexpMatches(stdout, r'1 error in Kernel Ring Buffer.')

    def test_if_check_runs_EXAMPLE01(self):
        stdout, stderr, retc = lib.base.coe(
            lib.shell.shell_exec(self.check + ' --test=stdout/EXAMPLE01,,0')
        )
        self.assertIn(
            '*    1 ; 03/12/2019 ; 13:10:45 ; Physical Security Chassis Intru ; General Chassis intrusion () ; Asserted',
            stdout,
        )
        self.assertEqual(stderr, '')
        self.assertEqual(retc, STATE_WARN)

    def test_if_check_runs_EXAMPLE02(self):
        stdout, stderr, retc = lib.base.coe(
            lib.shell.shell_exec(
                self.check + ' --test=stdout/EXAMPLE02,"SEL has no entries",0'
            )
        )
        self.assertIn('Everything is ok.', stdout)
        self.assertEqual(retc, STATE_OK)

    def test_if_check_runs_EXAMPLE03(self):
        stdout, stderr, retc = lib.base.coe(
            lib.shell.shell_exec(self.check + ' --test=stdout/EXAMPLE03,,0')
        )
        self.assertIn(
            '*   54 ; 08/06/2020 ; 15:05:37 ; System ACPI Power State ACPI_Stat ; S4/S5: soft-off ; Asserted',
            stdout,
        )
        self.assertEqual(stderr, '')
        self.assertEqual(retc, STATE_WARN)

    def test_if_check_runs_EXAMPLE04(self):
        stdout, stderr, retc = lib.base.coe(lib.shell.shell_exec(self.check))
        self.assertIn(
            'Could not open device at /dev/ipmi0 or /dev/ipmi/0 or /dev/ipmidev/0: No such file or directory',
            stdout,
        )
        self.assertEqual(stderr, '')
        self.assertEqual(retc, STATE_UNKNOWN)

    def test_if_check_runs_EXAMPLE05_sel_clear_without_ignore(self):
        """SEL clear entry without --ignore should still warn."""
        stdout, stderr, retc = lib.base.coe(
            lib.shell.shell_exec(self.check + ' --test=stdout/EXAMPLE05,,0')
        )
        self.assertIn('Log area reset/cleared', stdout)
        self.assertEqual(retc, STATE_WARN)

    def test_if_check_runs_EXAMPLE05_sel_clear_with_ignore(self):
        """SEL clear entry with --ignore should return OK (#982)."""
        stdout, stderr, retc = lib.base.coe(
            lib.shell.shell_exec(
                self.check
                + ' --test=stdout/EXAMPLE05,,0 --ignore="Log area reset/cleared"'
            )
        )
        self.assertIn('Everything is ok.', stdout)
        self.assertEqual(retc, STATE_OK)

    def test_if_check_runs_EXAMPLE01_with_ignore(self):
        """Ignore pattern should filter matching entries but keep others."""
        stdout, stderr, retc = lib.base.coe(
            lib.shell.shell_exec(
                self.check + ' --test=stdout/EXAMPLE01,,0 --ignore="Unknown #0xff"'
            )
        )
        self.assertNotIn('Unknown #0xff', stdout)
        self.assertIn('Physical Security Chassis Intru', stdout)
        self.assertEqual(retc, STATE_WARN)


if __name__ == '__main__':
    unittest.main()
