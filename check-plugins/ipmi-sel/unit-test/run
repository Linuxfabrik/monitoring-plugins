import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'warn-chassis-intrusion',
        'test': 'stdout/chassis-intrusion,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            '*    1 ; 03/12/2019 ; 13:10:45 ; Physical Security Chassis Intru ; General Chassis intrusion () ; Asserted',
        ],
    },
    {
        'id': 'ok-empty-sel',
        'test': 'stdout/empty-sel,"SEL has no entries",0',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.'],
    },
    {
        'id': 'warn-acpi-soft-off',
        'test': 'stdout/acpi-soft-off,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            '*   54 ; 08/06/2020 ; 15:05:37 ; System ACPI Power State ACPI_Stat ; S4/S5: soft-off ; Asserted',
        ],
    },
    # SEL clear entry without --ignore should still warn.
    {
        'id': 'warn-sel-log-cleared',
        'test': 'stdout/sel-log-cleared,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['Log area reset/cleared'],
    },
    # SEL clear entry with --ignore should return OK (#982).
    {
        'id': 'ok-sel-log-cleared-with-ignore',
        'test': 'stdout/sel-log-cleared,,0',
        'params': '--ignore="Log area reset/cleared"',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.'],
    },
    # Ignore pattern should filter matching entries but keep others.
    {
        'id': 'warn-chassis-intrusion-with-ignore',
        'test': 'stdout/chassis-intrusion,,0',
        'params': '--ignore="Unknown #0xff"',
        'assert-retc': STATE_WARN,
        'assert-in': ['Physical Security Chassis Intru'],
        'assert-not-in': ['Unknown #0xff'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../ipmi-sel'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
