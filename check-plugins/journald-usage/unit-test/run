import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'warn-seven-gib-used',
        'test': 'stdout/seven-gib-used,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            '7.0GiB used [WARNING] (sum of all archived and active journal files; SystemMaxUse=4G SystemKeepFree=1M)',
        ],
    },
    {
        'id': 'ok-three-kib-used',
        'test': 'stdout/three-kib-used,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            '3.2KiB used (sum of all archived and active journal files; SystemMaxUse=4G SystemKeepFree=1M)',
        ],
    },
    {
        'id': 'ok-twentysix-mib-used',
        'test': 'stdout/twentysix-mib-used,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            '26.6MiB used (sum of all archived and active journal files; SystemMaxUse=4G SystemKeepFree=1M)',
        ],
    },
    {
        'id': 'ok-zero-used',
        'test': 'stdout/zero-used,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            '0.0B used (sum of all archived and active journal files; SystemMaxUse=4G SystemKeepFree=1M)',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../journald-usage'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
