import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK, STATE_UNKNOWN
import lib.lftest


FAILED_MSG = (
    'Failed Pods: At least one container in the pod has terminated in failure. '
    'A container is considered to have failed if it exited with a non-zero status.'
)
PENDING_MSG = (
    'Pending Pods: Have been accepted by the Kubernetes system, but one or more '
    'of the container images have not been created. This could be because the '
    'system is pulling the image from a remote registry, there is insufficient '
    'capacity in the cluster, or some other scheduling issue.'
)
UNKNOWN_MSG = (
    'State of a pod could not be obtained, usually due to an error in '
    'communicating with the host where the pod is supposed to be running.'
)


TESTS = [
    {
        'id': 'crit-all-namespaces',
        'test': 'stdout/pods-mixed-states,,0',
        'assert-retc': STATE_CRIT,
        'assert-in': [
            FAILED_MSG,
            PENDING_MSG,
            'NAMESPACE       ! NAME        ! RDY ! RSTRT ! ',
            '----------------+-------------+-----+-------+-',
            'linuxfabrik-ns1 ! lf-ace543d7 ! 2/2 ! 0     ! ',
            'linuxfabrik-ns1 ! lf-b39dea01 ! 0/1 ! 0     ! ',
            'linuxfabrik-ns1 ! lf-60eccae7 ! 1/1 ! 0     ! ',
            'linuxfabrik-ns1 ! lf-fd905755 ! 1/1 ! 0     ! ',
            'linuxfabrik-ns2 ! lf-c9058a64 ! 1/1 ! 0     ! ',
        ],
    },
    {
        'id': 'crit-ns1-query',
        'test': 'stdout/pods-mixed-states,,0',
        'params': '--query="namespace like \'%-ns1\'"',
        'assert-retc': STATE_CRIT,
        'assert-in': [
            FAILED_MSG,
            PENDING_MSG,
            'NAMESPACE       ! NAME        ! RDY ! RSTRT ! ',
            '----------------+-------------+-----+-------+-',
            'linuxfabrik-ns1 ! lf-ace543d7 ! 2/2 ! 0     ! ',
            'linuxfabrik-ns1 ! lf-b39dea01 ! 0/1 ! 0     ! ',
            'linuxfabrik-ns1 ! lf-60eccae7 ! 1/1 ! 0     ! ',
        ],
    },
    {
        'id': 'unknown-ns2-query',
        'test': 'stdout/pods-mixed-states,,0',
        'params': '--query="namespace like \'%-ns2\'"',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': [
            UNKNOWN_MSG,
            'NAMESPACE       ! NAME        ! RDY ! RSTRT ! ',
            '----------------+-------------+-----+-------+-',
            'linuxfabrik-ns2 ! lf-c9058a64 ! 1/1 ! 0     ! ',
        ],
    },
    {
        'id': 'crit-failed-pod-by-name',
        'test': 'stdout/pods-mixed-states,,0',
        'params': '--query="name = \'lf-ace543d7\'"',
        'assert-retc': STATE_CRIT,
        'assert-in': [
            FAILED_MSG,
            'NAMESPACE       ! NAME        ! RDY ! RSTRT ! ',
            '----------------+-------------+-----+-------+-',
            'linuxfabrik-ns1 ! lf-ace543d7 ! 2/2 ! 0     ! ',
        ],
    },
    {
        'id': 'crit-pending-pod-by-name',
        'test': 'stdout/pods-mixed-states,,0',
        'params': '--query="name = \'lf-b39dea01\'"',
        'assert-retc': STATE_CRIT,
        'assert-in': [
            PENDING_MSG,
            'NAMESPACE       ! NAME        ! RDY ! RSTRT ! ',
            '----------------+-------------+-----+-------+-',
            'linuxfabrik-ns1 ! lf-b39dea01 ! 0/1 ! 0     ! ',
        ],
    },
    {
        'id': 'ok-running-pod-by-name',
        'test': 'stdout/pods-mixed-states,,0',
        'params': '--query="name = \'lf-60eccae7\'"',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok',
            'NAMESPACE       ! NAME        ! RDY ! RSTRT ! ',
            '----------------+-------------+-----+-------+-',
            'linuxfabrik-ns1 ! lf-60eccae7 ! 1/1 ! 0     ! ',
        ],
    },
    {
        'id': 'ok-succeeded-pod-by-name',
        'test': 'stdout/pods-mixed-states,,0',
        'params': '--query="name = \'lf-fd905755\'"',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok',
            'NAMESPACE       ! NAME        ! RDY ! RSTRT ! ',
            '----------------+-------------+-----+-------+-',
            'linuxfabrik-ns1 ! lf-fd905755 ! 1/1 ! 0     ! ',
        ],
    },
    {
        'id': 'unknown-pod-by-name',
        'test': 'stdout/pods-mixed-states,,0',
        'params': '--query="name = \'lf-c9058a64\'"',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': [
            UNKNOWN_MSG,
            'NAMESPACE       ! NAME        ! RDY ! RSTRT ! ',
            '----------------+-------------+-----+-------+-',
            'linuxfabrik-ns2 ! lf-c9058a64 ! 1/1 ! 0     ! ',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../kubectl-get-pods'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
