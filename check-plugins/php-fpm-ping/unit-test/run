import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'ok-pong',
        'test': 'stdout/pong,,',
        'assert-retc': STATE_OK,
        'assert-in': ['pong'],
    },
    {
        'id': 'warn-unexpected-response',
        'test': 'stdout/unexpected-response,,',
        'assert-retc': STATE_WARN,
        'assert-in': ['Lorem ipsum'],
    },
    {
        'id': 'crit-unexpected-response-severity-crit',
        'test': 'stdout/unexpected-response,,',
        'params': '--severity crit',
        'assert-retc': STATE_CRIT,
        'assert-in': ['Lorem ipsum'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../php-fpm-ping'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
