import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_OK, STATE_WARN

TESTS = [
    {
        # A charging backup battery unit (RUNNINGSTATUS 48) is a normal
        # operating state and must not raise a warning. Regression guard for
        # the running-status translation, which previously returned 'Unknown'
        # for code 48 and therefore flagged charging BBUs as WARN.
        'id': 'ok-bbu-charging',
        'test': 'stdout/bbu-charging,,0',
        'params': '--device-id=1 --password=pass --url=https://localhost --username=admin',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.'],
    },
    {
        'id': 'warn-psu-running-warning',
        'test': 'stdout/psu-running-warning,,0',
        'params': '--device-id=1 --password=pass --url=https://localhost --username=admin',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'There are warnings.',
            'UUID       ! Location   ! Produced   ! ControllerID ! #Charged ! Remain '
            '! Volt ! Health ! Running  ',
            '-----------+------------+------------+--------------+----------+--------'
            '+------+--------+----------',
            '210:0.0A.0 ! CTE0.PSU 0 ! 2014-3-25  ! 0A           ! 7        ! 5Y 4M  '
            '! 16.1 ! [OK]   ! [WARNING]',
        ],
    },
]


class TestCheck(unittest.TestCase):
    check = '../huawei-dorado-backup-power'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
