import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'ok-no-incidents',
        'test': 'stdout/no-incidents,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['Everything is ok.'],
    },
    {
        'id': 'warn-incident-krankenkassenkarten',
        'test': 'stdout/incident-krankenkassenkarten,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'Incidents: Störung beim Einlesen von Krankenkassenkarten. See https://support.hin.ch/de/ for details.',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../hin-status'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
