import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-97-accounts',
        'test': 'stdout/97-accounts,,',
        'assert-retc': STATE_OK,
        'assert-in': [
            '0 ringing, 2 active, 92 available, 3 unavailable (total 97 accounts)',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../starface-account-stats'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
