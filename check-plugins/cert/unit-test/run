"""Unit tests for cert.

Each test generates a fresh self-signed certificate via the `cryptography` lib. URL-source
tests fire up a tiny single-shot TLS listener on a random localhost port, run the plugin
against it and assert on the exit code and the user-facing message. File-source tests write
the generated certificate to a temp file (PEM or DER) and run the plugin against the path.
No external network access is required.
"""

import argparse
import datetime
import importlib.machinery
import importlib.util
import os
import resource
import socket
import ssl
import subprocess
import sys
import tempfile
import threading
import time
import unittest

from cryptography import x509
from cryptography.hazmat.primitives import hashes, serialization
from cryptography.hazmat.primitives.asymmetric import ec, ed25519, rsa
from cryptography.x509.oid import NameOID

sys.path.insert(0, '..')

import lib.time
from lib.globals import STATE_CRIT, STATE_OK, STATE_UNKNOWN, STATE_WARN

PLUGIN = '../cert'


def _make_key(key_type):
    if key_type == 'rsa':
        return rsa.generate_private_key(public_exponent=65537, key_size=2048)
    if key_type == 'ecdsa':
        return ec.generate_private_key(ec.SECP256R1())
    if key_type == 'ed25519':
        return ed25519.Ed25519PrivateKey.generate()
    raise ValueError(f'unsupported key_type: {key_type}')


def make_cert(
    common_name, days_valid=365, days_offset=0, sans=None, key_type='rsa',
    with_must_staple=False,
):
    """Build a self-signed certificate plus matching private key. `days_offset` shifts
    `notBefore` (negative for already-issued certs, positive for not-yet-valid certs).
    `key_type` is one of `rsa`, `ecdsa` or `ed25519`. When `with_must_staple` is True,
    the certificate carries the TLS Feature extension with status_request (5), which the
    plugin reports as OCSP Must-Staple = yes.
    """
    key = _make_key(key_type)
    subject = issuer = x509.Name([
        x509.NameAttribute(NameOID.COMMON_NAME, common_name),
    ])
    now = lib.time.now(as_type='utc')
    not_before = now + datetime.timedelta(days=days_offset)
    not_after = not_before + datetime.timedelta(days=days_valid)

    san_list = [x509.DNSName(common_name)]
    if sans:
        san_list.extend(x509.DNSName(s) for s in sans)

    builder = (
        x509.CertificateBuilder()
        .subject_name(subject)
        .issuer_name(issuer)
        .public_key(key.public_key())
        .serial_number(x509.random_serial_number())
        .not_valid_before(not_before)
        .not_valid_after(not_after)
        .add_extension(x509.SubjectAlternativeName(san_list), critical=False)
    )
    if with_must_staple:
        builder = builder.add_extension(
            x509.TLSFeature([x509.TLSFeatureType.status_request]),
            critical=False,
        )

    # Ed25519 carries its hash inside the algorithm; cryptography rejects an explicit
    # hashes.SHA256() in that case
    sign_hash = None if key_type == 'ed25519' else hashes.SHA256()
    cert = builder.sign(key, sign_hash)

    cert_pem = cert.public_bytes(serialization.Encoding.PEM)
    # PKCS8 works for every key type; TraditionalOpenSSL is rejected for Ed25519
    key_pem = key.private_bytes(
        encoding=serialization.Encoding.PEM,
        format=serialization.PrivateFormat.PKCS8,
        encryption_algorithm=serialization.NoEncryption(),
    )
    return cert_pem, key_pem


def make_chain(leaf_cn, intermediate_cn, leaf_days=60, intermediate_days=3650):
    """Build a two-level chain: a self-signed intermediate CA that signs the leaf. Returns
    (leaf_pem, intermediate_pem, leaf_key_pem) so a server can present leaf + intermediate.
    Used to test that the plugin captures the full peer chain (Python 3.13+) and lets a
    near-expiry intermediate drive the state.
    """
    now = lib.time.now(as_type='utc')
    ca_key = rsa.generate_private_key(public_exponent=65537, key_size=2048)
    ca_name = x509.Name([x509.NameAttribute(NameOID.COMMON_NAME, intermediate_cn)])
    ca_cert = (
        x509.CertificateBuilder()
        .subject_name(ca_name)
        .issuer_name(ca_name)
        .public_key(ca_key.public_key())
        .serial_number(x509.random_serial_number())
        .not_valid_before(now)
        .not_valid_after(now + datetime.timedelta(days=intermediate_days))
        .add_extension(x509.BasicConstraints(ca=True, path_length=None), critical=True)
        .sign(ca_key, hashes.SHA256())
    )
    leaf_key = rsa.generate_private_key(public_exponent=65537, key_size=2048)
    leaf_cert = (
        x509.CertificateBuilder()
        .subject_name(x509.Name([x509.NameAttribute(NameOID.COMMON_NAME, leaf_cn)]))
        .issuer_name(ca_name)
        .public_key(leaf_key.public_key())
        .serial_number(x509.random_serial_number())
        .not_valid_before(now)
        .not_valid_after(now + datetime.timedelta(days=leaf_days))
        .add_extension(x509.SubjectAlternativeName([x509.DNSName(leaf_cn)]), critical=False)
        .sign(ca_key, hashes.SHA256())
    )
    leaf_pem = leaf_cert.public_bytes(serialization.Encoding.PEM)
    intermediate_pem = ca_cert.public_bytes(serialization.Encoding.PEM)
    leaf_key_pem = leaf_key.private_bytes(
        encoding=serialization.Encoding.PEM,
        format=serialization.PrivateFormat.PKCS8,
        encryption_algorithm=serialization.NoEncryption(),
    )
    return leaf_pem, intermediate_pem, leaf_key_pem


class TLSServer:
    """Thin one-shot TLS listener that completes the handshake and then closes."""

    def __init__(self, cert_pem, key_pem):
        self.cert_path = self._write_temp(cert_pem)
        self.key_path = self._write_temp(key_pem)
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.sock.bind(('127.0.0.1', 0))
        self.sock.listen(5)
        self.port = self.sock.getsockname()[1]
        self.thread = threading.Thread(target=self._accept, daemon=True)
        self.thread.start()

    @staticmethod
    def _write_temp(data):
        tmp = tempfile.NamedTemporaryFile(delete=False, suffix='.pem')
        tmp.write(data)
        tmp.close()
        return tmp.name

    def _accept(self):
        ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
        ctx.minimum_version = ssl.TLSVersion.TLSv1_2
        ctx.load_cert_chain(self.cert_path, self.key_path)
        self.sock.settimeout(5)
        while True:
            try:
                conn, _ = self.sock.accept()
            except OSError:
                return
            try:
                with ctx.wrap_socket(conn, server_side=True) as tls_conn:
                    try:
                        tls_conn.recv(1)
                    except (OSError, ssl.SSLError):
                        pass
            except (OSError, ssl.SSLError):
                pass

    def close(self):
        try:
            self.sock.close()
        except OSError:
            pass
        for path in (self.cert_path, self.key_path):
            try:
                os.unlink(path)
            except OSError:
                pass


def run_plugin(*args, timeout=10, nofile=None):
    """Invoke the plugin with the given CLI args and return CompletedProcess. `nofile` sets
    RLIMIT_NOFILE to a (soft, hard) pair for the plugin process, which is how a scan's
    worker budget is put under test: a monitoring agent hands its plugins a soft limit far
    below the hard limit.
    """

    def _set_fd_limit():
        resource.setrlimit(resource.RLIMIT_NOFILE, nofile)

    return subprocess.run(
        [PLUGIN, *args],
        capture_output=True,
        text=True,
        timeout=timeout,
        preexec_fn=_set_fd_limit if nofile else None,
    )


def closed_port():
    """Bind a port and close it again, so the next connect attempt to it is refused."""
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.bind(('127.0.0.1', 0))
    port = sock.getsockname()[1]
    sock.close()
    return port


def load_plugin_module():
    """Import the plugin script as a module so its pure helpers can be called directly.
    The script carries no `.py` suffix, so the source loader has to be named explicitly.
    """
    loader = importlib.machinery.SourceFileLoader('cert_plugin', PLUGIN)
    spec = importlib.util.spec_from_loader('cert_plugin', loader)
    module = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(module)
    return module


class TestCheck(unittest.TestCase):

    def _serve(self, cert_pem, key_pem):
        srv = TLSServer(cert_pem, key_pem)
        self.addCleanup(srv.close)
        time.sleep(0.05)  # give the accept thread a moment to bind
        return srv.port

    def _url(self, port):
        return f'https://127.0.0.1:{port}/'

    def test_ok_valid_self_signed_with_insecure(self):
        cert_pem, key_pem = make_cert('test.example.com', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'test.example.com', '--insecure',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('verification skipped', result.stdout)
        self.assertIn('cert_days_left', result.stdout)
        self.assertIn('tls_handshake_time', result.stdout)

    def test_warn_self_signed_default_severity(self):
        cert_pem, key_pem = make_cert('test.example.com', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'test.example.com',
        )
        self.assertEqual(result.returncode, STATE_WARN, result.stdout)
        self.assertIn('chain unverified', result.stdout)

    def test_crit_self_signed_severity_crit(self):
        cert_pem, key_pem = make_cert('test.example.com', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'test.example.com', '--severity', 'crit',
        )
        self.assertEqual(result.returncode, STATE_CRIT, result.stdout)
        self.assertIn('chain unverified', result.stdout)

    def test_crit_expired(self):
        cert_pem, key_pem = make_cert(
            'test.example.com', days_valid=10, days_offset=-30,
        )
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'test.example.com', '--insecure',
        )
        self.assertEqual(result.returncode, STATE_CRIT, result.stdout)
        self.assertIn('expired', result.stdout)
        self.assertIn('days ago', result.stdout)

    def test_warn_low_days(self):
        cert_pem, key_pem = make_cert(
            'test.example.com', days_valid=10, days_offset=0,
        )
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'test.example.com', '--insecure',
            '--warning', '14:', '--critical', '5:',
        )
        self.assertEqual(result.returncode, STATE_WARN, result.stdout)

    def test_crit_very_low_days(self):
        cert_pem, key_pem = make_cert(
            'test.example.com', days_valid=3, days_offset=0,
        )
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'test.example.com', '--insecure',
            '--warning', '14:', '--critical', '5:',
        )
        self.assertEqual(result.returncode, STATE_CRIT, result.stdout)

    def test_warn_hostname_mismatch(self):
        # to isolate hostname mismatch from chain failure, trust the self-signed cert as a
        # CA by passing it via --ca-file; the chain then verifies and only the hostname
        # check is left to fail
        cert_pem, key_pem = make_cert('other.example.com', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        ca_file = tempfile.NamedTemporaryFile(delete=False, suffix='.pem')
        ca_file.write(cert_pem)
        ca_file.close()
        self.addCleanup(os.unlink, ca_file.name)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'test.example.com', '--ca-file', ca_file.name,
        )
        self.assertEqual(result.returncode, STATE_WARN, result.stdout)
        self.assertIn('Hostname mismatch', result.stdout)

    def test_lengthy_includes_all_fields(self):
        cert_pem, key_pem = make_cert(
            'test.example.com', days_valid=60, sans=['alt1.example.com'],
        )
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'test.example.com', '--insecure', '--lengthy',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        for needle in (
            'Subject CN', 'Issuer CN', 'Serial', 'Signature Algorithm',
            'Public Key', 'SANs', 'Not Before', 'Not After',
            'SHA-256 Fingerprint', 'OCSP Must-Staple', 'TLS Version', 'Chain',
            'alt1.example.com',
        ):
            self.assertIn(needle, result.stdout, f'missing {needle}')
        # RSA exponent must be exposed for RSA keys
        self.assertIn('RSA', result.stdout)
        self.assertIn('e=65537', result.stdout)
        # default (no Must-Staple extension) should report 'no'
        self.assertRegex(result.stdout, r'OCSP Must-Staple\s*!\s*no')

    def test_unknown_connection_refused(self):
        # bind a port, close it, the next connect attempt is refused
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.bind(('127.0.0.1', 0))
        port = sock.getsockname()[1]
        sock.close()
        result = run_plugin(
            '--source', 'url', '--url', f'https://127.0.0.1:{port}/',
            '--insecure', '--timeout', '2',
        )
        self.assertEqual(result.returncode, STATE_UNKNOWN, result.stdout)
        self.assertIn('Cannot connect', result.stdout)

    def test_unknown_missing_url(self):
        result = run_plugin('--source', 'url')
        self.assertEqual(result.returncode, STATE_UNKNOWN, result.stdout)
        self.assertIn('--url is required', result.stdout)

    def test_lengthy_ecdsa_key(self):
        cert_pem, key_pem = make_cert(
            'test.example.com', days_valid=60, key_type='ecdsa',
        )
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'test.example.com', '--insecure', '--lengthy',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        # cryptography exposes EC keys as ECPublicKey, so the plugin labels them "EC"
        self.assertIn('EC ', result.stdout)
        # only RSA keys carry an exponent in the public key label
        self.assertNotIn('e=', result.stdout)

    def test_lengthy_ed25519_key(self):
        cert_pem, key_pem = make_cert(
            'test.example.com', days_valid=60, key_type='ed25519',
        )
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'test.example.com', '--insecure', '--lengthy',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('Ed25519', result.stdout)

    def test_always_ok_masks_warn(self):
        cert_pem, key_pem = make_cert('test.example.com', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'test.example.com', '--always-ok',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('chain unverified', result.stdout)

    def test_warn_percent_threshold(self):
        # issued 50 days ago, valid 60 days -> ~10 days left = ~17% of the lifetime, so a
        # 25% warning threshold fires while the 5% critical does not
        cert_pem, key_pem = make_cert(
            'pct.example.com', days_valid=60, days_offset=-50,
        )
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'pct.example.com', '--insecure',
            '--warning', '25%', '--critical', '5%',
        )
        self.assertEqual(result.returncode, STATE_WARN, result.stdout)

    def test_crit_duration_threshold(self):
        # ~2 days left, critical when less than 3 days remain
        cert_pem, key_pem = make_cert(
            'iv.example.com', days_valid=60, days_offset=-58,
        )
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'iv.example.com', '--insecure',
            '--warning', '14d', '--critical', '3d',
        )
        self.assertEqual(result.returncode, STATE_CRIT, result.stdout)

    def test_ca_file_repeating(self):
        # the self-signed cert is trusted via two --ca-file values (combined with the
        # system store); with a matching SNI the chain verifies and the result is OK
        cert_pem, key_pem = make_cert('ca.example.com', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        ca_file = tempfile.NamedTemporaryFile(delete=False, suffix='.pem')
        ca_file.write(cert_pem)
        ca_file.close()
        self.addCleanup(os.unlink, ca_file.name)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'ca.example.com',
            '--ca-file', ca_file.name, '--ca-file', ca_file.name,
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('chain verified', result.stdout)

    @unittest.skipUnless(
        hasattr(ssl.SSLSocket, 'get_unverified_chain'),
        'requires Python 3.13+ ssl.SSLSocket.get_unverified_chain()',
    )
    def test_chain_intermediate_drives_state(self):
        # the leaf is valid for 60 days but the intermediate expires in 7; the plugin must
        # inspect the whole peer chain, raise WARN and surface the intermediate as the
        # soonest-expiring certificate
        leaf_pem, intermediate_pem, leaf_key_pem = make_chain(
            'chain.example.com', 'Test Intermediate CA',
            leaf_days=60, intermediate_days=7,
        )
        port = self._serve(leaf_pem + intermediate_pem, leaf_key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'chain.example.com', '--insecure',
            '--warning', '14:', '--critical', '5:',
        )
        self.assertEqual(result.returncode, STATE_WARN, result.stdout)
        self.assertIn('Test Intermediate CA', result.stdout)

    @unittest.skipUnless(
        hasattr(ssl.SSLSocket, 'get_unverified_chain'),
        'requires Python 3.13+ ssl.SSLSocket.get_unverified_chain()',
    )
    def test_chain_lengthy_shows_each_cert(self):
        leaf_pem, intermediate_pem, leaf_key_pem = make_chain(
            'chain.example.com', 'Test Intermediate CA',
        )
        port = self._serve(leaf_pem + intermediate_pem, leaf_key_pem)
        result = run_plugin(
            '--source', 'url', '--url', self._url(port),
            '--sni-hostname', 'chain.example.com', '--insecure', '--lengthy',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        # both the leaf and the intermediate get their own --lengthy block
        self.assertIn('chain.example.com', result.stdout)
        self.assertIn('Test Intermediate CA', result.stdout)
        self.assertIn('(chain 1)', result.stdout)


class TestFileSource(unittest.TestCase):
    """Tests for --source file. Each test writes a freshly generated cert to a temp file
    (PEM or DER) and runs the plugin against the path or a glob.
    """

    def _write(self, data, suffix='.pem'):
        tmp = tempfile.NamedTemporaryFile(delete=False, suffix=suffix)
        tmp.write(data)
        tmp.close()
        self.addCleanup(os.unlink, tmp.name)
        return tmp.name

    def test_ok_pem_file(self):
        cert_pem, _ = make_cert('test.example.com', days_valid=60)
        path = self._write(cert_pem)
        result = run_plugin('--source', 'file', '--filename', path)
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('test.example.com', result.stdout)
        self.assertIn('59d left', result.stdout)
        self.assertNotIn('chain', result.stdout)
        # tls_handshake_time perfdata only applies to URL source
        self.assertNotIn('tls_handshake_time', result.stdout)

    def test_ok_der_file(self):
        cert_pem, _ = make_cert('test.example.com', days_valid=60)
        cert = x509.load_pem_x509_certificate(cert_pem)
        cert_der = cert.public_bytes(serialization.Encoding.DER)
        path = self._write(cert_der, suffix='.der')
        result = run_plugin('--source', 'file', '--filename', path)
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('test.example.com', result.stdout)

    def test_crit_expired_file(self):
        cert_pem, _ = make_cert(
            'test.example.com', days_valid=10, days_offset=-30,
        )
        path = self._write(cert_pem)
        result = run_plugin('--source', 'file', '--filename', path)
        self.assertEqual(result.returncode, STATE_CRIT, result.stdout)

    def test_pem_bundle_expands_to_all_certs(self):
        leaf_pem, _ = make_cert('leaf.example.com', days_valid=60)
        intermediate_pem, _ = make_cert('intermediate.example.com', days_valid=365)
        path = self._write(leaf_pem + intermediate_pem)
        result = run_plugin('--source', 'file', '--filename', path)
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        # both certs from the bundle must appear as separate rows
        self.assertIn('2 certificates in', result.stdout)
        self.assertIn('leaf.example.com', result.stdout)
        self.assertIn('intermediate.example.com', result.stdout)

    def test_bundle_worst_state_drives_verdict(self):
        # leaf is fine, intermediate is expired. Worst-state aggregation across all certs
        # in a single bundle file must surface the expired intermediate as CRIT.
        leaf_pem, _ = make_cert('leaf.example.com', days_valid=60)
        expired_intermediate_pem, _ = make_cert(
            'old.intermediate.example.com', days_valid=10, days_offset=-30,
        )
        path = self._write(leaf_pem + expired_intermediate_pem)
        result = run_plugin('--source', 'file', '--filename', path)
        self.assertEqual(result.returncode, STATE_CRIT, result.stdout)
        self.assertIn('expired', result.stdout)

    def test_glob_multi_aggregates_worst(self):
        ok_pem, _ = make_cert('ok.example.com', days_valid=60)
        warn_pem, _ = make_cert('warn.example.com', days_valid=10)
        # write into a single tempdir so the glob matches both
        with tempfile.TemporaryDirectory() as tmpdir:
            for name, data in (('ok.pem', ok_pem), ('warn.pem', warn_pem)):
                with open(os.path.join(tmpdir, name), 'wb') as fh:
                    fh.write(data)
            result = run_plugin(
                '--source', 'file', '--filename', f'{tmpdir}/*.pem',
                '--warning', '14:', '--critical', '5:',
            )
        self.assertEqual(result.returncode, STATE_WARN, result.stdout)
        self.assertIn('2 certificates in', result.stdout)
        self.assertIn('worst', result.stdout)
        self.assertIn('ok.example.com', result.stdout)
        self.assertIn('warn.example.com', result.stdout)

    def test_unknown_no_match(self):
        result = run_plugin(
            '--source', 'file', '--filename', '/tmp/lfmp-cert-no-such-file-*.pem',
        )
        self.assertEqual(result.returncode, STATE_UNKNOWN, result.stdout)
        self.assertIn('No files match', result.stdout)

    def test_unknown_non_cert_file(self):
        # plain text file, no PEM marker and no DER prefix; the parser silently skips it
        # so we end up with zero parseable certs across one matched file
        path = self._write(b'not a certificate')
        result = run_plugin('--source', 'file', '--filename', path)
        self.assertEqual(result.returncode, STATE_UNKNOWN, result.stdout)
        self.assertIn('No parseable certificates', result.stdout)

    def test_unknown_corrupt_pem(self):
        # a file with a PEM CERTIFICATE marker but truncated body must surface as a real
        # error, not get silently skipped
        path = self._write(
            b'-----BEGIN CERTIFICATE-----\nnotbase64\n-----END CERTIFICATE-----\n',
        )
        result = run_plugin('--source', 'file', '--filename', path)
        self.assertEqual(result.returncode, STATE_UNKNOWN, result.stdout)
        self.assertIn('Cannot parse', result.stdout)

    def test_recursive_glob_skips_non_cert_files(self):
        # mix of certs, private key and a stray text file in nested dirs; recursive glob
        # should pick up only the certs and silently skip the rest
        cert_pem, key_pem = make_cert('test.example.com', days_valid=60)
        with tempfile.TemporaryDirectory() as tmpdir:
            os.makedirs(os.path.join(tmpdir, 'a/b/c'))
            with open(os.path.join(tmpdir, 'a/cert1.pem'), 'wb') as fh:
                fh.write(cert_pem)
            with open(os.path.join(tmpdir, 'a/b/cert2.pem'), 'wb') as fh:
                fh.write(cert_pem)
            with open(os.path.join(tmpdir, 'a/b/c/key.pem'), 'wb') as fh:
                fh.write(key_pem)
            with open(os.path.join(tmpdir, 'a/b/c/notes.txt'), 'wb') as fh:
                fh.write(b'shopping list')
            result = run_plugin(
                '--source', 'file', '--filename', f'{tmpdir}/**/*',
            )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('2 certificates in', result.stdout)

    def test_unknown_missing_filename(self):
        result = run_plugin('--source', 'file')
        self.assertEqual(result.returncode, STATE_UNKNOWN, result.stdout)
        self.assertIn('--filename is required', result.stdout)

    def test_lengthy_file_omits_tls_and_chain(self):
        cert_pem, _ = make_cert('test.example.com', days_valid=60)
        path = self._write(cert_pem)
        result = run_plugin(
            '--source', 'file', '--filename', path, '--lengthy',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('Subject CN', result.stdout)
        self.assertIn('SHA-256 Fingerprint', result.stdout)
        self.assertIn('OCSP Must-Staple', result.stdout)
        # no TLS handshake happened, so these rows should be absent
        self.assertNotIn('TLS Version', result.stdout)
        self.assertNotIn('Chain', result.stdout)

    def test_must_staple_yes(self):
        # add the TLS Feature extension carrying status_request (5) so the parser sees
        # OCSP Must-Staple set; cryptography exposes this via x509.TLSFeature
        cert_pem, _ = make_cert(
            'staple.example.com', days_valid=60, key_type='rsa',
            with_must_staple=True,
        )
        path = self._write(cert_pem)
        result = run_plugin(
            '--source', 'file', '--filename', path, '--lengthy',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertRegex(result.stdout, r'OCSP Must-Staple\s*!\s*yes')


class TestScanSource(unittest.TestCase):
    """Tests for --source scan. Each test fires up one or more local TLS listeners on
    127.0.0.1 and points the scanner at that host with the listeners' ports. Discovery
    is bypassed with --host so no real subnet is touched. Hosts are counted, not
    host/port targets (mirroring the lynis check).
    """

    def _serve(self, cert_pem, key_pem):
        srv = TLSServer(cert_pem, key_pem)
        self.addCleanup(srv.close)
        time.sleep(0.05)  # give the accept thread a moment to bind
        return srv.port

    def test_scan_ok_single_host(self):
        cert_pem, key_pem = make_cert('scan.example.com', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        result = run_plugin('--source', 'scan', '--host', '127.0.0.1', '--ports', str(port))
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        # a scan always uses the table form, even for a single certificate
        self.assertIn('1/1 host responded', result.stdout)
        self.assertIn('1 certificate', result.stdout)
        self.assertIn('scan.example.com', result.stdout)
        self.assertIn(f'127.0.0.1:{port}', result.stdout)
        # host-based perfdata, no per-handshake metric on a scan
        self.assertIn('hosts_total', result.stdout)
        self.assertIn('hosts_responded', result.stdout)
        self.assertIn('certs_found', result.stdout)
        self.assertNotIn('tls_handshake_time', result.stdout)

    def test_scan_two_ports_one_host_worst(self):
        ok_pem, ok_key = make_cert('ok.example.com', days_valid=60)
        warn_pem, warn_key = make_cert('warn.example.com', days_valid=10)
        p_ok = self._serve(ok_pem, ok_key)
        p_warn = self._serve(warn_pem, warn_key)
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1',
            '--ports', str(p_ok), '--ports', str(p_warn),
            '--warning', '14:', '--critical', '5:',
        )
        self.assertEqual(result.returncode, STATE_WARN, result.stdout)
        # one host answered on two ports: 1 host, 2 certificates
        self.assertIn('1/1 host responded', result.stdout)
        self.assertIn('2 certificates', result.stdout)
        self.assertIn('warn.example.com', result.stdout)

    def test_scan_port_range(self):
        cert_pem, key_pem = make_cert('range.example.com', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        # a one-port range start-end that covers exactly the listener port
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1', '--ports', f'{port}-{port}',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('range.example.com', result.stdout)

    def test_scan_crit_expired(self):
        cert_pem, key_pem = make_cert('old.example.com', days_valid=10, days_offset=-30)
        port = self._serve(cert_pem, key_pem)
        result = run_plugin('--source', 'scan', '--host', '127.0.0.1', '--ports', str(port))
        self.assertEqual(result.returncode, STATE_CRIT, result.stdout)
        self.assertIn('expired', result.stdout)

    def test_scan_no_responders(self):
        port = closed_port()
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1', '--ports', str(port),
            '--timeout', '2',
        )
        # nothing answered: not an error, just nothing to alert on
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('0/1 host responded', result.stdout)
        self.assertIn("'certs_found'=0", result.stdout)
        # no certificate, so no days-left metric
        self.assertNotIn('cert_days_left', result.stdout)

    def test_scan_lengthy_has_tls_version_and_chain(self):
        cert_pem, key_pem = make_cert('scan.example.com', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1', '--ports', str(port), '--lengthy',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('TLS Version', result.stdout)
        # the scan reports a trust verdict; a self-signed cert reads "self-signed"
        self.assertIn('Chain', result.stdout)
        self.assertIn('self-signed', result.stdout)

    def test_scan_exclude_removes_all_hosts(self):
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1', '--exclude', '127.0.0.1',
            '--ports', '443',
        )
        self.assertEqual(result.returncode, STATE_UNKNOWN, result.stdout)
        self.assertIn('No target hosts', result.stdout)

    def test_scan_invalid_port(self):
        result = run_plugin('--source', 'scan', '--host', '127.0.0.1', '--ports', 'abc')
        self.assertEqual(result.returncode, STATE_UNKNOWN, result.stdout)
        self.assertIn('Invalid port', result.stdout)

    def test_scan_self_signed_tolerated(self):
        # a valid self-signed cert (typical appliance/IPMI) is cryptographically sound, so
        # the scan tolerates it: OK, with the chain verdict shown in --lengthy
        cert_pem, key_pem = make_cert('appliance.local', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1', '--ports', str(port), '--lengthy',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('self-signed', result.stdout)

    def test_scan_untrusted_warns(self):
        # leaf signed by an internal CA, but the server presents only the leaf and the CA
        # is not trusted: not self-signed, so the trust check fails and raises WARN
        leaf_pem, _intermediate_pem, leaf_key_pem = make_chain(
            'app.example.com', 'Internal CA',
        )
        port = self._serve(leaf_pem, leaf_key_pem)
        result = run_plugin('--source', 'scan', '--host', '127.0.0.1', '--ports', str(port))
        self.assertEqual(result.returncode, STATE_WARN, result.stdout)

    def test_scan_untrusted_insecure_ok(self):
        # --insecure turns trust verification off entirely, so the untrusted cert is OK
        leaf_pem, _intermediate_pem, leaf_key_pem = make_chain(
            'app.example.com', 'Internal CA',
        )
        port = self._serve(leaf_pem, leaf_key_pem)
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1', '--ports', str(port), '--insecure',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)

    def test_scan_untrusted_severity_crit(self):
        leaf_pem, _intermediate_pem, leaf_key_pem = make_chain(
            'app.example.com', 'Internal CA',
        )
        port = self._serve(leaf_pem, leaf_key_pem)
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1', '--ports', str(port),
            '--severity', 'crit',
        )
        self.assertEqual(result.returncode, STATE_CRIT, result.stdout)


class TestWorkerBudget(unittest.TestCase):
    """Tests for the parallelism of --source scan. Every worker holds one socket while it
    probes, so the file-descriptor limit of the process, not --max-workers, has the last
    word. Asking for more workers than there are descriptors makes connect() fail with
    EMFILE, and EMFILE looks exactly like a target that stays silent: the scanner would
    skip those hosts and report OK for a subnet it never probed.
    """

    @classmethod
    def setUpClass(cls):
        cls.plugin = load_plugin_module()

    def _serve(self, cert_pem, key_pem):
        srv = TLSServer(cert_pem, key_pem)
        self.addCleanup(srv.close)
        time.sleep(0.05)  # give the accept thread a moment to bind
        return srv.port

    def _tight_fd_limit(self):
        """A descriptor limit low enough that it, and not the cap, bounds the workers."""
        return self.plugin.MAX_WORKERS_CAP + self.plugin.FD_RESERVE - 1

    def test_default_is_derived_from_the_fd_limit(self):
        fd_limit = self._tight_fd_limit()
        budget = self.plugin.get_max_workers(None, fd_limit)
        self.assertEqual(budget, fd_limit - self.plugin.FD_RESERVE)
        self.assertLess(budget, self.plugin.MAX_WORKERS_CAP)

    def test_default_never_exceeds_the_cap(self):
        # a roomy descriptor limit must not raise the parallelism past the cap: past it,
        # the kernel's system time for connects to dead addresses starves the other checks
        budget = self.plugin.get_max_workers(None, 1000000)
        self.assertEqual(budget, self.plugin.MAX_WORKERS_CAP)

    def test_unknown_fd_limit_falls_back_to_the_cap(self):
        # platforms without RLIMIT_NOFILE, and limits reported as unlimited
        budget = self.plugin.get_max_workers(None, None)
        self.assertEqual(budget, self.plugin.MAX_WORKERS_CAP)

    def test_explicit_request_is_clamped_to_the_cap(self):
        self.assertEqual(
            self.plugin.get_max_workers(5000, 1000000), self.plugin.MAX_WORKERS_CAP
        )

    def test_explicit_request_is_clamped_to_the_fd_limit(self):
        fd_limit = self._tight_fd_limit()
        budget = self.plugin.get_max_workers(5000, fd_limit)
        self.assertEqual(budget, fd_limit - self.plugin.FD_RESERVE)

    def test_explicit_request_within_the_budget_is_honoured(self):
        self.assertEqual(self.plugin.get_max_workers(10, 1024), 10)

    def test_never_fewer_than_one_worker(self):
        for requested, fd_limit in ((None, 1), (None, 0), (0, 1024), (-5, 1024)):
            self.assertEqual(self.plugin.get_max_workers(requested, fd_limit), 1)

    def test_scan_reports_the_clamp_under_verbose(self):
        cert_pem, key_pem = make_cert('scan.example.com', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1', '--ports', str(port),
            '--insecure', '--max-workers', '5000', '--verbose',
            nofile=(128, 128),
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('exceeds the file-descriptor budget', result.stdout)

    def test_scan_reports_the_worker_count(self):
        cert_pem, key_pem = make_cert('scan.example.com', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1', '--ports', str(port), '--insecure',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        # one target, so the scan needs exactly one worker, and the noun is singular
        self.assertIn(', 1 worker', result.stdout.splitlines()[0])

    def test_worker_count_stays_left_of_the_state_marker(self):
        # IcingaWeb replaces [WARNING] with an icon, so the state has to remain last
        cert_pem, key_pem = make_cert('scan.example.com', days_valid=10)
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1', '--ports', str(port), '--insecure',
        )
        self.assertEqual(result.returncode, STATE_WARN, result.stdout)
        self.assertRegex(result.stdout.splitlines()[0], r', 1 worker \[WARNING\]$')

    def test_scan_without_any_response_reports_the_worker_count(self):
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1',
            '--ports', str(closed_port()), '--timeout', '2',
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('0/1 host responded, 1 worker', result.stdout)

    def test_scan_never_builds_a_context_per_target(self):
        """The TLS contexts are built once and shared by all workers. One context per
        target would load the system trust store per target, which costs about 840 kB
        under OpenSSL 1.1 and puts a 2000-worker scan at roughly 1.6 GB of RAM.
        """
        plugin = self.plugin
        args = argparse.Namespace(
            CA_FILE=[], CLIENT_CERT=None, CLIENT_KEY=None, INSECURE=False,
            MAX_WORKERS=4, TIMEOUT=1, VERBOSE=False,
        )
        ok, contexts = plugin.build_scan_contexts(args)
        self.assertTrue(ok, contexts)
        verify_ctx, insecure_ctx = contexts

        original = plugin.ssl.create_default_context
        plugin.ssl.create_default_context = lambda *a, **kw: self.fail(
            'scan_targets built a TLS context per target instead of reusing the shared one'
        )
        self.addCleanup(setattr, plugin.ssl, 'create_default_context', original)

        ports = [closed_port() for _ in range(4)]
        ok, result = plugin.scan_targets(
            args, ['127.0.0.1'], ports, verify_ctx, insecure_ctx,
        )
        self.assertTrue(ok, result)
        items, workers = result
        self.assertEqual(items, [])
        self.assertEqual(workers, 4)

    def test_build_scan_contexts_skips_verification_with_insecure(self):
        args = argparse.Namespace(
            CA_FILE=[], CLIENT_CERT=None, CLIENT_KEY=None, INSECURE=True,
        )
        ok, (verify_ctx, insecure_ctx) = self.plugin.build_scan_contexts(args)
        self.assertTrue(ok)
        self.assertIsNone(verify_ctx)
        self.assertEqual(insecure_ctx.verify_mode, ssl.CERT_NONE)

    def test_build_scan_contexts_reports_a_broken_ca_file(self):
        args = argparse.Namespace(
            CA_FILE=['/nonexistent/ca.pem'], CLIENT_CERT=None, CLIENT_KEY=None,
            INSECURE=False,
        )
        ok, result = self.plugin.build_scan_contexts(args)
        self.assertFalse(ok)
        self.assertIn('Cannot set up the TLS context', result)

    def test_scan_survives_a_low_fd_limit(self):
        # the clamp keeps the scan inside its descriptor budget, so the certificate is
        # found instead of the host being skipped as unreachable
        cert_pem, key_pem = make_cert('scan.example.com', days_valid=60)
        port = self._serve(cert_pem, key_pem)
        result = run_plugin(
            '--source', 'scan', '--host', '127.0.0.1', '--ports', str(port), '--insecure',
            nofile=(128, 128),
        )
        self.assertEqual(result.returncode, STATE_OK, result.stdout)
        self.assertIn('1/1 host responded', result.stdout)


if __name__ == '__main__':
    unittest.main()
