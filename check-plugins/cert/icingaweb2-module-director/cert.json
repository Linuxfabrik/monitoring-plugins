    "Datafield": {
        "1": {
            "varname": "cert_always_ok",
            "caption": "Cert: Always OK?",
            "description": "Always returns OK.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "f25dd1e2-06b5-4b03-bb2f-08f7d64360cf"
        },
        "2": {
            "varname": "cert_ca_file",
            "caption": "Cert: Ca File",
            "description": "Path to a CA bundle in PEM format used for chain verification. Default uses the system trust store.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "8b94b1fe-83bd-48fb-b79f-f6dc3e0d41c0"
        },
        "3": {
            "varname": "cert_client_cert",
            "caption": "Cert: Client Cert",
            "description": "Path to a client certificate in PEM format for mutual TLS.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "59dbad07-eb26-484d-b437-414d1601c950"
        },
        "4": {
            "varname": "cert_client_key",
            "caption": "Cert: Client Key",
            "description": "Path to the client certificate private key in PEM format.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "264bb103-861c-4f13-b596-1bd33d876c2e"
        },
        "5": {
            "varname": "cert_critical",
            "caption": "Cert: Critical",
            "description": "CRIT threshold for days remaining until the certificate expires. Supports Nagios ranges. Example: `5:` (CRIT when below 5 days).",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "6fdbf84f-4a4a-414f-9ac5-b305a5302dbe"
        },
        "6": {
            "varname": "cert_filename",
            "caption": "Cert: Filename",
            "description": "Path to a certificate file or a glob pattern matching multiple certificate files. Required when --source=file. Files are read as PEM or DER (autodetected); when a PEM bundle contains multiple certificates (typical for fullchain.pem or a CA bundle), each certificate becomes its own row in the output. Globs follow Python conventions: `*` matches one path segment, `**` matches across directories. Always quote the pattern in shells so that the shell does not expand the wildcard before the plugin sees it. Example: `--filename='/etc/ssl/certs/*.pem'`. Recursive example: `--filename='/etc/letsencrypt/live/**/cert.pem'`",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "e1a3f93c-3ba0-42eb-8a51-732381792f9a"
        },
        "7": {
            "varname": "cert_insecure",
            "caption": "Cert: Insecure?",
            "description": "Skip chain and hostname verification entirely. The certificate is still fetched and inspected, but the chain verdict is reported as \"verification skipped\".",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "ba4bc30f-2b0d-477e-ad51-79cb7ea0fa5c"
        },
        "8": {
            "varname": "cert_lengthy",
            "caption": "Cert: Lengthy?",
            "description": "Extended reporting.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeBoolean",
            "format": null,
            "settings": {},
            "uuid": "b2294ebc-36b0-4a9f-8f37-bb3520b255a5"
        },
        "9": {
            "varname": "cert_severity",
            "caption": "Cert: Severity",
            "description": "Severity assigned to hostname mismatch and chain verification failures. Defaults to %(default)s so that operators running internal CAs are not paged by trust issues that are expected in their environment. Set to `crit` to enforce strict trust.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeDatalist",
            "format": null,
            "settings": {
                "behavior": "strict",
                "data_type": "string",
                "datalist": "cert_severity_list"
            },
            "uuid": "87d1027d-8b39-4dab-9539-b8ae3ef09d0b"
        },
        "10": {
            "varname": "cert_sni_hostname",
            "caption": "Cert: Sni Hostname",
            "description": "SNI hostname sent during the TLS handshake and used for hostname verification. Useful when --url points at an IP address or a load balancer that needs an explicit SNI. Default uses the hostname from --url.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "b5ca62eb-7883-4d08-87c8-d31190c9efad"
        },
        "11": {
            "varname": "cert_source",
            "caption": "Cert: Source",
            "description": "Where the certificate is fetched from. `url` fetches it from a TLS endpoint (requires --url). `file` reads it from one or many local files (requires --filename, supports glob patterns). `p12` and `jks` are reserved for future expansion.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeDatalist",
            "format": null,
            "settings": {
                "behavior": "strict",
                "data_type": "string",
                "datalist": "cert_source_list"
            },
            "uuid": "584dc1b2-48e8-40cb-82eb-6aa546b5d183"
        },
        "12": {
            "varname": "cert_timeout",
            "caption": "Cert: Timeout",
            "description": "Network timeout in seconds.",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "2ae3b17a-3261-4167-a573-3034ff7c72c5"
        },
        "13": {
            "varname": "cert_url",
            "caption": "Cert: URL",
            "description": "URL of the TLS endpoint to inspect. Required when --source=url. Example: `https://www.example.com/`",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
            "settings": {
                "visibility": "visible"
            },
            "uuid": "02140b96-19c6-4d46-8d9a-a50afb1278ea"
        },
        "14": {
            "varname": "cert_warning",
            "caption": "Cert: Warning",
            "description": "WARN threshold for days remaining until the certificate expires. Supports Nagios ranges. Example: `14:` (WARN when below 14 days).",
            "datatype": "Icinga\\Module\\Director\\DataType\\DataTypeString",
            "format": null,
