import sys

sys.path.insert(0, '..')

import unittest

import lib.lftest
from lib.globals import STATE_OK, STATE_UNKNOWN, STATE_WARN

TESTS = [
    {
        'id': 'ok-all-services-running',
        'test': 'stdout/all-services-running,,0',
        'assert-retc': STATE_OK,
        'assert-in': [
            'Everything is ok.',
            'cache             ! Running',
            'gitaly            ! Running',
            'queues            ! Running',
        ],
    },
    {
        'id': 'warn-most-services-unhealthy',
        'test': 'stdout/most-services-unhealthy,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'There are issues with cache_check,',
            'cache             ! [WARNING] unexpected Cache check result',
            'db                ! Running',
            'gitaly            ! Running',
        ],
    },
    {
        'id': 'warn-gitaly-unhealthy-keys-order-v1',
        'test': 'stdout/gitaly-unhealthy-keys-order-v1,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'There are issues with gitaly_check.',
            'gitaly            ! [WARNING] 14:connections to all backends failing',
        ],
    },
    {
        'id': 'warn-gitaly-unhealthy-keys-order-v2',
        'test': 'stdout/gitaly-unhealthy-keys-order-v2,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            'There are issues with gitaly_check.',
            'gitaly            ! [WARNING] 14:connections to all backends failing',
        ],
    },
    {
        'id': 'warn-db-connection-error',
        'test': 'stdout/db-connection-error,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['ActiveRecord::DatabaseConnectionError'],
    },
    {
        'id': 'warn-bad-gateway',
        'test': 'stdout/bad-gateway,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['Bad Gateway'],
    },
    {
        'id': 'warn-nginx-502-workhorse',
        'test': 'stdout/nginx-502-workhorse,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['nginx returned 502 when communicating with gitlab-workhorse'],
    },
    {
        # Single-line JSON (no leading whitespace) triggers the
        # "Unknown error fetching URL" path because lib.url.fetch_json
        # treats it as a non-JSON response under the test harness.
        'id': 'unknown-single-line-status-ok',
        'test': 'stdout/single-line-status-ok,,0',
        'assert-retc': STATE_UNKNOWN,
        'assert-in': ['Unknown error fetching URL'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../gitlab-readiness'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
