import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK
import lib.lftest


TESTS = [
    {
        'id': 'ok-mongodb-11-percent-used',
        'test': 'stdout/mongodb-11-percent-used,,0',
        'params': '--token=253ff1ec-a5b8-4248-be1d-b898d298d8fc',
        'assert-retc': STATE_OK,
        'assert-in': [
            'MongoDB "nodebb": 11.2% Disk Usage (22.2GiB/197.4GiB), '
            '5 collections, 11 indexes, 175.8K objects',
        ],
    },
]


class TestCheck(unittest.TestCase):

    check = '../nodebb-database'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
