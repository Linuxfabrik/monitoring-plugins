import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


TESTS = [
    {
        'id': 'ok-no-failed-units',
        'test': 'stdout/no-failed-units,,0',
        'assert-retc': STATE_OK,
        'assert-regex': r'Everything is ok.',
    },
    {
        'id': 'warn-one-failed-openipmi',
        'test': 'stdout/one-failed-openipmi,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['1 failed unit: openipmi.service'],
    },
    {
        'id': 'warn-two-failed-openipmi-smartd',
        'test': 'stdout/two-failed-openipmi-smartd,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['2 failed units: openipmi.service, smartd.service'],
    },
    {
        'id': 'warn-two-failed-ignore-openipmi',
        'test': 'stdout/two-failed-openipmi-smartd,,0',
        'params': '--ignore=openipmi.service',
        'assert-retc': STATE_WARN,
        'assert-in': ['1 failed unit: smartd.service'],
    },
    {
        'id': 'ok-two-failed-ignore-both',
        'test': 'stdout/two-failed-openipmi-smartd,,0',
        'params': '--ignore=openipmi.service --ignore=smartd.service',
        'assert-retc': STATE_OK,
        'assert-regex': r'Everything is ok.',
    },
    {
        'id': 'ok-two-failed-ignore-both-plus-fantasy',
        'test': 'stdout/two-failed-openipmi-smartd,,0',
        'params': '--ignore=openipmi.service --ignore=smartd.service --ignore=fantasy.mount',
        'assert-retc': STATE_OK,
        'assert-regex': r'Everything is ok.',
    },
    {
        'id': 'warn-one-failed-chronyd',
        'test': 'stdout/one-failed-chronyd,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['1 failed unit: chronyd.service'],
    },
    {
        'id': 'warn-three-failed-tomcat-varnish',
        'test': 'stdout/three-failed-tomcat-varnish,,0',
        'assert-retc': STATE_WARN,
        'assert-in': [
            '3 failed units: tomcat8.service, varnish.service, varnishlog.service',
        ],
        'assert-regex': (
            r'tomcat8.service    ! not-found ! failed ! failed ! tomcat8.service'
        ),
    },
]


class TestCheck(unittest.TestCase):

    check = '../systemd-units-failed'


lib.lftest.attach_tests(TestCheck, TESTS)


if __name__ == '__main__':
    unittest.main()
