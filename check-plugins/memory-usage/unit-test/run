import sys
sys.path.insert(0, '..')

import unittest

from lib.globals import STATE_CRIT, STATE_OK, STATE_WARN
import lib.lftest


# The memory-usage plugin normally calls `psutil.virtual_memory()` and
# walks `psutil.process_iter()` for its `--top` table. Its `--test`
# hook reads a JSON fixture that mirrors the attributes of the
# `svmem` namedtuple:
#
#     {"total": <bytes>, "available": <bytes>, "percent": <0..100>,
#      "used": <bytes>, "free": <bytes>, "buffers": <bytes>,
#      "cached": <bytes>, "shared": <bytes>}
#
# When `--test` is active, the plugin forces `--top=0` internally so
# that the Top-N scan of real processes is skipped and the test stays
# deterministic.
TESTS = [
    {
        'id': 'ok-nominal',
        'test': 'stdout/ok-nominal,,0',
        'assert-retc': STATE_OK,
        'assert-in': ['50%', 'total:', 'used:', 'available:', 'free:'],
    },
    {
        'id': 'warn-above-warn',
        'test': 'stdout/warn-above-warn,,0',
        'assert-retc': STATE_WARN,
        'assert-in': ['92%', '[WARNING]'],
    },
    {
        'id': 'crit-near-exhaustion',
        'test': 'stdout/crit-near-exhaustion,,0',
        'assert-retc': STATE_CRIT,
        'assert-in': ['99%', '[CRITICAL]'],
    },
    {
        'id': 'ok-always-ok-masks-critical',
        'test': 'stdout/crit-near-exhaustion,,0',
        'params': '--always-ok',
        'assert-retc': STATE_OK,
        'assert-in': ['99%'],
    },
    {
        'id': 'ok-custom-thresholds-nominal-is-crit',
        'test': 'stdout/ok-nominal,,0',
        'params': '--warning=40 --critical=45',
        'assert-retc': STATE_CRIT,
        'assert-in': ['50%', '[CRITICAL]'],
    },
]


class TestCheck(unittest.TestCase):

    check = '../memory-usage'

    def test(self):
        for t in TESTS:
            with self.subTest(id=t['id']):
                lib.lftest.run(self, self.check, t)


if __name__ == '__main__':
    unittest.main()
