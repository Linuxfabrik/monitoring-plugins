            "imports": [
                "tpl-service-generic"
            ],
            "max_check_attempts": 5,
            "notes": "Checks user schemas in MySQL/MariaDB for two replication- and performance-relevant defects: base tables with no index at all (mysqltuner v2.8.41's `mysql_tables()` check) and InnoDB base tables without a user-defined `PRIMARY KEY`. The second case is a documented hotspot for ROW-based replication: the replica has to materialise each row event against an internal hidden 6-byte index, which can degrade to a full table scan per row event. Alerts when either count crosses `--warning` / `--critical`.",
            "notes_url": "https://linuxfabrik.github.io/monitoring-plugins/check-plugins/mysql-table-indexes/",
            "object_name": "tpl-service-mysql-table-indexes",
            "object_type": "template",
            "retry_interval": 15,
            "service_set": null,
            "template_choice": null,
            "use_agent": null,
            "use_var_overrides": null,
            "vars": {
                "criticality": "C",
                "mysql_table_indexes_always_ok": false,
                "mysql_table_indexes_critical": 10,
                "mysql_table_indexes_defaults_file": "/var/spool/icinga2/.my.cnf",
                "mysql_table_indexes_defaults_group": "client",
                "mysql_table_indexes_lengthy": true,
                "mysql_table_indexes_timeout": 3,
                "mysql_table_indexes_warning": 1
            },
