import os
import sys
import unittest

sys.path.insert(0, '..')

from lib.globals import STATE_OK, STATE_WARN
import lib.lftest


CACHE_DB = '/tmp/linuxfabrik-monitoring-plugins-apache-httpd-status.db'


# The apache-httpd-status plugin talks to Apache's `mod_status` endpoint
# (server-status?auto) which changes its field set across httpd versions
# and MPMs. The plugin also stores previous values in a local SQLite
# cache so that continuous counters can be converted into per-interval
# rates, which means realistic coverage needs **sequences** of fixture
# files that simulate consecutive invocations:
#
#   call 1  -> "Waiting for more data (1)."   (no prev_uptime)
#   call 2  -> "Waiting for more data (3)."   (no prev_duration_global,
#                                               only for Stage 3 output)
#   call 3  -> the real output
#
# For plugins that never reach the third stage (pre-2.4.35 httpd without
# `Total Duration`) the sequence stops after call 2.
#
# Fixtures are named `<os>-httpd-<version>-<mpm>-ext-<on|off>[-<n>]`
# and were captured against real podman containers:
#
#   - rhel7-httpd-2.4.6-prefork-*       : pre-2.4.13 format, no ConnsAsync,
#                                          no Total Duration (Stage 2 only)
#   - rhel8-httpd-2.4.37-event-*        : first RHEL with Total Duration
#                                          (Stage 3)
#   - rhel9-httpd-2.4.62-event-*        : current RHEL 9 httpd
#   - rhel10-httpd-2.4.63-event-*       : current RHEL 10 httpd
#   - fedora34-httpd-2.4.48-event-*     : Fedora with event MPM (Stage 3)
#   - fedora34-httpd-2.4.48-worker-*    : worker MPM, which does NOT
#                                          emit ConnsTotal/ConnsAsync*,
#                                          so exercises the "field is
#                                          missing" branches
#   - fedora34-httpd-2.4.48-worker-...-no-cpuload-*
#                                       : additionally lacks CPULoad,
#                                          exercises that optional-field
#                                          branch
#
# Each scenario lists its steps; the cache DB is deleted before each
# scenario so the sequences do not bleed into each other.

STAGE1_REGEX = r'\d+/\d+ workers busy'
STAGE2_REGEX = r'\d+/\d+ workers busy.*accesses.*traffic'
STAGE3_REGEX = r'\S+: \d+/\d+ workers busy.*accesses.*traffic; Up '
WARN_REGEX = r'workers busy \(\d+\.\d+% \[WARNING\]'


SCENARIOS = [
    {
        'id': 'rhel7-httpd-2.4.6-prefork-ext-off',
        'steps': [
            {
                'test': 'stdout/rhel7-httpd-2.4.6-prefork-ext-off,,0',
                'assert-retc': STATE_OK,
                'assert-regex': STAGE1_REGEX,
            },
        ],
    },
    {
        'id': 'rhel7-httpd-2.4.6-prefork-ext-on',
        'steps': [
            {
                'test': 'stdout/rhel7-httpd-2.4.6-prefork-ext-on-1,,0',
                'assert-retc': STATE_OK,
                'assert-in': ['Waiting for more data (1).'],
            },
            {
                'test': 'stdout/rhel7-httpd-2.4.6-prefork-ext-on-2,,0',
                'assert-retc': STATE_OK,
                'assert-regex': STAGE2_REGEX,
            },
        ],
    },
    {
        'id': 'rhel8-httpd-2.4.37-event-ext-off',
