            {
                'test': 'stdout/rhel8-httpd-2.4.37-event-ext-off,,0',
                'assert-retc': STATE_OK,
                'assert-regex': STAGE1_REGEX,
            },
        ],
    },
    {
        'id': 'rhel8-httpd-2.4.37-event-ext-on',
