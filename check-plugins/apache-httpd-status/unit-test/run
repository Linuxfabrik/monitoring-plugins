            },
        ],
    },
    {
        # Same shape as the worker scenario above but additionally
        # misses CPULoad, which the plugin handles via another
        # "field is missing" branch.
        'id': 'fedora34-httpd-2.4.48-worker-ext-on-no-cpuload',
        'steps': [
