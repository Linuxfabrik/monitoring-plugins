# Windows-specific extension of requirements.in. Generates
# `lockfiles/py313-windows/requirements.txt` (Nuitka build host runs
# Python 3.13; see BUILD.md). Lives in its own subdirectory so the
# Dependabot `pip` watch at `/lockfiles/py313-windows` is independent
# from the Linux lockfiles.
#
# To regenerate:
#   python3.13 -m venv .venv-py313
#   source .venv-py313/bin/activate
#   python -m pip install 'pip<25.1' pip-tools
#   mkdir -p lockfiles/py313-windows
#   python -m piptools compile --generate-hashes \
#       --strip-extras --allow-unsafe \
#       --output-file=lockfiles/py313-windows/requirements.txt \
#       requirements-py313-windows.in

linuxfabrik-lib

# Needed on Windows only:
sspilib
