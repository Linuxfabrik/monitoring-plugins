# Windows-specific extension of requirements.in. Generates
# `requirements-py313-windows.txt` (Nuitka build host runs Python 3.13;
# see BUILD.md).
#
# To regenerate:
#   python3.13 -m venv .venv-py313
#   source .venv-py313/bin/activate
#   python -m pip install 'pip<25.1' pip-tools
#   python -m piptools compile --generate-hashes \
#       --output-file=requirements-py313-windows.txt requirements-windows.in

linuxfabrik-lib

# Needed on Windows only:
sspilib
